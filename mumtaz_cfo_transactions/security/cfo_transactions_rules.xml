<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="rule_mumtaz_cfo_transaction_company_scope" model="ir.rule">
        <field name="name">CFO transaction company scope</field>
        <field name="model_id" ref="model_mumtaz_cfo_transaction"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('mumtaz_cfo_base.group_mumtaz_cfo_user'))]"/>
    </record>

    <record id="rule_mumtaz_cfo_review_item_company_scope" model="ir.rule">
        <field name="name">CFO review item company scope</field>
        <field name="model_id" ref="model_mumtaz_cfo_review_item"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('mumtaz_cfo_base.group_mumtaz_cfo_user'))]"/>
    </record>
</odoo>
