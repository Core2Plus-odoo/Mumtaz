              name="Lead Nurture"
              parent="crm.crm_menu_root"
              sequence="30"
              groups="mumtaz_lead_nurture.group_lead_nurture_user"/>

    <menuitem id="menu_nurture_leads"
              name="Nurture Leads"
              parent="menu_lead_nurture_root"
              action="action_nurture_leads"
              sequence="10"/>

    <menuitem id="menu_nurture_campaigns"
              name="Campaigns"
              parent="menu_lead_nurture_root"
