<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="lead_nurture_log_list" model="ir.ui.view">
        <field name="name">lead.nurture.log.list</field>
        <field name="model">lead.nurture.log</field>
        <field name="arch" type="xml">
            <list string="Communication Log" create="false" edit="false"
                  decoration-danger="status == 'failed' or status == 'bounced'"
                  decoration-success="status == 'replied'"
                  decoration-info="status == 'opened'">
                <field name="timestamp"/>
                <field name="lead_id"/>
                <field name="campaign_name" string="Campaign" optional="show"/>
                <field name="channel"/>
                <field name="status"/>
                <field name="subject"/>
                <field name="score_change" string="Score"/>
                <field name="provider_ref" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="lead_nurture_log_form" model="ir.ui.view">
        <field name="name">lead.nurture.log.form</field>
        <field name="model">lead.nurture.log</field>
        <field name="arch" type="xml">
            <form string="Communication Log Entry" create="false">
                <sheet>
                    <group>
                        <group>
                            <field name="lead_id"/>
                            <field name="campaign_id"/>
                            <field name="step_id"/>
                            <field name="channel"/>
                            <field name="status"/>
                            <field name="timestamp"/>
                            <field name="score_change"/>
                        </group>
                        <group>
                            <field name="subject"/>
                            <field name="provider_ref"/>
                        </group>
                    </group>
                    <group string="Message Preview">
                        <field name="body_preview" nolabel="1" readonly="1"/>
                    </group>
                    <group string="Response">
                        <field name="response_summary" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="lead_nurture_log_search" model="ir.ui.view">
        <field name="name">lead.nurture.log.search</field>
        <field name="model">lead.nurture.log</field>
        <field name="arch" type="xml">
            <search string="Communication Log">
                <field name="lead_id"/>
                <field name="campaign_id"/>
                <filter string="Email" name="email" domain="[('channel','=','email')]"/>
                <filter string="WhatsApp" name="whatsapp" domain="[('channel','=','whatsapp')]"/>
                <filter string="Replied" name="replied" domain="[('status','=','replied')]"/>
                <filter string="Failed" name="failed" domain="[('status','in',['failed','bounced'])]"/>
                <filter string="By Campaign" name="group_campaign" context="{'group_by': 'campaign_id'}"/>
                <filter string="By Channel" name="group_channel" context="{'group_by': 'channel'}"/>
            </search>
        </field>
    </record>

    <record id="action_lead_nurture_log" model="ir.actions.act_window">
        <field name="name">Communication Log</field>
        <field name="res_model">lead.nurture.log</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No communication logs yet.</p>
        </field>
    </record>

</odoo>
