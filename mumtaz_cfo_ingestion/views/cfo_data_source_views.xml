<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_mumtaz_cfo_data_source_tree" model="ir.ui.view">
        <field name="name">mumtaz.cfo.data.source.tree</field>
        <field name="model">mumtaz.cfo.data.source</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="workspace_id"/>
                <field name="source_type"/>
                <field name="mapping_profile_id"/>
                <field name="upload_batch_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_mumtaz_cfo_data_source_form" model="ir.ui.view">
        <field name="name">mumtaz.cfo.data.source.form</field>
        <field name="model">mumtaz.cfo.data.source</field>
        <field name="arch" type="xml">
            <form string="CFO Data Source">
                <header>
                    <button name="action_view_upload_batches" string="Upload Batches" type="object"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="workspace_id"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                            <field name="source_type"/>
                        </group>
                        <group>
                            <field name="mapping_profile_id"/>
                            <field name="external_ref"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mumtaz_cfo_data_source" model="ir.actions.act_window">
        <field name="name">Data Sources</field>
        <field name="res_model">mumtaz.cfo.data.source</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
