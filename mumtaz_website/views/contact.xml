<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="contact" name="Mumtaz — Contact">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>
            <t t-call="mumtaz_website.website_navbar"/>

            <section class="mzw-page-hero">
                <div class="mzw-section-inner">
                    <div class="mzw-section-label">Get in touch</div>
                    <h1 class="mzw-section-title">Let's talk</h1>
                    <p class="mzw-page-hero-sub">
                        Whether you need a demo, have questions, or want to discuss a custom plan —
                        our team is here.
                    </p>
                </div>
            </section>

            <section class="mzw-contact-section">
                <div class="mzw-section-inner">
                    <div class="mzw-contact-grid">

                        <!-- Contact options -->
                        <div class="mzw-contact-info">
                            <div class="mzw-contact-card">
                                <div class="mzw-contact-icon">💼</div>
                                <h3>Sales</h3>
                                <p>Request a demo or discuss your plan options.</p>
                                <a href="mailto:sales@mumtaz.digital" class="mzw-contact-link">
                                    sales@mumtaz.digital
                                </a>
                            </div>
                            <div class="mzw-contact-card">
                                <div class="mzw-contact-icon">🛠️</div>
                                <h3>Support</h3>
                                <p>Technical help, account issues, or platform questions.</p>
                                <a href="mailto:support@mumtaz.digital" class="mzw-contact-link">
                                    support@mumtaz.digital
                                </a>
                            </div>
                            <div class="mzw-contact-card">
                                <div class="mzw-contact-icon">🤝</div>
                                <h3>Partnerships</h3>
                                <p>Interested in white-labelling or reselling Mumtaz?</p>
                                <a href="mailto:partners@mumtaz.digital" class="mzw-contact-link">
                                    partners@mumtaz.digital
                                </a>
                            </div>
                        </div>

                        <!-- CTA panel -->
                        <div class="mzw-contact-cta-panel">
                            <div class="mzw-cta-panel-inner">
                                <h2>Request a Demo</h2>
                                <p>
                                    Send us a message at
                                    <a href="mailto:sales@mumtaz.digital">sales@mumtaz.digital</a>
                                    with your company name and what you'd like to see, and we'll
                                    schedule a personalised walkthrough within 24 hours.
                                </p>
                                <div class="mzw-cta-panel-checklist">
                                    <div class="mzw-cpc-item">✓ Full platform walkthrough</div>
                                    <div class="mzw-cpc-item">✓ Live ZAKI AI demo</div>
                                    <div class="mzw-cpc-item">✓ Tailored to your industry</div>
                                    <div class="mzw-cpc-item">✓ No commitment required</div>
                                </div>
                                <a href="mailto:sales@mumtaz.digital?subject=Demo%20Request%20from%20mumtaz.digital"
                                   class="mzw-btn mzw-btn-primary mzw-btn-lg">
                                    Email Us Now
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            </section>

            <t t-call="mumtaz_website.website_footer"/>
        </t>
    </template>
</odoo>
