<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_mumtaz_voice_session_list" model="ir.ui.view">
        <field name="name">mumtaz.voice.session.list</field>
        <field name="model">mumtaz.voice.session</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/><field name="user_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="status"/><field name="message_count" string="Messages"/>
                <field name="model_used"/><field name="create_date" string="Started"/>
            </list>
        </field>
    </record>
    <record id="view_mumtaz_voice_session_form" model="ir.ui.view">
        <field name="name">mumtaz.voice.session.form</field>
        <field name="model">mumtaz.voice.session</field>
        <field name="arch" type="xml">
            <form string="CFO Voice Session">
                <header>
                    <button name="action_ask" string="Ask CFO" type="object" class="oe_highlight" invisible="not transcript"/>
                    <button name="action_clear_session" string="Clear" type="object"/>
                    <button name="action_view_history" string="View History" type="object"/>
                    <field name="status" widget="statusbar" statusbar_visible="idle,processing,done,error"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-comments" type="object" name="action_view_history">
                            <field name="message_count" widget="statinfo" string="Messages"/>
                        </button>
                    </div>
                    <group>
                        <field name="name"/><field name="user_id"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <group string="Your Question">
                        <field name="transcript" placeholder="Type your CFO question here…" nolabel="1"/>
                    </group>
                    <group string="CFO Response">
                        <field name="response" nolabel="1" readonly="1"/>
                        <field name="intent" readonly="1"/>
                        <field name="model_used" readonly="1"/>
                        <field name="token_usage" readonly="1"/>
                        <field name="last_error" readonly="1" invisible="not last_error"/>
                    </group>
                    <notebook>
                        <page string="Conversation History">
                            <field name="message_ids" readonly="1">
                                <list create="0" delete="0">
                                    <field name="create_date" string="Time"/><field name="role"/>
                                    <field name="content"/><field name="intent"/>
                                    <field name="model_used"/><field name="token_usage"/>
                                </list>
                            </field>
                        </page>
                        <page string="Financial Context" invisible="not financial_context">
                            <field name="financial_context" nolabel="1" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_mumtaz_voice_assistant" model="ir.actions.client">
        <field name="name">CFO Voice Assistant</field>
        <field name="tag">mumtaz_voice_assistant</field>
    </record>
    <record id="action_mumtaz_voice_sessions" model="ir.actions.act_window">
        <field name="name">Voice Sessions</field>
        <field name="res_model">mumtaz.voice.session</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_mumtaz_voice_messages" model="ir.actions.act_window">
        <field name="name">Conversation History</field>
        <field name="res_model">mumtaz.voice.message</field>
        <field name="view_mode">list</field>
    </record>
    <menuitem id="menu_mumtaz_voice_assistant" name="CFO Voice Assistant"
              parent="mumtaz_core.menu_mumtaz_root" action="action_mumtaz_voice_assistant"
              sequence="5" groups="base.group_user"/>
    <menuitem id="menu_mumtaz_voice_sessions" name="Voice Sessions"
              parent="mumtaz_core.menu_mumtaz_root" action="action_mumtaz_voice_sessions"
              sequence="6" groups="base.group_user"/>
    <menuitem id="menu_mumtaz_voice_history" name="Conversation History"
              parent="mumtaz_core.menu_mumtaz_root" action="action_mumtaz_voice_messages"
              sequence="7" groups="mumtaz_core.group_mumtaz_manager"/>
</odoo>
