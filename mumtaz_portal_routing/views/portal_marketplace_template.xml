<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_marketplace_home" name="Mumtaz Marketplace Portal">
        <t t-call="mumtaz_portal_routing.portal_base_layout">

            <!-- Page header -->
            <div class="mzp-page-header mzp-header-marketplace">
                <div class="mzp-page-header-inner">
                    <div>
                        <h1 class="mzp-page-title">Marketplace</h1>
                        <p class="mzp-page-subtitle">
                            Discover products, services, and partnership opportunities across the SME network
                        </p>
                    </div>
                    <div class="mzp-header-actions">
                        <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings&amp;view_type=form"
                           class="mzp-btn mzp-btn-primary">
                            + Post Listing
                        </a>
                        <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings"
                           class="mzp-btn mzp-btn-ghost">
                            Browse All
                        </a>
                    </div>
                </div>
            </div>

            <!-- Stat cards -->
            <div class="mzp-section">
                <div class="mzp-stat-grid mzp-stat-grid-4">
                    <div class="mzp-stat-card">
                        <div class="mzp-stat-value">
                            <t t-esc="total_listings"/>
                        </div>
                        <div class="mzp-stat-label">Active Listings</div>
                        <div class="mzp-stat-detail">Published on marketplace</div>
                    </div>
                    <div class="mzp-stat-card mzp-stat-primary">
                        <div class="mzp-stat-value">
                            <t t-esc="my_listings"/>
                        </div>
                        <div class="mzp-stat-label">My Published</div>
                        <div class="mzp-stat-detail">
                            <t t-if="my_draft_listings &gt; 0">
                                <t t-esc="my_draft_listings"/> draft(s)
                            </t>
                        </div>
                    </div>
                    <t t-if="new_inquiry_count &gt; 0">
                        <div class="mzp-stat-card mzp-stat-warning">
                            <div class="mzp-stat-value">
                                <t t-esc="new_inquiry_count"/>
                            </div>
                            <div class="mzp-stat-label">New Inquiries</div>
                            <div class="mzp-stat-detail">Awaiting response</div>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="mzp-stat-card mzp-stat-success">
                            <div class="mzp-stat-value">
                                <t t-esc="inquiry_count"/>
                            </div>
                            <div class="mzp-stat-label">Total Inquiries</div>
                            <div class="mzp-stat-detail">All responded</div>
                        </div>
                    </t>
                    <div class="mzp-stat-card">
                        <div class="mzp-stat-value">
                            <t t-esc="product_count + service_count + partnership_count"/>
                        </div>
                        <div class="mzp-stat-label">All Types</div>
                        <div class="mzp-stat-detail">
                            <t t-esc="product_count"/>P · <t t-esc="service_count"/>S · <t t-esc="partnership_count"/>P
                        </div>
                    </div>
                </div>
            </div>

            <!-- Listing type breakdown -->
            <t t-if="total_listings &gt; 0">
                <div class="mzp-section">
                    <div class="mzp-intel-banner mzp-intel-marketplace">
                        <div class="mzp-intel-item">
                            <span class="mzp-intel-icon">📦</span>
                            <div class="mzp-intel-body">
                                <div class="mzp-intel-value"><t t-esc="product_count"/></div>
                                <div class="mzp-intel-label">Products</div>
                            </div>
                        </div>
                        <div class="mzp-intel-divider"></div>
                        <div class="mzp-intel-item">
                            <span class="mzp-intel-icon">🔧</span>
                            <div class="mzp-intel-body">
                                <div class="mzp-intel-value"><t t-esc="service_count"/></div>
                                <div class="mzp-intel-label">Services</div>
                            </div>
                        </div>
                        <div class="mzp-intel-divider"></div>
                        <div class="mzp-intel-item">
                            <span class="mzp-intel-icon">🤝</span>
                            <div class="mzp-intel-body">
                                <div class="mzp-intel-value"><t t-esc="partnership_count"/></div>
                                <div class="mzp-intel-label">Partnerships</div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>

            <!-- Quick actions -->
            <div class="mzp-section">
                <h2 class="mzp-section-title">Quick Actions</h2>
                <div class="mzp-quick-actions">
                    <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings"
                       class="mzp-action-card">
                        <div class="mzp-action-icon">🛒</div>
                        <div class="mzp-action-label">Browse Listings</div>
                    </a>
                    <a href="/web#action=mumtaz_marketplace.action_mumtaz_my_listings"
                       class="mzp-action-card">
                        <div class="mzp-action-icon">📋</div>
                        <div class="mzp-action-label">My Listings
                            <t t-if="my_listings &gt; 0">
                                <span class="mzp-action-badge">
                                    <t t-esc="my_listings"/>
                                </span>
                            </t>
                        </div>
                    </a>
                    <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_inquiries"
                       class="mzp-action-card">
                        <div class="mzp-action-icon">💬</div>
                        <div class="mzp-action-label">
                            Inquiries
                            <t t-if="new_inquiry_count &gt; 0">
                                <span class="mzp-action-badge mzp-badge-warning">
                                    <t t-esc="new_inquiry_count"/>
                                </span>
                            </t>
                        </div>
                    </a>
                    <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings&amp;view_type=form"
                       class="mzp-action-card mzp-action-featured">
                        <div class="mzp-action-icon">✏️</div>
                        <div class="mzp-action-label">Post New Listing</div>
                    </a>
                    <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_categories"
                       class="mzp-action-card">
                        <div class="mzp-action-icon">🏷️</div>
                        <div class="mzp-action-label">Categories</div>
                    </a>
                    <a href="/web#action=mumtaz_lead_scraper.action_lead_scraper_record"
                       class="mzp-action-card">
                        <div class="mzp-action-icon">📊</div>
                        <div class="mzp-action-label">Analytics</div>
                    </a>
                </div>
            </div>

            <!-- Categories grid -->
            <t t-if="categories">
                <div class="mzp-section">
                    <div class="mzp-section-header">
                        <h2 class="mzp-section-title">Browse by Category</h2>
                        <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_categories"
                           class="mzp-section-link">Manage →</a>
                    </div>
                    <div class="mzp-category-grid">
                        <t t-foreach="categories" t-as="cat">
                            <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings"
                               class="mzp-category-card">
                                <div class="mzp-category-icon">
                                    <t t-if="cat.icon">
                                        <i t-att-class="'fa ' + cat.icon"/>
                                    </t>
                                    <t t-else="">🏷️</t>
                                </div>
                                <div class="mzp-category-name">
                                    <t t-esc="cat.name"/>
                                </div>
                                <div class="mzp-category-count">
                                    <t t-esc="cat.listing_count or 0"/> listings
                                </div>
                            </a>
                        </t>
                    </div>
                </div>
            </t>

            <!-- Recent inquiries -->
            <t t-if="recent_inquiries">
                <div class="mzp-section">
                    <div class="mzp-section-header">
                        <h2 class="mzp-section-title">Recent Inquiries</h2>
                        <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_inquiries"
                           class="mzp-section-link">View all →</a>
                    </div>
                    <div class="mzp-session-list">
                        <t t-foreach="recent_inquiries" t-as="inq">
                            <a t-att-href="'/web#id=' + str(inq.id) + '&amp;model=mumtaz.marketplace.inquiry&amp;view_type=form'"
                               class="mzp-session-item">
                                <div class="mzp-session-icon">
                                    <t t-if="inq.state == 'new'">🆕</t>
                                    <t t-elif="inq.state == 'in_progress'">⏳</t>
                                    <t t-elif="inq.state == 'responded'">✅</t>
                                    <t t-else="">📋</t>
                                </div>
                                <div class="mzp-session-body">
                                    <div class="mzp-session-name">
                                        <t t-esc="inq.inquirer_name or inq.inquirer_company or 'Inquiry'"/>
                                        <t t-if="inq.listing_id">
                                            — <t t-esc="inq.listing_id.name"/>
                                        </t>
                                    </div>
                                    <div class="mzp-session-meta">
                                        <span t-att-class="'mzp-badge mzp-badge-' + ('warning' if inq.state == 'new' else 'success' if inq.state == 'responded' else 'draft')">
                                            <t t-esc="inq.state"/>
                                        </span>
                                        · <t t-esc="inq.create_date" t-options='{"widget": "datetime"}'/>
                                    </div>
                                </div>
                                <div class="mzp-session-arrow">→</div>
                            </a>
                        </t>
                    </div>
                </div>
            </t>

            <!-- Featured listings -->
            <div class="mzp-section">
                <div class="mzp-section-header">
                    <h2 class="mzp-section-title">Latest Listings</h2>
                    <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings"
                       class="mzp-section-link">View all →</a>
                </div>
                <t t-if="featured_listings">
                    <div class="mzp-listing-grid">
                        <t t-foreach="featured_listings" t-as="listing">
                            <a t-att-href="'/web#id=' + str(listing.id) + '&amp;model=mumtaz.marketplace.listing&amp;view_type=form'"
                               class="mzp-listing-card">
                                <div class="mzp-listing-header">
                                    <span class="mzp-badge mzp-badge-published">
                                        <t t-esc="listing.listing_type or 'listing'"/>
                                    </span>
                                    <t t-if="listing.category_id">
                                        <span class="mzp-listing-category">
                                            <t t-esc="listing.category_id.name"/>
                                        </span>
                                    </t>
                                </div>
                                <h3 class="mzp-listing-title">
                                    <t t-esc="listing.name"/>
                                </h3>
                                <t t-if="listing.short_description">
                                    <p class="mzp-listing-summary">
                                        <t t-esc="listing.short_description"/>
                                    </p>
                                </t>
                                <div class="mzp-listing-footer">
                                    <span class="mzp-listing-price">
                                        <t t-if="listing.price_type == 'free'">Free</t>
                                        <t t-elif="listing.price_type == 'negotiable'">Negotiable</t>
                                        <t t-elif="listing.price_type == 'from'">From <t t-esc="'%.0f' % (listing.price or 0)"/></t>
                                        <t t-else=""><t t-esc="'%.0f' % (listing.price or 0)"/></t>
                                    </span>
                                    <span class="mzp-listing-company">
                                        <t t-esc="listing.company_id.name"/>
                                    </span>
                                </div>
                            </a>
                        </t>
                    </div>
                </t>
                <t t-else="">
                    <div class="mzp-empty-state mzp-empty-state-large">
                        <div class="mzp-empty-icon">🛒</div>
                        <h3>No Listings Yet</h3>
                        <p>Be the first to post a product, service, or partnership opportunity.</p>
                        <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings&amp;view_type=form"
                           class="mzp-btn mzp-btn-primary">
                            Post a Listing
                        </a>
                    </div>
                </t>
            </div>

        </t>
    </template>
</odoo>
