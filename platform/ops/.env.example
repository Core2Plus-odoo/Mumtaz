# =====================================================================
#  Mumtaz Platform — environment template
#  Copy to /opt/mumtaz/.env on the server and fill REAL values.
#  NEVER commit the real .env. NOTHING here is hardcoded in app code.
#  Brand is Mumtaz ivory/gold/Inter (set at the UI layer, not here).
#
#  RULES for this file (so the installer can parse it safely):
#   - One KEY=VALUE per line. No inline comments after a value.
#   - Do not wrap values in quotes. Special chars (! @ #) are fine.
#   - Comment lines start with # in column 1.
# =====================================================================

NODE_ENV=production
ENVIRONMENT=production

# Secrets — leave JWT_SECRET blank and the installer generates one.
JWT_SECRET=
JWT_EXPIRY_SECONDS=86400

# Platform database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=mumtaz_admin
DB_PASS=CHANGE_ME_STRONG
DB_NAME=mumtaz_platform

# Odoo
ODOO_URL=https://erp.mumtaz.digital
ODOO_MASTER_PW=CHANGE_ME_STRONG
ODOO_ADMIN_EMAIL=umer@mumtaz.digital
ODOO_ADMIN_PASS=CHANGE_ME_STRONG
ODOO_BIN=/opt/mumtaz/odoo/server/odoo-bin
ODOO_CONF=/etc/odoo19.conf
ODOO_VENV=/opt/mumtaz/odoo/venv/bin/python

# AI / Voice (required for ZAKI). Current model id; spec's dated id is stale.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Platform owner (super admin). Password used once at bootstrap, bcrypt-hashed.
SUPER_ADMIN_EMAIL=umer@mumtaz.digital
SUPER_ADMIN_PASSWORD=CHANGE_ME_STRONG
MUMTAZ_OWNERS=umer@mumtaz.digital

# URLs
PLATFORM_URL=https://app.mumtaz.digital
ERP_URL=https://erp.mumtaz.digital
ZAKI_URL=https://zaki.mumtaz.digital
MARKETING_URL=https://mumtaz.digital
REDIS_URL=redis://localhost:6379

# CORS allowlist (never *)
CORS_ORIGINS=https://app.mumtaz.digital,https://zaki.mumtaz.digital,https://erp.mumtaz.digital,https://mumtaz.digital
