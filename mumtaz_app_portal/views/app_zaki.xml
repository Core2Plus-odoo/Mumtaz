<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="app_zaki" name="Mumtaz App — ZAKI AI Section">
        <t t-call="mumtaz_app_portal.app_base_layout">

            <div class="mza-page">

                <!-- Section header -->
                <div class="mza-section-hero mza-hero-zaki">
                    <div class="mza-hero-inner">
                        <div>
                            <h1 class="mza-hero-title">ZAKI AI</h1>
                            <p class="mza-hero-sub">Your AI CFO — financial intelligence, transaction analytics, AI-powered insights</p>
                        </div>
                        <div class="mza-hero-actions">
                            <a href="/mumtaz/ai" class="mza-btn mza-btn-gold">🤖 Ask ZAKI</a>
                            <a href="/mumtaz/cfo" class="mza-btn mza-btn-ghost">CFO Workspace</a>
                        </div>
                    </div>
                </div>

                <!-- Financial stats -->
                <div class="mza-section">
                    <div class="mza-stat-row">
                        <div class="mza-stat-card">
                            <div class="mza-stat-val"><t t-esc="tx_count"/></div>
                            <div class="mza-stat-lbl">Transactions</div>
                        </div>
                        <t t-if="review_count &gt; 0">
                            <div class="mza-stat-card mza-stat-warning">
                                <div class="mza-stat-val"><t t-esc="review_count"/></div>
                                <div class="mza-stat-lbl">Pending Review</div>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="mza-stat-card mza-stat-success">
                                <div class="mza-stat-val">✓</div>
                                <div class="mza-stat-lbl">Review Clear</div>
                            </div>
                        </t>
                        <div class="mza-stat-card mza-stat-success">
                            <div class="mza-stat-val"><t t-esc="'%.0f' % income_total"/></div>
                            <div class="mza-stat-lbl">Total Inflow</div>
                        </div>
                        <div class="mza-stat-card mza-stat-danger">
                            <div class="mza-stat-val"><t t-esc="'%.0f' % expense_total"/></div>
                            <div class="mza-stat-lbl">Total Outflow</div>
                        </div>
                    </div>
                </div>

                <!-- Net position banner -->
                <t t-if="tx_count &gt; 0">
                    <div class="mza-section">
                        <t t-set="net" t-value="income_total - expense_total"/>
                        <div t-att-class="'mza-net-banner ' + ('mza-net-pos' if net &gt;= 0 else 'mza-net-neg')">
                            <div class="mza-net-label">Net Position</div>
                            <div class="mza-net-value">
                                <t t-esc="('+ ' if net &gt;= 0 else '− ') + '%.2f' % abs(net)"/>
                            </div>
                            <t t-if="workspace">
                                <div class="mza-net-workspace"><t t-esc="workspace.name"/></div>
                            </t>
                        </div>
                    </div>
                </t>

                <!-- Quick actions -->
                <div class="mza-section">
                    <h2 class="mza-section-title">Actions</h2>
                    <div class="mza-action-grid">
                        <a href="/mumtaz/ai" class="mza-action-tile mza-tile-gold">
                            <span class="mza-tile-icon">🤖</span>
                            <span class="mza-tile-lbl">Ask ZAKI AI</span>
                        </a>
                        <a href="/mumtaz/cfo" class="mza-action-tile">
                            <span class="mza-tile-icon">📊</span>
                            <span class="mza-tile-lbl">CFO Workspace</span>
                        </a>
                        <a href="/web#action=mumtaz_cfo_transactions.action_cfo_transaction_list"
                           class="mza-action-tile">
                            <span class="mza-tile-icon">💳</span>
                            <span class="mza-tile-lbl">Transactions</span>
                        </a>
                        <a href="/web#action=mumtaz_cfo_transactions.action_cfo_review_queue"
                           class="mza-action-tile">
                            <span class="mza-tile-icon">🔎</span>
                            <span class="mza-tile-lbl">Review Queue
                                <t t-if="review_count &gt; 0">
                                    <span class="mza-badge mza-badge-warning"><t t-esc="review_count"/></span>
                                </t>
                            </span>
                        </a>
                        <a href="/mumtaz/finance" class="mza-action-tile">
                            <span class="mza-tile-icon">🏦</span>
                            <span class="mza-tile-lbl">Finance Hub</span>
                        </a>
                        <a href="/web#action=mumtaz_cfo_ingestion.action_cfo_upload_batch"
                           class="mza-action-tile">
                            <span class="mza-tile-icon">⬆️</span>
                            <span class="mza-tile-lbl">Upload Data</span>
                        </a>
                    </div>
                </div>

                <!-- Recent AI sessions -->
                <t t-if="recent_sessions">
                    <div class="mza-section">
                        <div class="mza-section-hdr">
                            <h2 class="mza-section-title">AI Sessions</h2>
                            <span class="mza-section-meta"><t t-esc="ai_session_count"/> total</span>
                        </div>
                        <div class="mza-list">
                            <t t-foreach="recent_sessions" t-as="session">
                                <a t-att-href="'/mumtaz/ai?session=' + str(session.id)"
                                   class="mza-list-item">
                                    <span class="mza-list-icon">💬</span>
                                    <div class="mza-list-body">
                                        <div class="mza-list-title">
                                            <t t-esc="session.name or 'AI Session'"/>
                                        </div>
                                        <div class="mza-list-meta">
                                            <t t-esc="session.create_date" t-options='{"widget": "datetime"}'/>
                                        </div>
                                    </div>
                                    <span class="mza-list-arrow">→</span>
                                </a>
                            </t>
                        </div>
                    </div>
                </t>

                <!-- Recent transactions -->
                <t t-if="recent_txs">
                    <div class="mza-section">
                        <div class="mza-section-hdr">
                            <h2 class="mza-section-title">Recent Transactions</h2>
                            <a href="/mumtaz/cfo" class="mza-section-link">View all →</a>
                        </div>
                        <div class="mza-table-wrap">
                            <table class="mza-table">
                                <thead>
                                    <tr>
                                        <th>Date</th><th>Description</th>
                                        <th>Direction</th><th class="mza-th-right">Amount</th><th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="recent_txs" t-as="tx">
                                        <tr>
                                            <td><t t-esc="tx.date" t-options='{"widget": "date"}'/></td>
                                            <td class="mza-td-primary"><t t-esc="tx.description or '—'"/></td>
                                            <td>
                                                <span t-att-class="'mza-badge mza-badge-' + ('success' if tx.direction == 'inflow' else 'danger')">
                                                    <t t-esc="tx.direction"/>
                                                </span>
                                            </td>
                                            <td t-att-class="'mza-td-amt ' + ('mza-pos' if tx.direction == 'inflow' else 'mza-neg')">
                                                <t t-esc="'%.2f' % tx.amount"/>
                                            </td>
                                            <td>
                                                <t t-if="tx.requires_review">
                                                    <span class="mza-badge mza-badge-warning">Review</span>
                                                </t>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </t>

                <!-- Empty state (no workspace) -->
                <t t-if="not workspace">
                    <div class="mza-section">
                        <div class="mza-empty mza-empty-lg">
                            <div class="mza-empty-icon">📊</div>
                            <div class="mza-empty-title">Set Up Your CFO Workspace</div>
                            <div class="mza-empty-body">
                                Create a workspace to start tracking transactions and unlocking AI financial insights.
                            </div>
                            <a href="/mumtaz/cfo" class="mza-btn mza-btn-gold">Create Workspace</a>
                        </div>
                    </div>
                </t>

            </div>
        </t>
    </template>
</odoo>
