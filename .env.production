# ── General ──────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=warning

# ── PostgreSQL (for Odoo) ─────────────────────────────────────────────
POSTGRES_DB=mumtaz
POSTGRES_USER=odoo
POSTGRES_PASSWORD=change_me

# ── Odoo ─────────────────────────────────────────────────────────────
ODOO_URL=http://localhost:8069
ODOO_DB=mumtaz
# Must match admin_passwd in /etc/odoo/odoo.conf
ODOO_MASTER_PASS=change_me
ODOO_ADMIN=admin@mumtaz.digital
ODOO_PASS=change_me
ODOO_ADDONS_PATH=/opt/custom_addons

# ── ZAKI server (port 8001) ───────────────────────────────────────────
JWT_SECRET=change_me
ANTHROPIC_API_KEY=sk-ant-...

# ── ERP server (port 8002) ───────────────────────────────────────────
ERP_SECRET=change_me

# ── Email / SMTP ─────────────────────────────────────────────────────
EMAIL_FROM=noreply@mumtaz.digital
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Stripe ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Redis ────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Security ─────────────────────────────────────────────────────────
SECURE_COOKIES=True
HTTP_LOGGING=False
ALLOWED_HOSTS=mumtaz.digital,www.mumtaz.digital,app.mumtaz.digital
API_RATE_LIMIT=1000
API_RATE_WINDOW=60
SENTRY_DSN=
