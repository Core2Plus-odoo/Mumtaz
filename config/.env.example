# ═══════════════════════════════════════════════════════════════════
# Mumtaz Platform — Environment Template
# Copy to .env.production and fill ALL values before deploying.
# NEVER commit a filled .env file to git.
#
# Generate secrets:
#   JWT_SECRET:       openssl rand -hex 64
#   POSTGRES_PASSWORD: openssl rand -hex 32
#   REDIS_PASSWORD:   openssl rand -hex 32
#   ODOO_MASTER_PASS: openssl rand -hex 32
# ═══════════════════════════════════════════════════════════════════

ENVIRONMENT=production

# ── Database (PostgreSQL — REQUIRED for production) ─────────────────
DATABASE_URL=postgresql://mumtaz:CHANGE_ME@db:5432/mumtaz_platform
POSTGRES_DB=mumtaz_platform
POSTGRES_USER=mumtaz
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# ── Security ─────────────────────────────────────────────────────────
# CRITICAL: Must be set. Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME
TOKEN_HOURS=24

# Comma-separated list of allowed CORS origins (no wildcards in production)
CORS_ORIGINS=https://mumtaz.digital,https://app.mumtaz.digital,https://ai.mumtaz.digital

# ── Odoo ERP ──────────────────────────────────────────────────────────
ODOO_URL=http://odoo:8069
ODOO_DB=mumtaz
ODOO_ADMIN_USER=admin@mumtaz.digital
ODOO_ADMIN_PASS=CHANGE_ME
# Master password for database management — keep secret
ODOO_MASTER_PASS=CHANGE_ME
ODOO_TIMEOUT=15

# Odoo Postgres (shared with platform or separate)
POSTGRES_DB=mumtaz

# ── Anthropic (Zaki AI) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
ZAKI_MODEL=claude-opus-4-7
ZAKI_ROUTER_MODEL=claude-haiku-4-5
ZAKI_AGENT_MODEL=claude-opus-4-7

# ── Stripe ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_STARTER=price_CHANGE_ME
STRIPE_PRICE_GROWTH=price_CHANGE_ME
STRIPE_PRICE_SCALE=price_CHANGE_ME

# ── ZATCA (Saudi Arabia e-invoicing) ─────────────────────────────────
# sandbox | simulation | production
ZATCA_ENV=sandbox
ZATCA_VAT_NUMBER=
ZATCA_SELLER_NAME=
# Generated via /api/v1/admin/settings/zatca/csr — do not set manually
ZATCA_CSID=
ZATCA_PRIVATE_KEY=

# ── Mail (SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@mumtaz.digital
SMTP_USE_TLS=true

# ── Platform ──────────────────────────────────────────────────────────
PORTAL_BASE_URL=https://app.mumtaz.digital
PORTAL_HOST=app.mumtaz.digital
# Comma-separated admin emails
MUMTAZ_ADMINS=admin@mumtaz.digital

# Zaki-AI → Platform connection
ZAKI_SERVER_URL=http://platform:8002

# ── Monitoring ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16
GRAFANA_PASSWORD=CHANGE_ME
# SENTRY_DSN=https://CHANGE_ME@sentry.io/PROJECT_ID
