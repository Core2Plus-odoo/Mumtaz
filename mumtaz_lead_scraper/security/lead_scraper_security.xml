<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_lead_scraper_viewer" model="res.groups">
            <field name="name">Lead Scraper / Viewer</field>
            <field name="comment">Read-only access to jobs and extracted records.</field>
        </record>

        <record id="group_lead_scraper_user" model="res.groups">
            <field name="name">Lead Scraper / User</field>
            <field name="comment">Can run scrapers, manage sources, and push leads to CRM.</field>
            <field name="implied_ids" eval="[(4, ref('group_lead_scraper_viewer'))]"/>
        </record>

        <record id="group_lead_scraper_admin" model="res.groups">
            <field name="name">Lead Scraper / Admin</field>
            <field name="comment">Full access including delete and configuration.</field>
            <field name="implied_ids" eval="[(4, ref('group_lead_scraper_user'))]"/>
        </record>

    </data>
</odoo>
