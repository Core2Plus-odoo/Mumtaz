[Unit]
Description=Mumtaz ZAKI API Server (FastAPI)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/zaki-server
EnvironmentFile=/opt/zaki-server/.env
ExecStart=/opt/zaki-server/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=zaki-api

[Install]
WantedBy=multi-user.target
