[Unit]
Description=ZAKI Server — Mumtaz AI CFO Backend
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/zaki-server
EnvironmentFile=/opt/zaki-server/.env
ExecStart=/opt/zaki-server/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8001 --workers 2
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
