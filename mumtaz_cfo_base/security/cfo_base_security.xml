<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="group_mumtaz_cfo_user" model="res.groups">
        <field name="name">Mumtaz / CFO User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_mumtaz_cfo_manager" model="res.groups">
        <field name="name">Mumtaz / CFO Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_mumtaz_cfo_user')), (4, ref('base.group_system'))]"/>
    </record>
</odoo>
