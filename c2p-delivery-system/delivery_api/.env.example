# C2P Agency OS — complete configuration reference.
# Copy to .env (same directory) and set what you need. Everything is optional
# unless marked required; the system runs fully LOCAL (no AI provider) when
# C2P_LLM_PROVIDER=none. Restart after changes: sudo systemctl restart delivery-api

# ── AI provider ─────────────────────────────────────────────────────────────
# none  = zero-API mode: every stage runs on built-in knowledge (free).
# anthropic = Claude via ANTHROPIC_API_KEY (paid credits).
# openai = any OpenAI-compatible endpoint (Ollama/Groq/OpenRouter) — free options.
C2P_LLM_PROVIDER=none
#ANTHROPIC_API_KEY=sk-ant-...
#C2P_MODEL=claude-haiku-4-5          # default model (per-task: C2P_MODEL_<TASK>)
#C2P_OPENAI_BASE_URL=http://localhost:11434/v1   # e.g. local Ollama
#C2P_OPENAI_KEY=
#C2P_WEB_SEARCH=1                    # Anthropic server-side web search on/off
#C2P_MAX_OUTPUT_TOKENS=0             # hard cap per request (0 = no cap)
#C2P_LLM_RETRIES=5                   # retries on 429/5xx with backoff
#C2P_PROMPT_CACHE=1                  # cache system prompts (~90% cheaper input)

# ── Intelligence & quality ──────────────────────────────────────────────────
#C2P_LOCAL_INTELLIGENCE=1            # local-first classify/estimate/docs/config
#C2P_LOCAL_CONFIDENCE=0.8            # min confidence to skip the model
#C2P_EMBED_KNOWLEDGE=1               # embed Odoo/CA/PM/BA knowledge in prompts
#C2P_QA_ENABLED=1                    # Delivery Director review pass (2x calls)
#C2P_QA_BAR=75                       # quality bar 0-100
#C2P_QA_MAX_REVISIONS=1              # auto-revisions when below the bar

# ── PM estimating model ─────────────────────────────────────────────────────
#C2P_DAY_RATE_AED=1800               # blended consultant day rate
#C2P_TEAM_VELOCITY=13.5              # effective man-days per week

# ── Odoo connection (agents read/write the client instance) ────────────────
# Preferred: set these in the console (Grounding → Odoo Connection; encrypted).
# Env is the fallback for headless setups.
#ODOO_URL=https://yourco.odoo.com
#ODOO_USER=bot@core2plus.com
#ODOO_PASSWORD=api-key-here
#C2P_CRM_DB=your-database-name

# ── Module deploy (Developer agent output → addons repo) ────────────────────
# Preferred: console (Grounding → GitHub Repo; token encrypted). Env fallback:
#C2P_GH_REPO=https://github.com/org/addons
#C2P_GH_TOKEN=ghp_...
#C2P_GH_BRANCH=staging
#C2P_GH_SUBDIR=addons
# Legacy local-checkout path (used only when GitHub is not configured):
#C2P_ADDONS_DIR=/opt/addons-checkout
#C2P_DEPLOY_LIVE=0
#C2P_DEPLOY_BRANCH=staging

# ── Login (single admin) ────────────────────────────────────────────────────
#C2P_ADMIN_AUTH=1                    # branded login page on the console
#C2P_ADMIN_USER=admin
#C2P_ADMIN_PASSWORD=change-me        # or C2P_ADMIN_PASSWORD_HASH (pbkdf2)
#C2P_JWT_SECRET=                     # openssl rand -hex 32   (required if auth on)
#C2P_JWT_TTL=604800                  # session seconds (7 days)

# ── Storage & security ──────────────────────────────────────────────────────
#C2P_STORE=delivery.db               # SQLite path (WAL mode; back this file up)
#C2P_SECRET_KEY=                     # Fernet key → encrypts stored credentials
#C2P_CORS=*

# ── Multi-tenant SaaS mode (advanced; off by default) ──────────────────────
#MULTITENANT=0
#C2P_CONTROL_DB=control.db
#C2P_TENANT_DIR=tenants
#STRIPE_SECRET_KEY=
#STRIPE_WEBHOOK_SECRET=

# ── Outbound channels (dry-run until configured) ───────────────────────────
#SMTP_HOST=
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASSWORD=
#SMTP_FROM=
#WHATSAPP_TOKEN=
#WHATSAPP_PHONE_ID=
