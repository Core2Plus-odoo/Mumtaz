<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ── List View ─────────────────────────────────────────────────── -->
    <record id="view_mumtaz_core_log_tree" model="ir.ui.view">
        <field name="name">mumtaz.core.log.tree</field>
        <field name="model">mumtaz.core.log</field>
        <field name="arch" type="xml">
            <list create="0" delete="0" default_order="create_date desc"
                  decoration-danger="level == 'error'"
                  decoration-warning="level == 'warning'">
                <field name="create_date" string="Date"/>
                <field name="company_id" optional="show"/>
                <field name="user_id"/>
                <field name="module_name" string="Module"/>
                <field name="action"/>
                <field name="level" widget="badge"
                       decoration-success="level == 'info'"
                       decoration-warning="level == 'warning'"
                       decoration-danger="level == 'error'"/>
            </list>
        </field>
    </record>

    <!-- ── Form View ─────────────────────────────────────────────────── -->
    <record id="view_mumtaz_core_log_form" model="ir.ui.view">
        <field name="name">mumtaz.core.log.form</field>
        <field name="model">mumtaz.core.log</field>
        <field name="arch" type="xml">
            <form create="0" delete="0" edit="0" string="Query Log">
                <sheet>
                    <group>
                        <group string="Who / When">
                            <field name="create_date" string="Timestamp"/>
                            <field name="company_id"/>
                            <field name="user_id"/>
                        </group>
                        <group string="What">
                            <field name="module_name" string="Module"/>
                            <field name="action"/>
                            <field name="level" widget="badge"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Request">
                            <field name="request_payload" widget="ace" options="{'mode': 'json'}"
                                   nolabel="1" readonly="1"/>
                        </page>
                        <page string="Response">
                            <field name="response_payload" widget="ace" options="{'mode': 'json'}"
                                   nolabel="1" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Search View ───────────────────────────────────────────────── -->
    <record id="view_mumtaz_core_log_search" model="ir.ui.view">
        <field name="name">mumtaz.core.log.search</field>
        <field name="model">mumtaz.core.log</field>
        <field name="arch" type="xml">
            <search string="Search Logs">
                <field name="user_id"/>
                <field name="module_name" string="Module"/>
                <field name="action"/>
                <filter string="Errors" name="errors"
                        domain="[('level', '=', 'error')]"/>
                <filter string="Warnings" name="warnings"
                        domain="[('level', '=', 'warning')]"/>
                <filter string="Info" name="info"
                        domain="[('level', '=', 'info')]"/>
                <filter string="Voice Queries" name="voice"
                        domain="[('module_name', '=', 'mumtaz_voice')]"/>
                <filter string="AI Chat" name="ai"
                        domain="[('module_name', '=', 'mumtaz_ai')]"/>
                <filter string="Today" name="today"
                        domain="[('create_date', '>=', datetime.datetime.now().strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="Last 7 Days" name="last_week"
                        domain="[('create_date', '>=', (datetime.datetime.now() - datetime.timedelta(days=7)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="Last 30 Days" name="last_month"
                        domain="[('create_date', '>=', (datetime.datetime.now() - datetime.timedelta(days=30)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="Module" name="group_module" context="{'group_by': 'module_name'}"/>
                <filter string="Level" name="group_level" context="{'group_by': 'level'}"/>
                <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                <filter string="Company" name="group_company" context="{'group_by': 'company_id'}"/>
                <filter string="Date" name="group_date" context="{'group_by': 'create_date:day'}"/>
            </search>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────────── -->
    <record id="action_mumtaz_core_log" model="ir.actions.act_window">
        <field name="name">Mumtaz Query Logs</field>
        <field name="res_model">mumtaz.core.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_mumtaz_core_log_search"/>
        <field name="context">{'search_default_last_month': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No queries logged yet</p>
            <p>Logs appear here after users interact with the CFO Voice Assistant or AI Chat.</p>
        </field>
    </record>

    <!-- ── Menu ──────────────────────────────────────────────────────── -->
    <menuitem id="menu_mumtaz_logs" name="Query Logs"
              parent="menu_mumtaz_configuration"
              action="action_mumtaz_core_log"
              sequence="20"
              groups="mumtaz_core.group_mumtaz_manager"/>
</odoo>
