<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ── Application Category ─────────────────────────────────────── -->
    <record id="module_category_mumtaz" model="ir.module.category">
        <field name="name">Mumtaz Platform</field>
        <field name="description">Mumtaz SME Operating Platform</field>
        <field name="sequence">100</field>
    </record>

    <!-- ── Readonly Analyst ─────────────────────────────────────────── -->
    <!-- Baseline access: read reports, dashboards, KPIs. No edits.     -->
    <record id="group_mumtaz_analyst" model="res.groups">
        <field name="name">Readonly Analyst</field>
        <field name="category_id" ref="module_category_mumtaz"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- ── Finance User ─────────────────────────────────────────────── -->
    <!-- Can enter transactions, use AI, access CFO assistant.          -->
    <record id="group_mumtaz_finance_user" model="res.groups">
        <field name="name">Finance User</field>
        <field name="category_id" ref="module_category_mumtaz"/>
        <field name="implied_ids" eval="[(4, ref('group_mumtaz_analyst'))]"/>
    </record>

    <!-- ── SME Admin ────────────────────────────────────────────────── -->
    <!-- Company-level administrator: manage profile, onboarding, users.-->
    <record id="group_mumtaz_sme_admin" model="res.groups">
        <field name="name">SME Admin</field>
        <field name="category_id" ref="module_category_mumtaz"/>
        <field name="implied_ids" eval="[(4, ref('group_mumtaz_finance_user'))]"/>
    </record>

    <!-- ── Partner Manager ──────────────────────────────────────────── -->
    <!-- Manages brand configs and partner/ecosystem assignments.       -->
    <record id="group_mumtaz_partner_manager" model="res.groups">
        <field name="name">Partner Manager</field>
        <field name="category_id" ref="module_category_mumtaz"/>
        <field name="implied_ids" eval="[(4, ref('group_mumtaz_analyst'))]"/>
    </record>

    <!-- ── Admin (formerly group_mumtaz_manager — XML ID preserved) ── -->
    <!-- Internal platform admin. Implies SME Admin + Partner Manager.  -->
    <record id="group_mumtaz_manager" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id" ref="module_category_mumtaz"/>
        <field name="implied_ids" eval="[
            (4, ref('group_mumtaz_sme_admin')),
            (4, ref('group_mumtaz_partner_manager')),
        ]"/>
    </record>

    <!-- ── Super Admin ──────────────────────────────────────────────── -->
    <!-- Platform-level superuser. Full access across all companies.   -->
    <record id="group_mumtaz_super_admin" model="res.groups">
        <field name="name">Super Admin</field>
        <field name="category_id" ref="module_category_mumtaz"/>
        <field name="implied_ids" eval="[(4, ref('group_mumtaz_manager'))]"/>
    </record>

</odoo>
