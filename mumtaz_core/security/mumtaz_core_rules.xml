<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="rule_mumtaz_core_settings_company" model="ir.rule">
        <field name="name">Mumtaz Core Settings multi-company</field>
        <field name="model_id" ref="model_mumtaz_core_settings"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_mumtaz_core_log_company" model="ir.rule">
        <field name="name">Mumtaz Core Logs multi-company</field>
        <field name="model_id" ref="model_mumtaz_core_log"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
