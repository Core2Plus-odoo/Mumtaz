<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Favicon ──────────────────────────────────────────────── -->
    <template id="mumtaz_favicon" inherit_id="web.layout" name="Mumtaz Favicon">
        <xpath expr="//link[@rel='shortcut icon']" position="replace">
            <link rel="shortcut icon"
                  href="/mumtaz_theme/static/src/img/favicon.svg"
                  type="image/svg+xml"/>
        </xpath>
    </template>

    <!-- ── DM Sans + Instrument Serif fonts ────────────────────── -->
    <template id="mumtaz_fonts" inherit_id="web.layout" name="Mumtaz Fonts">
        <xpath expr="//head" position="inside">
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin=""/>
            <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&amp;family=DM+Sans:wght@400;500;600&amp;family=DM+Mono:wght@400;500&amp;display=swap"
                  rel="stylesheet"/>
            <style>
                body, .o_web_client { font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif !important; }
            </style>
        </xpath>
    </template>

    <!-- ── Login page CSS ──────────────────────────────────────────
         mumtaz_login.css is loaded via the web.assets_frontend bundle
         (see __manifest__.py), which applies to the /web/login page. We do
         NOT inject it through an inherited template: web.login_layout has no
         <head> in Odoo 19, so an //head xpath there fails to parse and rolls
         back the whole module upgrade.
    -->

</odoo>
