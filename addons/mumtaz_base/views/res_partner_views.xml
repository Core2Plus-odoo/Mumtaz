<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_partner_form_mumtaz" model="ir.ui.view">
        <field name="name">res.partner.form.mumtaz.code</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="x_mumtaz_code"/>
            </xpath>
        </field>
    </record>

    <record id="view_res_partner_filter_mumtaz" model="ir.ui.view">
        <field name="name">res.partner.search.mumtaz.code</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="x_mumtaz_code"/>
            </xpath>
        </field>
    </record>
</odoo>
