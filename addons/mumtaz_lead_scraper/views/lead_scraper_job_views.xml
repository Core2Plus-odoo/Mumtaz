<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List ──────────────────────────────────────────────────────── -->
    <record id="lead_scraper_job_list_view" model="ir.ui.view">
        <field name="name">lead.scraper.job.list</field>
        <field name="model">lead.scraper.job</field>
        <field name="arch" type="xml">
            <list string="Scraping Jobs"
                  decoration-success="status == 'done'"
                  decoration-danger="status == 'failed'"
                  decoration-warning="status == 'running'"
                  decoration-muted="status == 'cancelled'">
                <field name="name"/>
                <field name="source_id"/>
                <field name="triggered_by"/>
                <field name="start_time"/>
                <field name="duration" string="Duration (s)"/>
                <field name="total_found" string="Found"/>
                <field name="total_processed" string="Processed"/>
                <field name="total_created" string="CRM"/>
                <field name="total_duplicates" string="Dupes"/>
                <field name="total_failed" string="Failed"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'done'"
                       decoration-danger="status == 'failed'"
                       decoration-warning="status == 'running'"/>
            </list>
        </field>
    </record>

    <!-- ── Form ──────────────────────────────────────────────────────── -->
    <record id="lead_scraper_job_form_view" model="ir.ui.view">
        <field name="name">lead.scraper.job.form</field>
        <field name="model">lead.scraper.job</field>
        <field name="arch" type="xml">
            <form string="Scraping Job">
                <header>
                    <button name="action_push_all_to_crm" type="object"
                            string="Push All to CRM"
                            class="oe_highlight"
                            invisible="status != 'done'"
                            groups="mumtaz_lead_scraper.group_lead_scraper_user"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            invisible="status not in ('pending', 'running')"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="pending,running,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_records" type="object"
                                class="oe_stat_button" icon="fa-list">
                            <field name="record_count" widget="statinfo" string="Records"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group>
                        <group string="Job Info">
                            <field name="source_id" readonly="1"/>
                            <field name="triggered_by" readonly="1"/>
                            <field name="start_time" readonly="1"/>
                            <field name="end_time" readonly="1"/>
                            <field name="duration" readonly="1"/>
                        </group>
                        <group string="Results">
                            <field name="total_found"/>
                            <field name="total_processed"/>
                            <field name="total_created"/>
                            <field name="total_duplicates"/>
                            <field name="total_skipped"/>
                            <field name="total_failed"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Run Log" name="log">
                            <field name="log_text" widget="text" nolabel="1" readonly="1"/>
                        </page>
                        <page string="Error" name="error"
                              invisible="not error_message">
                            <field name="error_message" widget="text" nolabel="1" readonly="1"/>
                        </page>
                        <page string="Records" name="records">
                            <field name="record_ids" nolabel="1">
                                <list>
                                    <field name="company_name"/>
                                    <field name="contact_name"/>
                                    <field name="email"/>
                                    <field name="phone"/>
                                    <field name="duplicate_status" widget="badge"/>
                                    <field name="processing_status" widget="badge"
                                           decoration-success="processing_status == 'crm_created'"
                                           decoration-warning="processing_status == 'skipped'"
                                           decoration-danger="processing_status == 'failed'"/>
                                    <field name="crm_lead_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────────── -->
    <record id="action_lead_scraper_job" model="ir.actions.act_window">
        <field name="name">Scraping Jobs</field>
        <field name="res_model">lead.scraper.job</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No scraping jobs yet. Run a source to see jobs here.
            </p>
        </field>
    </record>

</odoo>
