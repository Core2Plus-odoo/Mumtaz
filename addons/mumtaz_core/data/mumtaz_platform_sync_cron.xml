<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="ir_cron_mumtaz_platform_credential_sync" model="ir.cron">
        <field name="name">Mumtaz: Sync Credentials from Platform</field>
        <field name="model_id" ref="mumtaz_core.model_mumtaz_core_settings"/>
        <field name="state">code</field>
        <field name="code">model._cron_sync_platform_credentials()</field>
        <field name="interval_number">24</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
        <field name="nextcall" eval="(datetime.now() + timedelta(hours=1)).strftime('%Y-%m-%d %H:00:00')"/>
    </record>

</odoo>
