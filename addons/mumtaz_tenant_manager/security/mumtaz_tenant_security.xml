<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Security groups ──────────────────────────────────────── -->

        <record id="group_mumtaz_platform_manager" model="res.groups">
            <field name="name">Platform Manager</field>
            <field name="comment">
                Read and update tenant records; cannot provision or delete.
            </field>
        </record>

        <record id="group_mumtaz_platform_admin" model="res.groups">
            <field name="name">Platform Administrator</field>
            <field name="comment">
                Full access to tenant management, provisioning, and bundle configuration.
                Intended for Mumtaz platform operators only.
            </field>
            <field name="implied_ids" eval="[(4, ref('group_mumtaz_platform_manager'))]"/>
        </record>

    </data>
</odoo>
