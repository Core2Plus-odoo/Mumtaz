<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- =====================================================================
         E-Invoice Sequence
         ===================================================================== -->
    <record id="seq_mumtaz_einvoice" model="ir.sequence">
        <field name="name">Mumtaz E-Invoice Number</field>
        <field name="code">mumtaz.einvoice</field>
        <field name="prefix">EI/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="use_date_range">False</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- =====================================================================
         Scheduled Action: Auto-retry rejected e-invoices
         ===================================================================== -->
    <record id="ir_cron_mumtaz_einvoice_retry" model="ir.cron">
        <field name="name">Mumtaz E-Invoicing: Retry Rejected Submissions</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="state">code</field>
        <field name="code">
configs = env['mumtaz.einvoice.config'].search([('auto_submit', '=', True)])
auto_submit_company_ids = configs.mapped('company_id').ids
rejected_moves = env['account.move'].search([
    ('einvoice_status', '=', 'rejected'),
    ('state', '=', 'posted'),
    ('move_type', 'in', ['out_invoice', 'out_refund']),
    ('company_id', 'in', auto_submit_company_ids),
])
for move in rejected_moves:
    try:
        move.action_submit_einvoice()
        env.cr.commit()
    except Exception:
        env.cr.rollback()
        </field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 06:00:00')"/>
    </record>

    <!-- =====================================================================
         Scheduled Action: Daily status sync — flag stale submitted invoices
         ===================================================================== -->
    <record id="ir_cron_mumtaz_einvoice_status_sync" model="ir.cron">
        <field name="name">Mumtaz E-Invoicing: Sync Submission Status</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="state">code</field>
        <field name="code">
cutoff = datetime.now() - timedelta(hours=24)
stale = env['account.move'].search([
    ('einvoice_status', '=', 'submitted'),
    ('state', '=', 'posted'),
    ('move_type', 'in', ['out_invoice', 'out_refund']),
    ('einvoice_submission_date', '!=', False),
    ('einvoice_submission_date', '&lt;', cutoff),
])
if stale:
    stale.write({'einvoice_status': 'rejected'})
        </field>
        <field name="interval_number">4</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
        <field name="nextcall" eval="(datetime.now() + timedelta(hours=4)).strftime('%Y-%m-%d %H:00:00')"/>
    </record>

</odoo>
