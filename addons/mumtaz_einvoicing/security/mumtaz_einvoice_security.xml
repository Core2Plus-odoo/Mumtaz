<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =====================================================================
         Security Category
         ===================================================================== -->
    <record id="module_category_mumtaz_einvoicing" model="ir.module.category">
        <field name="name">Mumtaz E-Invoicing</field>
        <field name="description">Manage e-invoicing compliance for UAE FTA, KSA ZATCA, and Pakistan FBR.</field>
        <field name="sequence">100</field>
    </record>

    <!-- =====================================================================
         Record Rules: mumtaz.einvoice.config
         Users can only read/write configurations for their own company.
         ===================================================================== -->
    <record id="rule_einvoice_config_company" model="ir.rule">
        <field name="name">E-Invoice Config: own company only</field>
        <field name="model_id" ref="model_mumtaz_einvoice_config"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Managers also restricted to own company -->
    <record id="rule_einvoice_config_company_manager" model="ir.rule">
        <field name="name">E-Invoice Config: managers own company only</field>
        <field name="model_id" ref="model_mumtaz_einvoice_config"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('account.group_account_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- =====================================================================
         Record Rules: account.move (e-invoice fields)
         Standard Odoo rules apply; users already see invoices for their company.
         We add an explicit rule ensuring einvoice submission actions
         respect multi-company boundaries.
         ===================================================================== -->
    <record id="rule_einvoice_move_company" model="ir.rule">
        <field name="name">E-Invoice: invoice must belong to user company</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
