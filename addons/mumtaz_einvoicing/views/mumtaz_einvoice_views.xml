<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =====================================================================
         E-Invoice Status statusbar (injected above the invoice body)
         ===================================================================== -->
    <record id="view_move_form_einvoice_statusbar" model="ir.ui.view">
        <field name="name">account.move.form.einvoice.statusbar</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">

            <!-- Smart button: E-Invoice -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_submit_einvoice"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-file-text-o"
                    attrs="{'invisible': [('move_type', 'not in', ['out_invoice', 'out_refund'])]}"
                    groups="account.group_account_user">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="einvoice_status" widget="badge"
                                   decoration-success="einvoice_status == 'accepted'"
                                   decoration-danger="einvoice_status in ('rejected', 'cancelled')"
                                   decoration-warning="einvoice_status == 'submitted'"
                                   decoration-info="einvoice_status == 'draft'"
                                   decoration-muted="einvoice_status == 'not_applicable'"/>
                        </span>
                        <span class="o_stat_text">E-Invoice</span>
                    </div>
                </button>
            </xpath>

            <!-- E-Invoice statusbar above the invoice header -->
            <xpath expr="//sheet" position="before">
                <div class="o_mumtaz_einvoice_statusbar"
                     attrs="{'invisible': [('move_type', 'not in', ['out_invoice', 'out_refund'])]}">
                    <field name="einvoice_status"
                           widget="statusbar"
                           statusbar_visible="draft,submitted,accepted"
                           readonly="1"/>
                </div>
            </xpath>

            <!-- =========================================================
                 "Other Info" tab — E-Invoicing section
                 ========================================================= -->
            <xpath expr="//page[@name='other_info']" position="inside">
                <separator string="E-Invoicing"/>
                <group name="einvoice_main" string="E-Invoice Details"
                       attrs="{'invisible': [('move_type', 'not in', ['out_invoice', 'out_refund'])]}">
                    <group name="einvoice_left">
                        <field name="einvoice_country_type" readonly="1"/>
                        <field name="einvoice_status" readonly="1"/>
                        <field name="einvoice_number" readonly="1"/>
                        <field name="einvoice_uuid" readonly="1"/>
                    </group>
                    <group name="einvoice_right">
                        <field name="einvoice_submission_date" readonly="1"/>
                        <field name="einvoice_acceptance_date" readonly="1"/>
                    </group>
                </group>

                <!-- QR Code image -->
                <group name="einvoice_qr" string="QR Code"
                       attrs="{'invisible': ['|', ('einvoice_qr_code', '=', False), ('move_type', 'not in', ['out_invoice', 'out_refund'])]}">
                    <field name="einvoice_qr_code" string="QR String (TLV)" readonly="1"/>
                    <field name="einvoice_qr_image" widget="image" readonly="1"
                           attrs="{'invisible': [('einvoice_qr_image', '=', False)]}"
                           options="{'size': [128, 128]}"/>
                </group>

                <!-- XML payload (collapsed by default) -->
                <group name="einvoice_xml" string="XML Payload"
                       attrs="{'invisible': ['|', ('einvoice_xml_payload', '=', False), ('move_type', 'not in', ['out_invoice', 'out_refund'])]}">
                    <field name="einvoice_xml_payload" widget="text" readonly="1" nolabel="1"
                           options="{'rows': 8}"/>
                </group>

                <!-- Validation errors -->
                <group name="einvoice_errors" string="Validation Errors"
                       attrs="{'invisible': ['|', ('einvoice_validation_errors', '=', False), ('move_type', 'not in', ['out_invoice', 'out_refund'])]}">
                    <field name="einvoice_validation_errors" widget="text" readonly="1" nolabel="1"
                           options="{'rows': 4}"/>
                </group>

                <!-- Action buttons -->
                <group name="einvoice_actions" string="Actions"
                       attrs="{'invisible': [('move_type', 'not in', ['out_invoice', 'out_refund'])]}">
                    <div class="o_mumtaz_einvoice_buttons">
                        <button name="action_submit_einvoice"
                                type="object"
                                string="Submit E-Invoice"
                                class="btn btn-primary"
                                attrs="{'invisible': ['|', ('state', '!=', 'posted'), ('einvoice_status', 'in', ['submitted', 'accepted', 'cancelled'])]}"
                                groups="account.group_account_user"
                                confirm="Submit this invoice to the tax authority? This action cannot be undone."/>
                        <button name="action_cancel_einvoice"
                                type="object"
                                string="Cancel E-Invoice"
                                class="btn btn-danger"
                                attrs="{'invisible': [('einvoice_status', 'not in', ['submitted', 'accepted', 'draft'])]}"
                                groups="account.group_account_manager"
                                confirm="Are you sure you want to cancel the e-invoice submission? This may trigger a cancellation request to the authority."/>
                    </div>
                </group>
            </xpath>

        </field>
    </record>

    <!-- =====================================================================
         List view: add einvoice_status column to invoice list
         ===================================================================== -->
    <record id="view_move_tree_einvoice_status" model="ir.ui.view">
        <field name="name">account.move.tree.einvoice.status</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="einvoice_status" optional="show" widget="badge"
                       decoration-success="einvoice_status == 'accepted'"
                       decoration-danger="einvoice_status in ('rejected', 'cancelled')"
                       decoration-warning="einvoice_status == 'submitted'"
                       decoration-info="einvoice_status == 'draft'"
                       decoration-muted="einvoice_status == 'not_applicable'"/>
            </xpath>
        </field>
    </record>

    <!-- =====================================================================
         Action: E-Invoice Submissions (filtered list of all submissions)
         ===================================================================== -->
    <record id="action_mumtaz_einvoice_submissions" model="ir.actions.act_window">
        <field name="name">E-Invoice Submissions</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('einvoice_status', '!=', 'not_applicable'), ('move_type', 'in', ['out_invoice', 'out_refund'])]</field>
        <field name="context">{'default_move_type': 'out_invoice'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No e-invoice submissions yet.
            </p>
            <p>
                Post a customer invoice and click <b>Submit E-Invoice</b> to get started.
            </p>
        </field>
    </record>

</odoo>
