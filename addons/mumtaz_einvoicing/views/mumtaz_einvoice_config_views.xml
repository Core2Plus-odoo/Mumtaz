<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =====================================================================
         Tree / List view
         ===================================================================== -->
    <record id="view_mumtaz_einvoice_config_tree" model="ir.ui.view">
        <field name="name">mumtaz.einvoice.config.tree</field>
        <field name="model">mumtaz.einvoice.config</field>
        <field name="arch" type="xml">
            <list string="E-Invoice Configurations" decoration-muted="not tax_registration_number">
                <field name="company_id"/>
                <field name="country_type" widget="badge"
                       decoration-info="country_type == 'uae'"
                       decoration-success="country_type == 'ksa'"
                       decoration-warning="country_type == 'pakistan'"/>
                <field name="tax_registration_number" optional="show"/>
                <field name="zatca_environment" optional="show"
                       attrs="{'invisible': [('country_type', '!=', 'ksa')]}"/>
                <field name="fbr_environment" optional="show"
                       attrs="{'invisible': [('country_type', '!=', 'pakistan')]}"/>
                <field name="auto_submit" optional="show"/>
            </list>
        </field>
    </record>

    <!-- =====================================================================
         Form view
         ===================================================================== -->
    <record id="view_mumtaz_einvoice_config_form" model="ir.ui.view">
        <field name="name">mumtaz.einvoice.config.form</field>
        <field name="model">mumtaz.einvoice.config</field>
        <field name="arch" type="xml">
            <form string="E-Invoice Configuration">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="company_id" readonly="1"/>
                        </h1>
                        <h2>
                            <field name="country_type" widget="badge"
                                   decoration-info="country_type == 'uae'"
                                   decoration-success="country_type == 'ksa'"
                                   decoration-warning="country_type == 'pakistan'"
                                   readonly="1"/>
                        </h2>
                    </div>

                    <!-- General Settings -->
                    <group string="General Settings" name="general_settings">
                        <group name="general_left">
                            <field name="company_id"
                                   attrs="{'readonly': [('id', '!=', False)]}"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="tax_registration_number"
                                   placeholder="e.g. 100123456789003 (UAE TRN)"/>
                            <field name="sequence_id"
                                   options="{'no_create': False}"
                                   domain="[('code', '=', 'mumtaz.einvoice')]"/>
                        </group>
                        <group name="general_right">
                            <field name="auto_submit"/>
                            <field name="country_type" readonly="1"/>
                        </group>
                    </group>

                    <!-- UAE FTA Settings -->
                    <group string="UAE FTA Settings" name="uae_settings"
                           attrs="{'invisible': [('country_type', '!=', 'uae')]}">
                        <div class="alert alert-info" role="alert">
                            <p>
                                <strong>UAE FTA E-Invoicing:</strong>
                                UAE e-invoicing currently uses QR code generation (TLV format)
                                embedded in printed invoices. No API submission is required.
                                Ensure your TRN (Tax Registration Number) is exactly 15 digits.
                            </p>
                        </div>
                        <group name="uae_left">
                            <field name="tax_registration_number"
                                   string="Tax Registration Number (TRN)"
                                   placeholder="100123456789003"/>
                        </group>
                    </group>

                    <!-- KSA ZATCA Settings -->
                    <group string="KSA ZATCA Phase 2 Settings" name="ksa_settings"
                           attrs="{'invisible': [('country_type', '!=', 'ksa')]}">
                        <div class="alert alert-warning" role="alert"
                             attrs="{'invisible': [('zatca_environment', '!=', 'production')]}">
                            <strong>Production Mode:</strong>
                            Invoices will be submitted to ZATCA in real-time.
                            Ensure your certificate and private key are correctly configured.
                        </div>
                        <group name="ksa_left">
                            <field name="zatca_environment" widget="radio"/>
                            <field name="zatca_vat_number"
                                   placeholder="300XXXXXXXXX003"/>
                            <field name="tax_registration_number"
                                   string="Tax Registration Number"
                                   placeholder="300XXXXXXXXX003"/>
                        </group>
                        <group name="ksa_right">
                            <field name="zatca_compliance_request_id" readonly="1"/>
                        </group>
                        <separator string="ZATCA Certificate (Restricted)"/>
                        <group name="ksa_cert" groups="account.group_account_manager">
                            <field name="zatca_certificate" widget="text"
                                   placeholder="Paste base64-encoded PEM certificate here"
                                   options="{'rows': 5}"/>
                            <field name="zatca_private_key" widget="text"
                                   placeholder="Paste base64-encoded private key here"
                                   password="True"
                                   options="{'rows': 5}"/>
                        </group>
                        <div name="ksa_actions" class="o_mumtaz_config_actions">
                            <button name="action_test_zatca_connection"
                                    type="object"
                                    string="Test ZATCA Connection"
                                    class="btn btn-secondary"
                                    icon="fa-plug"/>
                        </div>
                    </group>

                    <!-- Pakistan FBR Settings -->
                    <group string="Pakistan FBR Settings" name="pak_settings"
                           attrs="{'invisible': [('country_type', '!=', 'pakistan')]}">
                        <div class="alert alert-warning" role="alert"
                             attrs="{'invisible': [('fbr_environment', '!=', 'production')]}">
                            <strong>Production Mode:</strong>
                            Invoices will be submitted to FBR in real-time.
                        </div>
                        <group name="pak_left">
                            <field name="fbr_environment" widget="radio"/>
                            <field name="fbr_pos_id" placeholder="POS-XXXXXXXX"/>
                            <field name="tax_registration_number"
                                   string="NTN (National Tax Number)"
                                   placeholder="1234567-8"/>
                        </group>
                        <group name="pak_right" groups="account.group_account_manager">
                            <field name="fbr_username" placeholder="FBR portal username"/>
                            <field name="fbr_password" password="True"/>
                        </group>
                        <div name="pak_actions" class="o_mumtaz_config_actions">
                            <button name="action_test_fbr_connection"
                                    type="object"
                                    string="Test FBR Connection"
                                    class="btn btn-secondary"
                                    icon="fa-plug"/>
                        </div>
                    </group>

                    <!-- Not Configured Warning -->
                    <div class="alert alert-danger" role="alert"
                         attrs="{'invisible': [('country_type', '!=', False)]}">
                        <p>
                            <strong>Country Not Supported:</strong>
                            The company's country is not currently supported for automated
                            e-invoicing. Supported countries: UAE, Saudi Arabia, Pakistan.
                        </p>
                        <p>
                            You can still save this configuration for future use.
                        </p>
                    </div>

                </sheet>
            </form>
        </field>
    </record>

    <!-- =====================================================================
         Action window for configuration
         ===================================================================== -->
    <record id="action_mumtaz_einvoice_config" model="ir.actions.act_window">
        <field name="name">E-Invoice Configuration</field>
        <field name="res_model">mumtaz.einvoice.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No e-invoicing configuration yet.
            </p>
            <p>
                Create a configuration for your company to enable UAE FTA,
                KSA ZATCA Phase 2, or Pakistan FBR e-invoicing.
            </p>
        </field>
    </record>

</odoo>
