<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="stage_new" model="crm.stage">
            <field name="name">New Enquiry</field><field name="sequence">1</field>
        </record>
        <record id="stage_discovery" model="crm.stage">
            <field name="name">Discovery Call</field><field name="sequence">2</field>
        </record>
        <record id="stage_proposal" model="crm.stage">
            <field name="name">Proposal Sent</field><field name="sequence">3</field>
        </record>
        <record id="stage_negotiation" model="crm.stage">
            <field name="name">Negotiation</field><field name="sequence">4</field>
        </record>
        <record id="stage_agreement" model="crm.stage">
            <field name="name">Agreement</field><field name="sequence">5</field>
        </record>
        <record id="stage_won" model="crm.stage">
            <field name="name">Won</field><field name="sequence">6</field>
            <field name="is_won" eval="True"/>
        </record>
        <record id="stage_lost" model="crm.stage">
            <field name="name">Lost</field><field name="sequence">7</field>
            <field name="fold" eval="True"/>
        </record>
    </data>
</odoo>
