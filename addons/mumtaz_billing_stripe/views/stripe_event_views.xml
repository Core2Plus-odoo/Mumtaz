<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stripe_event_list" model="ir.ui.view">
        <field name="name">mumtaz.stripe.event.list</field>
        <field name="model">mumtaz.stripe.event</field>
        <field name="arch" type="xml">
            <list string="Stripe Events" decoration-muted="not processed">
                <field name="received_at"/>
                <field name="event_type"/>
                <field name="tenant_id"/>
                <field name="subscription_id"/>
                <field name="processed" widget="boolean_toggle"/>
                <field name="note" optional="show"/>
                <field name="stripe_event_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="action_stripe_event" model="ir.actions.act_window">
        <field name="name">Stripe Events</field>
        <field name="res_model">mumtaz.stripe.event</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
