<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_mumtaz_cfo_workspace_tree" model="ir.ui.view">
        <field name="name">mumtaz.cfo.workspace.tree</field>
        <field name="model">mumtaz.cfo.workspace</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="owner_user_id"/>
                <field name="category_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_mumtaz_cfo_workspace_form" model="ir.ui.view">
        <field name="name">mumtaz.cfo.workspace.form</field>
        <field name="model">mumtaz.cfo.workspace</field>
        <field name="arch" type="xml">
            <form string="CFO Workspace">
                <header>
                    <button name="action_load_default_categories" string="Load Default Categories" type="object" class="btn-primary" invisible="not erp_feature_enabled"/>
                    <button name="action_view_categories" string="Categories" type="object"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-tags" type="object" name="action_view_categories">
                            <field name="category_count" widget="statinfo" string="Categories"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="owner_user_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" placeholder="Workspace context, policies, and governance notes."/>
                        <field name="erp_feature_note" readonly="1" invisible="not erp_feature_note"/>
                    </group>
                    <notebook>
                        <page string="Categories">
                            <field name="category_ids" context="{'default_workspace_id': id, 'default_company_id': company_id}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="kind"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_mumtaz_cfo_workspace" model="ir.actions.act_window">
        <field name="name">Workspaces</field>
        <field name="res_model">mumtaz.cfo.workspace</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
