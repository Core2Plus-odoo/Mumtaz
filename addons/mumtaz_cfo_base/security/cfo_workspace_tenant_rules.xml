<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="rule_mumtaz_cfo_workspace_tenant_user" model="ir.rule">
            <field name="name">CFO Workspace - Tenant scoped access</field>
            <field name="model_id" ref="model_mumtaz_cfo_workspace"/>
            <field name="domain_force">['&amp;', ('tenant_id', '!=', False), ('company_id', 'in', company_ids)]</field>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">False</field>
            <field name="groups" eval="[(4, ref('mumtaz_cfo_base.group_mumtaz_cfo_user'))]"/>
        </record>

        <record id="rule_mumtaz_cfo_workspace_tenant_admin" model="ir.rule">
            <field name="name">CFO Workspace - Platform admin full access</field>
            <field name="model_id" ref="model_mumtaz_cfo_workspace"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
            <field name="groups" eval="[(4, ref('mumtaz_tenant_manager.group_mumtaz_platform_admin'))]"/>
        </record>
    </data>
</odoo>
