<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="cfo_workspace_tenant_user_rule" model="ir.rule">
            <field name="name">CFO Workspace - User Tenant Access</field>
            <field name="model_id" ref="model_mumtaz_cfo_workspace"/>
            <field name="domain_force">[('tenant_id', 'in', user.partner_id.parent_id.mapped('id'))]</field>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>

        <record id="cfo_workspace_admin_rule" model="ir.rule">
            <field name="name">CFO Workspace - Admin Access</field>
            <field name="model_id" ref="model_mumtaz_cfo_workspace"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
            <field name="groups" eval="[(4, ref('mumtaz_tenant_manager.group_mumtaz_platform_admin'))]"/>
        </record>
    </data>
</odoo>
