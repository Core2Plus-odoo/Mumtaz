<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="rule_mumtaz_cfo_workspace_company_scope" model="ir.rule">
        <field name="name">CFO Workspace company scope</field>
        <field name="model_id" ref="model_mumtaz_cfo_workspace"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('mumtaz_cfo_base.group_mumtaz_cfo_user'))]"/>
    </record>

    <record id="rule_mumtaz_cfo_category_company_scope" model="ir.rule">
        <field name="name">CFO Category company scope</field>
        <field name="model_id" ref="model_mumtaz_cfo_category"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('mumtaz_cfo_base.group_mumtaz_cfo_user'))]"/>
    </record>
</odoo>
