<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="sme_profile_tenant_user_rule" model="ir.rule">
            <field name="name">SME Profile - User Tenant Access</field>
            <field name="model_id" ref="model_mumtaz_sme_profile"/>
            <field name="domain_force">[('tenant_id', 'in', user.partner_id.parent_id.mapped('id'))]</field>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
            <field name="groups" eval="[(4, ref('mumtaz_portal_base.group_sme_user'))]"/>
        </record>

        <record id="sme_profile_admin_rule" model="ir.rule">
            <field name="name">SME Profile - Admin Access</field>
            <field name="model_id" ref="model_mumtaz_sme_profile"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
            <field name="groups" eval="[(4, ref('mumtaz_tenant_manager.group_mumtaz_platform_admin'))]"/>
        </record>
    </data>
</odoo>
