<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="app_zaki" name="Mumtaz App — ZAKI AI Section">
        <t t-call="mumtaz_app_portal.app_base_layout">

            <div class="mza-page">

                <!-- ═══════════════════════════ ZAKI HERO ══════════════════════════ -->
                <div class="mza-zaki-hero">
                    <div class="mza-zaki-hero-glow"/>
                    <div class="mza-zaki-hero-content">
                        <div class="mza-zaki-hero-badge">
                            <span class="mza-zaki-pulse"/>
                            AI-Powered CFO Intelligence
                        </div>
                        <h1 class="mza-zaki-hero-title">
                            <span class="mza-zaki-z">Z</span><span class="mza-zaki-a">A</span><span class="mza-zaki-k">K</span><span class="mza-zaki-i">I</span>
                            <span class="mza-zaki-sub-word"> AI</span>
                        </h1>
                        <p class="mza-zaki-hero-tagline">Your intelligent financial co-pilot — analyse transactions, forecast cash flow, surface insights.</p>

                        <!-- Main ask interface -->
                        <a href="/mumtaz/ai" class="mza-zaki-ask-field">
                            <span class="mza-zaki-ask-icon">✦</span>
                            <span class="mza-zaki-ask-placeholder">Ask ZAKI anything about your finances…</span>
                            <span class="mza-zaki-ask-send">↵</span>
                        </a>

                        <!-- Suggested prompts -->
                        <div class="mza-zaki-chips">
                            <a href="/mumtaz/ai?q=What+is+my+cash+position+this+month" class="mza-zaki-chip">
                                <span>💰</span> Cash position this month
                            </a>
                            <a href="/mumtaz/ai?q=Summarise+my+top+expenses" class="mza-zaki-chip">
                                <span>📉</span> Summarise top expenses
                            </a>
                            <a href="/mumtaz/ai?q=Show+overdue+invoices" class="mza-zaki-chip">
                                <span>🔔</span> Overdue invoices
                            </a>
                            <a href="/mumtaz/ai?q=Net+profit+vs+last+month" class="mza-zaki-chip">
                                <span>📈</span> Net profit trend
                            </a>
                            <a href="/mumtaz/ai?q=Forecast+next+month+cash+flow" class="mza-zaki-chip">
                                <span>🔮</span> Cash flow forecast
                            </a>
                        </div>
                    </div>
                </div>

                <!-- ═══════════════════════════ FINANCIAL METRICS ══════════════════ -->
                <t t-if="tx_count &gt; 0">
                    <div class="mza-section mza-section-pad">
                        <t t-set="net" t-value="income_total - expense_total"/>
                        <div class="mza-zaki-metrics">
                            <div class="mza-zaki-metric mza-zm-green">
                                <div class="mza-zm-icon">↑</div>
                                <div class="mza-zm-body">
                                    <div class="mza-zm-label">Total Inflow</div>
                                    <div class="mza-zm-value">
                                        <t t-esc="'%.0f' % income_total"/>
                                    </div>
                                </div>
                            </div>
                            <div class="mza-zaki-metric mza-zm-red">
                                <div class="mza-zm-icon">↓</div>
                                <div class="mza-zm-body">
                                    <div class="mza-zm-label">Total Outflow</div>
                                    <div class="mza-zm-value">
                                        <t t-esc="'%.0f' % expense_total"/>
                                    </div>
                                </div>
                            </div>
                            <t t-set="net_class" t-value="'mza-zm-green' if net &gt;= 0 else 'mza-zm-red'"/>
                            <div t-att-class="'mza-zaki-metric mza-zm-featured ' + net_class">
                                <div class="mza-zm-icon">=</div>
                                <div class="mza-zm-body">
                                    <div class="mza-zm-label">Net Position</div>
                                    <div class="mza-zm-value">
                                        <t t-esc="('+' if net &gt;= 0 else '−') + ' %.0f' % abs(net)"/>
                                    </div>
                                    <t t-if="workspace">
                                        <div class="mza-zm-sub">
                                            <t t-esc="workspace.name"/>
                                        </div>
                                    </t>
                                </div>
                            </div>
                            <div class="mza-zaki-metric mza-zm-purple">
                                <div class="mza-zm-icon">✦</div>
                                <div class="mza-zm-body">
                                    <div class="mza-zm-label">Transactions</div>
                                    <div class="mza-zm-value">
                                        <t t-esc="tx_count"/>
                                    </div>
                                    <t t-if="review_count &gt; 0">
                                        <div class="mza-zm-sub mza-sub-warn">
                                            <t t-esc="review_count"/> pending review
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>

                <!-- ═══════════════════════════ SPLIT: SESSIONS + TRANSACTIONS ══════ -->
                <div class="mza-section mza-section-pad">
                    <div class="mza-zaki-split">

                        <!-- Left: AI Sessions -->
                        <div class="mza-card mza-zaki-sessions-card">
                            <div class="mza-card-header">
                                <h2 class="mza-card-title" style="border:none;margin:0;padding:0">
                                    AI Sessions
                                    <span class="mza-zaki-sessions-count">
                                        <t t-esc="ai_session_count"/> total
                                    </span>
                                </h2>
                                <a href="/mumtaz/ai" class="mza-btn mza-btn-primary mza-btn-sm">+ New Chat</a>
                            </div>

                            <t t-if="recent_sessions">
                                <div class="mza-session-list">
                                    <t t-foreach="recent_sessions" t-as="session">
                                        <a t-att-href="'/mumtaz/ai?session=' + str(session.id)"
                                           class="mza-session-item">
                                            <div class="mza-session-avatar">
                                                <span class="mza-zaki-pulse-sm"/>
                                                ✦
                                            </div>
                                            <div class="mza-session-body">
                                                <div class="mza-session-name">
                                                    <t t-esc="session.name or 'AI Session #' + str(session.id)"/>
                                                </div>
                                                <div class="mza-session-meta">
                                                    <t t-esc="session.create_date" t-options='{"widget": "datetime"}'/>
                                                </div>
                                            </div>
                                            <span class="mza-session-arrow">→</span>
                                        </a>
                                    </t>
                                </div>
                                <div style="margin-top:12px">
                                    <a href="/mumtaz/ai" class="mza-btn mza-btn-ghost mza-btn-sm" style="width:100%;justify-content:center">
                                        View all sessions →
                                    </a>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="mza-zaki-no-sessions">
                                    <div class="mza-zaki-empty-icon">✦</div>
                                    <p>No AI sessions yet.</p>
                                    <a href="/mumtaz/ai" class="mza-btn mza-btn-primary mza-btn-sm">Start a conversation</a>
                                </div>
                            </t>
                        </div>

                        <!-- Right: Transaction Queue + Quick Actions -->
                        <div class="mza-zaki-right-col">

                            <!-- Transaction review queue -->
                            <t t-if="review_count &gt; 0">
                                <div class="mza-card mza-zaki-review-card">
                                    <div class="mza-zaki-review-header">
                                        <span class="mza-zaki-review-dot"/>
                                        <span class="mza-zaki-review-title">Review Queue</span>
                                        <span class="mza-badge mza-badge-yellow">
                                            <t t-esc="review_count"/> pending
                                        </span>
                                    </div>
                                    <p class="mza-zaki-review-sub">Transactions flagged for manual review.</p>
                                    <a href="/web#action=mumtaz_cfo_transactions.action_cfo_review_queue"
                                       class="mza-btn mza-btn-primary mza-btn-sm" style="width:100%;justify-content:center">
                                        Review Now →
                                    </a>
                                </div>
                            </t>

                            <!-- Recent transactions mini-table -->
                            <t t-if="recent_txs">
                                <div class="mza-card">
                                    <div class="mza-card-header">
                                        <span class="mza-card-title" style="border:none;margin:0;padding:0;font-size:13.5px">Recent Transactions</span>
                                        <a href="/mumtaz/cfo" class="mza-card-link">View all →</a>
                                    </div>
                                    <div class="mza-tx-mini-list">
                                        <t t-foreach="recent_txs" t-as="tx">
                                            <div t-att-class="'mza-tx-row ' + ('mza-tx-in' if tx.direction == 'inflow' else 'mza-tx-out')">
                                                <div class="mza-tx-dir">
                                                    <t t-if="tx.direction == 'inflow'">↑</t>
                                                    <t t-else="">↓</t>
                                                </div>
                                                <div class="mza-tx-info">
                                                    <div class="mza-tx-desc">
                                                        <t t-esc="(tx.description or 'Transaction')[:32]"/>
                                                    </div>
                                                    <div class="mza-tx-date">
                                                        <t t-esc="tx.date" t-options='{"widget": "date"}'/>
                                                        <t t-if="tx.requires_review">
                                                            <span class="mza-badge mza-badge-yellow" style="font-size:9px;padding:1px 5px">Review</span>
                                                        </t>
                                                    </div>
                                                </div>
                                                <div t-att-class="'mza-tx-amount ' + ('mza-tx-pos' if tx.direction == 'inflow' else 'mza-tx-neg')">
                                                    <t t-esc="('+' if tx.direction == 'inflow' else '−') + ' %.0f' % tx.amount"/>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </t>

                            <!-- Quick actions -->
                            <div class="mza-card">
                                <div class="mza-zaki-quick-title">Quick Actions</div>
                                <div class="mza-zaki-quick-grid">
                                    <a href="/mumtaz/cfo" class="mza-zaki-quick-btn">
                                        <span>📊</span> CFO Workspace
                                    </a>
                                    <a href="/web#action=mumtaz_cfo_transactions.action_cfo_transaction_list"
                                       class="mza-zaki-quick-btn">
                                        <span>💳</span> All Transactions
                                    </a>
                                    <a href="/web#action=mumtaz_cfo_ingestion.action_cfo_upload_batch"
                                       class="mza-zaki-quick-btn">
                                        <span>⬆</span> Upload Data
                                    </a>
                                    <a href="/mumtaz/finance" class="mza-zaki-quick-btn">
                                        <span>🏦</span> Finance Hub
                                    </a>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- ═══════════════════════════ EMPTY STATE ═══════════════════════ -->
                <t t-if="not workspace">
                    <div class="mza-section mza-section-pad">
                        <div class="mza-zaki-setup-card">
                            <div class="mza-zaki-setup-glow"/>
                            <div class="mza-zaki-setup-icon">✦</div>
                            <h3 class="mza-zaki-setup-title">Set Up Your CFO Workspace</h3>
                            <p class="mza-zaki-setup-sub">
                                Create a workspace to start tracking transactions and unlock AI-powered financial insights with ZAKI.
                            </p>
                            <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
                                <a href="/mumtaz/cfo" class="mza-btn mza-btn-primary">Create Workspace</a>
                                <a href="/mumtaz/ai" class="mza-btn mza-btn-ghost">Talk to ZAKI →</a>
                            </div>
                        </div>
                    </div>
                </t>

            </div>
        </t>
    </template>
</odoo>
