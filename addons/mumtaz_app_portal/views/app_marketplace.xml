<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="app_marketplace" name="Mumtaz App — Marketplace Section">
        <t t-call="mumtaz_app_portal.app_base_layout">

            <div class="mza-page">

                <!-- ═══════════════════════════ MARKETPLACE HERO ══════════════════ -->
                <div class="mza-portal-hero mza-portal-hero-marketplace">
                    <div class="mza-portal-hero-content">
                        <div class="mza-portal-hero-left">
                            <div class="mza-portal-hero-badge mza-badge-marketplace">Marketplace</div>
                            <h1 class="mza-portal-hero-title">SME Network</h1>
                            <p class="mza-portal-hero-sub">
                                Discover products, services, and partnership opportunities across the Mumtaz SME ecosystem.
                            </p>
                            <div class="mza-portal-hero-actions">
                                <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings&amp;view_type=form"
                                   class="mza-btn mza-btn-primary">+ Post Listing</a>
                                <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings"
                                   class="mza-btn mza-btn-ghost">Browse All</a>
                            </div>
                        </div>
                        <div class="mza-portal-hero-stats">
                            <div class="mza-portal-hero-stat">
                                <div class="mza-portal-hero-stat-val mza-val-green">
                                    <t t-esc="total_listings"/>
                                </div>
                                <div class="mza-portal-hero-stat-lbl">Active Listings</div>
                            </div>
                            <div class="mza-portal-hero-stat">
                                <div class="mza-portal-hero-stat-val">
                                    <t t-esc="my_listings"/>
                                </div>
                                <div class="mza-portal-hero-stat-lbl">Mine Published</div>
                            </div>
                            <div class="mza-portal-hero-stat">
                                <div t-att-class="'mza-portal-hero-stat-val' + (' mza-val-amber' if new_inquiry_count &gt; 0 else '')">
                                    <t t-esc="new_inquiry_count if new_inquiry_count &gt; 0 else inquiry_count"/>
                                </div>
                                <div class="mza-portal-hero-stat-lbl">
                                    <t t-if="new_inquiry_count &gt; 0">New Inquiries</t>
                                    <t t-else="">Inquiries</t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ═══════════════════════════ LISTING TYPE BREAKDOWN ════════════ -->
                <t t-if="total_listings &gt; 0">
                    <div class="mza-section mza-section-pad">
                        <div class="mza-mkt-type-strip">
                            <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings"
                               class="mza-mkt-type-card">
                                <div class="mza-mkt-type-icon mza-mkt-icon-blue">📦</div>
                                <div class="mza-mkt-type-val">
                                    <t t-esc="product_count"/>
                                </div>
                                <div class="mza-mkt-type-lbl">Products</div>
                            </a>
                            <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings"
                               class="mza-mkt-type-card">
                                <div class="mza-mkt-type-icon mza-mkt-icon-purple">🔧</div>
                                <div class="mza-mkt-type-val">
                                    <t t-esc="service_count"/>
                                </div>
                                <div class="mza-mkt-type-lbl">Services</div>
                            </a>
                            <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings"
                               class="mza-mkt-type-card">
                                <div class="mza-mkt-type-icon mza-mkt-icon-green">🤝</div>
                                <div class="mza-mkt-type-val">
                                    <t t-esc="partnership_count"/>
                                </div>
                                <div class="mza-mkt-type-lbl">Partnerships</div>
                            </a>
                            <t t-if="my_draft_listings &gt; 0">
                                <a href="/web#action=mumtaz_marketplace.action_mumtaz_my_listings"
                                   class="mza-mkt-type-card mza-mkt-type-draft">
                                    <div class="mza-mkt-type-icon mza-mkt-icon-gray">✏️</div>
                                    <div class="mza-mkt-type-val mza-val-amber">
                                        <t t-esc="my_draft_listings"/>
                                    </div>
                                    <div class="mza-mkt-type-lbl">My Drafts</div>
                                </a>
                            </t>
                        </div>
                    </div>
                </t>

                <!-- ═══════════════════════════ CATEGORIES ════════════════════════ -->
                <t t-if="categories">
                    <div class="mza-section mza-section-pad">
                        <h2 class="mza-section-title" style="margin-bottom:14px">Browse by Category</h2>
                        <div class="mza-category-chips">
                            <t t-foreach="categories" t-as="cat">
                                <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings"
                                   class="mza-category-chip">
                                    <t t-if="cat.icon"><i t-att-class="'fa ' + cat.icon"/></t>
                                    <t t-else="">🏷️</t>
                                    <span><t t-esc="cat.name"/></span>
                                    <span class="mza-chip-badge"><t t-esc="cat.listing_count or 0"/></span>
                                </a>
                            </t>
                        </div>
                    </div>
                </t>

                <!-- ═══════════════════════════ MAIN CONTENT SPLIT ════════════════ -->
                <div class="mza-section mza-section-pad">
                    <div class="mza-mkt-split">

                        <!-- Listings grid -->
                        <div class="mza-mkt-listings">
                            <div class="mza-section-head" style="margin-bottom:16px">
                                <h2 class="mza-section-title">Latest Listings</h2>
                                <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings"
                                   class="mza-section-link">View all →</a>
                            </div>
                            <t t-if="featured_listings">
                                <div class="mza-listing-grid">
                                    <t t-foreach="featured_listings" t-as="listing">
                                        <a t-att-href="'/web#id=' + str(listing.id) + '&amp;model=mumtaz.marketplace.listing&amp;view_type=form'"
                                           class="mza-listing-card">
                                            <div class="mza-listing-img">
                                                <t t-if="listing.listing_type == 'product'">📦</t>
                                                <t t-elif="listing.listing_type == 'service'">🔧</t>
                                                <t t-elif="listing.listing_type == 'partnership'">🤝</t>
                                                <t t-else="">🛒</t>
                                            </div>
                                            <div class="mza-listing-body">
                                                <div class="mza-listing-title">
                                                    <t t-esc="listing.name"/>
                                                </div>
                                                <div class="mza-listing-meta">
                                                    <t t-if="listing.short_description">
                                                        <t t-esc="listing.short_description[:80]"/>
                                                    </t>
                                                    <t t-elif="listing.category_id">
                                                        <t t-esc="listing.category_id.name"/>
                                                    </t>
                                                </div>
                                                <div class="mza-listing-footer">
                                                    <span class="mza-listing-price">
                                                        <t t-if="listing.price_type == 'free'">Free</t>
                                                        <t t-elif="listing.price_type == 'negotiable'">Negotiable</t>
                                                        <t t-elif="listing.price_type == 'from'">From <t t-esc="'%.0f' % (listing.price or 0)"/></t>
                                                        <t t-else=""><t t-esc="'%.0f' % (listing.price or 0)"/></t>
                                                    </span>
                                                    <span class="mza-badge mza-badge-green" style="font-size:10px">
                                                        <t t-esc="listing.listing_type or 'listing'"/>
                                                    </span>
                                                </div>
                                            </div>
                                        </a>
                                    </t>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="mza-empty">
                                    <div class="mza-empty-icon">🛒</div>
                                    <div class="mza-empty-title">No listings yet</div>
                                    <div class="mza-empty-sub">Be the first to post a product or service.</div>
                                    <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings&amp;view_type=form"
                                       class="mza-btn mza-btn-primary" style="margin-top:12px">Post a Listing</a>
                                </div>
                            </t>
                        </div>

                        <!-- Inquiries sidebar -->
                        <div class="mza-mkt-sidebar">

                            <!-- New inquiries alert -->
                            <t t-if="new_inquiry_count &gt; 0">
                                <div class="mza-mkt-inquiry-alert">
                                    <div class="mza-mkt-inquiry-alert-icon">💬</div>
                                    <div class="mza-mkt-inquiry-alert-body">
                                        <div class="mza-mkt-inquiry-alert-val">
                                            <t t-esc="new_inquiry_count"/>
                                        </div>
                                        <div class="mza-mkt-inquiry-alert-lbl">New Inquiries</div>
                                    </div>
                                    <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_inquiries"
                                       class="mza-btn mza-btn-primary mza-btn-sm">Review →</a>
                                </div>
                            </t>

                            <!-- Recent inquiries list -->
                            <div class="mza-card">
                                <div class="mza-card-header">
                                    <span class="mza-card-title" style="border:none;margin:0;padding:0;font-size:13.5px">Recent Inquiries</span>
                                    <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_inquiries"
                                       class="mza-card-link">All →</a>
                                </div>
                                <t t-if="recent_inquiries">
                                    <div class="mza-inquiry-list">
                                        <t t-foreach="recent_inquiries" t-as="inq">
                                            <a t-att-href="'/web#id=' + str(inq.id) + '&amp;model=mumtaz.marketplace.inquiry&amp;view_type=form'"
                                               class="mza-inquiry-item">
                                                <div t-att-class="'mza-inquiry-dot ' + ('mza-dot-new' if inq.state == 'new' else 'mza-dot-done')"/>
                                                <div class="mza-inquiry-body">
                                                    <div class="mza-inquiry-name">
                                                        <t t-esc="inq.inquirer_name or inq.inquirer_company or 'Inquiry'"/>
                                                    </div>
                                                    <div class="mza-inquiry-listing">
                                                        <t t-if="inq.listing_id">
                                                            <t t-esc="inq.listing_id.name"/>
                                                        </t>
                                                    </div>
                                                </div>
                                                <span t-att-class="'mza-badge ' + ('mza-badge-yellow' if inq.state == 'new' else 'mza-badge-green')" style="font-size:9px">
                                                    <t t-esc="inq.state"/>
                                                </span>
                                            </a>
                                        </t>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="mza-empty" style="padding:24px">
                                        <div class="mza-empty-icon" style="font-size:28px">💬</div>
                                        <div class="mza-empty-title" style="font-size:13px">No inquiries yet</div>
                                    </div>
                                </t>
                            </div>

                            <!-- Quick actions -->
                            <div class="mza-card">
                                <div class="mza-zaki-quick-title">Quick Actions</div>
                                <div style="display:flex;flex-direction:column;gap:8px">
                                    <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings&amp;view_type=form"
                                       class="mza-btn mza-btn-primary mza-btn-sm" style="justify-content:center">
                                        + Post a Listing
                                    </a>
                                    <a href="/web#action=mumtaz_marketplace.action_mumtaz_my_listings"
                                       class="mza-btn mza-btn-ghost mza-btn-sm" style="justify-content:center">
                                        My Listings
                                    </a>
                                    <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_inquiries"
                                       class="mza-btn mza-btn-ghost mza-btn-sm" style="justify-content:center">
                                        All Inquiries
                                    </a>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

            </div>
        </t>
    </template>
</odoo>
