<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="app_marketplace" name="Mumtaz App — Marketplace Section">
        <t t-call="mumtaz_app_portal.app_base_layout">

            <div class="mza-page">

                <!-- Section header -->
                <div class="mza-section-hero mza-hero-marketplace">
                    <div class="mza-hero-inner">
                        <div>
                            <h1 class="mza-hero-title">Marketplace</h1>
                            <p class="mza-hero-sub">Discover products, services, and partnership opportunities across the SME network</p>
                        </div>
                        <div class="mza-hero-actions">
                            <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings&amp;view_type=form"
                               class="mza-btn mza-btn-primary">+ Post Listing</a>
                            <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings"
                               class="mza-btn mza-btn-ghost">Browse All</a>
                        </div>
                    </div>
                </div>

                <!-- Stats -->
                <div class="mza-section">
                    <div class="mza-stat-row">
                        <div class="mza-stat-card">
                            <div class="mza-stat-val"><t t-esc="total_listings"/></div>
                            <div class="mza-stat-lbl">Active Listings</div>
                        </div>
                        <div class="mza-stat-card mza-stat-blue">
                            <div class="mza-stat-val"><t t-esc="my_listings"/></div>
                            <div class="mza-stat-lbl">My Published</div>
                            <t t-if="my_draft_listings &gt; 0">
                                <div class="mza-stat-sub"><t t-esc="my_draft_listings"/> draft(s)</div>
                            </t>
                        </div>
                        <t t-if="new_inquiry_count &gt; 0">
                            <div class="mza-stat-card mza-stat-warning">
                                <div class="mza-stat-val"><t t-esc="new_inquiry_count"/></div>
                                <div class="mza-stat-lbl">New Inquiries</div>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="mza-stat-card mza-stat-success">
                                <div class="mza-stat-val"><t t-esc="inquiry_count"/></div>
                                <div class="mza-stat-lbl">Total Inquiries</div>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- Type breakdown strip -->
                <t t-if="total_listings &gt; 0">
                    <div class="mza-section">
                        <div class="mza-intel-strip mza-intel-marketplace">
                            <div class="mza-intel-cell">
                                <span class="mza-intel-val">📦 <t t-esc="product_count"/></span>
                                <span class="mza-intel-key">Products</span>
                            </div>
                            <div class="mza-intel-cell">
                                <span class="mza-intel-val">🔧 <t t-esc="service_count"/></span>
                                <span class="mza-intel-key">Services</span>
                            </div>
                            <div class="mza-intel-cell">
                                <span class="mza-intel-val">🤝 <t t-esc="partnership_count"/></span>
                                <span class="mza-intel-key">Partnerships</span>
                            </div>
                        </div>
                    </div>
                </t>

                <!-- Quick actions -->
                <div class="mza-section">
                    <h2 class="mza-section-title">Actions</h2>
                    <div class="mza-action-grid">
                        <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings"
                           class="mza-action-tile">
                            <span class="mza-tile-icon">🛒</span>
                            <span class="mza-tile-lbl">Browse All</span>
                        </a>
                        <a href="/web#action=mumtaz_marketplace.action_mumtaz_my_listings"
                           class="mza-action-tile">
                            <span class="mza-tile-icon">📋</span>
                            <span class="mza-tile-lbl">My Listings</span>
                        </a>
                        <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_inquiries"
                           class="mza-action-tile">
                            <span class="mza-tile-icon">💬</span>
                            <span class="mza-tile-lbl">Inquiries
                                <t t-if="new_inquiry_count &gt; 0">
                                    <span class="mza-badge mza-badge-warning">
                                        <t t-esc="new_inquiry_count"/>
                                    </span>
                                </t>
                            </span>
                        </a>
                        <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings&amp;view_type=form"
                           class="mza-action-tile mza-tile-featured">
                            <span class="mza-tile-icon">✏️</span>
                            <span class="mza-tile-lbl">Post Listing</span>
                        </a>
                        <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_categories"
                           class="mza-action-tile">
                            <span class="mza-tile-icon">🏷️</span>
                            <span class="mza-tile-lbl">Categories</span>
                        </a>
                    </div>
                </div>

                <!-- Categories -->
                <t t-if="categories">
                    <div class="mza-section">
                        <h2 class="mza-section-title">Browse by Category</h2>
                        <div class="mza-category-row">
                            <t t-foreach="categories" t-as="cat">
                                <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings"
                                   class="mza-category-chip">
                                    <t t-if="cat.icon">
                                        <i t-att-class="'fa ' + cat.icon"/>
                                    </t>
                                    <t t-else="">🏷️</t>
                                    <span><t t-esc="cat.name"/></span>
                                    <span class="mza-chip-count">
                                        <t t-esc="cat.listing_count or 0"/>
                                    </span>
                                </a>
                            </t>
                        </div>
                    </div>
                </t>

                <!-- Recent inquiries -->
                <t t-if="recent_inquiries">
                    <div class="mza-section">
                        <div class="mza-section-hdr">
                            <h2 class="mza-section-title">Recent Inquiries</h2>
                            <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_inquiries"
                               class="mza-section-link">View all →</a>
                        </div>
                        <div class="mza-list">
                            <t t-foreach="recent_inquiries" t-as="inq">
                                <a t-att-href="'/web#id=' + str(inq.id) + '&amp;model=mumtaz.marketplace.inquiry&amp;view_type=form'"
                                   class="mza-list-item">
                                    <span class="mza-list-icon">
                                        <t t-if="inq.state == 'new'">🆕</t>
                                        <t t-elif="inq.state == 'responded'">✅</t>
                                        <t t-else="">💬</t>
                                    </span>
                                    <div class="mza-list-body">
                                        <div class="mza-list-title">
                                            <t t-esc="inq.inquirer_name or inq.inquirer_company or 'Inquiry'"/>
                                            <t t-if="inq.listing_id"> — <t t-esc="inq.listing_id.name"/></t>
                                        </div>
                                        <div class="mza-list-meta">
                                            <span t-att-class="'mza-badge mza-badge-' + ('warning' if inq.state == 'new' else 'success' if inq.state == 'responded' else 'draft')">
                                                <t t-esc="inq.state"/>
                                            </span>
                                            · <t t-esc="inq.create_date" t-options='{"widget": "datetime"}'/>
                                        </div>
                                    </div>
                                    <span class="mza-list-arrow">→</span>
                                </a>
                            </t>
                        </div>
                    </div>
                </t>

                <!-- Latest listings grid -->
                <div class="mza-section">
                    <div class="mza-section-hdr">
                        <h2 class="mza-section-title">Latest Listings</h2>
                        <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings"
                           class="mza-section-link">View all →</a>
                    </div>
                    <t t-if="featured_listings">
                        <div class="mza-listing-grid">
                            <t t-foreach="featured_listings" t-as="listing">
                                <a t-att-href="'/web#id=' + str(listing.id) + '&amp;model=mumtaz.marketplace.listing&amp;view_type=form'"
                                   class="mza-listing-card">
                                    <div class="mza-listing-top">
                                        <span class="mza-badge mza-badge-success">
                                            <t t-esc="listing.listing_type or 'listing'"/>
                                        </span>
                                        <t t-if="listing.category_id">
                                            <span class="mza-listing-cat">
                                                <t t-esc="listing.category_id.name"/>
                                            </span>
                                        </t>
                                    </div>
                                    <div class="mza-listing-name"><t t-esc="listing.name"/></div>
                                    <t t-if="listing.short_description">
                                        <div class="mza-listing-desc">
                                            <t t-esc="listing.short_description"/>
                                        </div>
                                    </t>
                                    <div class="mza-listing-foot">
                                        <span class="mza-listing-price">
                                            <t t-if="listing.price_type == 'free'">Free</t>
                                            <t t-elif="listing.price_type == 'negotiable'">Negotiable</t>
                                            <t t-elif="listing.price_type == 'from'">From <t t-esc="'%.0f' % (listing.price or 0)"/></t>
                                            <t t-else=""><t t-esc="'%.0f' % (listing.price or 0)"/></t>
                                        </span>
                                        <span class="mza-listing-co">
                                            <t t-esc="listing.company_id.name"/>
                                        </span>
                                    </div>
                                </a>
                            </t>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="mza-empty">
                            <div class="mza-empty-icon">🛒</div>
                            <div class="mza-empty-title">No listings yet</div>
                            <div class="mza-empty-body">Be the first to post a product or service.</div>
                            <a href="/web#action=mumtaz_marketplace.action_mumtaz_marketplace_listings&amp;view_type=form"
                               class="mza-btn mza-btn-primary">Post a Listing</a>
                        </div>
                    </t>
                </div>

            </div>
        </t>
    </template>
</odoo>
