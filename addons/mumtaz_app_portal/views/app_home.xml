<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="app_home" name="Mumtaz App — Home Dashboard">
        <t t-call="mumtaz_app_portal.app_base_layout">

            <div class="mza-page">

                <!-- Welcome banner -->
                <div class="mza-welcome-banner">
                    <div class="mza-welcome-inner">
                        <div class="mza-welcome-text">
                            <h1 class="mza-welcome-title">
                                Welcome back<t t-if="user.name">, <t t-esc="user.name.split()[0]"/></t>
                            </h1>
                            <p class="mza-welcome-sub">
                                <t t-esc="company.name"/> · <t t-esc="today_date"/>
                            </p>
                        </div>
                        <t t-if="subscription">
                            <div t-att-class="'mza-sub-pill mza-sub-' + (subscription.status or 'trial')">
                                <span class="mza-sub-dot"/>
                                <t t-esc="subscription.plan_id.name if subscription.plan_id else 'Trial'"/>
                                <t t-if="subscription.status == 'trial' and subscription.trial_end_date">
                                    — ends <t t-esc="subscription.trial_end_date" t-options='{"widget": "date"}'/>
                                </t>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- Health overview cards -->
                <div class="mza-section">
                    <div class="mza-health-grid">

                        <!-- ERP health -->
                        <t t-if="has_erp">
                            <a href="/app/erp" class="mza-health-card mza-health-erp">
                                <div class="mza-health-header">
                                    <span class="mza-health-icon">🎯</span>
                                    <span class="mza-health-label">ERP</span>
                                    <span class="mza-health-arrow">→</span>
                                </div>
                                <div class="mza-health-stats">
                                    <div class="mza-health-stat">
                                        <span class="mza-health-num"><t t-esc="erp_leads_total or 0"/></span>
                                        <span class="mza-health-stat-label">Leads</span>
                                    </div>
                                    <div class="mza-health-stat">
                                        <span class="mza-health-num mza-num-warning"><t t-esc="erp_opps_open or 0"/></span>
                                        <span class="mza-health-stat-label">Open Opps</span>
                                    </div>
                                    <div class="mza-health-stat">
                                        <span class="mza-health-num mza-num-success"><t t-esc="erp_opps_won or 0"/></span>
                                        <span class="mza-health-stat-label">Won</span>
                                    </div>
                                </div>
                                <t t-if="erp_campaign_count and erp_campaign_count &gt; 0">
                                    <div class="mza-health-footer">
                                        📣 <t t-esc="erp_campaign_count"/> active campaign(s)
                                    </div>
                                </t>
                            </a>
                        </t>
                        <t t-if="not has_erp">
                            <div class="mza-health-card mza-health-locked">
                                <div class="mza-health-header">
                                    <span class="mza-health-icon">🎯</span>
                                    <span class="mza-health-label">ERP</span>
                                    <span class="mza-health-lock">🔒</span>
                                </div>
                                <div class="mza-health-upgrade">
                                    <p>ERP &amp; lead tools not included in your current plan.</p>
                                    <a href="/app/account" class="mza-upgrade-link">Upgrade plan →</a>
                                </div>
                            </div>
                        </t>

                        <!-- ZAKI health -->
                        <t t-if="has_zaki">
                            <a href="/app/zaki" class="mza-health-card mza-health-zaki">
                                <div class="mza-health-header">
                                    <span class="mza-health-icon">🤖</span>
                                    <span class="mza-health-label">ZAKI AI</span>
                                    <span class="mza-health-arrow">→</span>
                                </div>
                                <div class="mza-health-stats">
                                    <div class="mza-health-stat">
                                        <span class="mza-health-num"><t t-esc="zaki_tx_count or 0"/></span>
                                        <span class="mza-health-stat-label">Transactions</span>
                                    </div>
                                    <t t-if="zaki_net is not None">
                                        <div class="mza-health-stat">
                                            <span t-att-class="'mza-health-num ' + ('mza-num-success' if zaki_net &gt;= 0 else 'mza-num-danger')">
                                                <t t-esc="('+ ' if zaki_net &gt;= 0 else '− ') + '%.0f' % abs(zaki_net)"/>
                                            </span>
                                            <span class="mza-health-stat-label">Net Position</span>
                                        </div>
                                    </t>
                                    <t t-if="zaki_review_count and zaki_review_count &gt; 0">
                                        <div class="mza-health-stat">
                                            <span class="mza-health-num mza-num-warning"><t t-esc="zaki_review_count"/></span>
                                            <span class="mza-health-stat-label">Review Queue</span>
                                        </div>
                                    </t>
                                </div>
                                <t t-if="zaki_ai_sessions and zaki_ai_sessions &gt; 0">
                                    <div class="mza-health-footer">
                                        💬 <t t-esc="zaki_ai_sessions"/> AI session(s)
                                    </div>
                                </t>
                            </a>
                        </t>
                        <t t-if="not has_zaki">
                            <div class="mza-health-card mza-health-locked">
                                <div class="mza-health-header">
                                    <span class="mza-health-icon">🤖</span>
                                    <span class="mza-health-label">ZAKI AI</span>
                                    <span class="mza-health-lock">🔒</span>
                                </div>
                                <div class="mza-health-upgrade">
                                    <p>ZAKI AI CFO is not included in your plan.</p>
                                    <a href="/app/account" class="mza-upgrade-link">Upgrade plan →</a>
                                </div>
                            </div>
                        </t>

                        <!-- Marketplace health -->
                        <t t-if="has_marketplace">
                            <a href="/app/marketplace" class="mza-health-card mza-health-marketplace">
                                <div class="mza-health-header">
                                    <span class="mza-health-icon">🛒</span>
                                    <span class="mza-health-label">Marketplace</span>
                                    <span class="mza-health-arrow">→</span>
                                </div>
                                <div class="mza-health-stats">
                                    <div class="mza-health-stat">
                                        <span class="mza-health-num"><t t-esc="mp_total_listings or 0"/></span>
                                        <span class="mza-health-stat-label">Live Listings</span>
                                    </div>
                                    <div class="mza-health-stat">
                                        <span class="mza-health-num mza-num-primary"><t t-esc="mp_my_listings or 0"/></span>
                                        <span class="mza-health-stat-label">Mine</span>
                                    </div>
                                    <t t-if="mp_new_inquiries and mp_new_inquiries &gt; 0">
                                        <div class="mza-health-stat">
                                            <span class="mza-health-num mza-num-warning"><t t-esc="mp_new_inquiries"/></span>
                                            <span class="mza-health-stat-label">New Inquiries</span>
                                        </div>
                                    </t>
                                </div>
                            </a>
                        </t>
                        <t t-if="not has_marketplace">
                            <div class="mza-health-card mza-health-locked">
                                <div class="mza-health-header">
                                    <span class="mza-health-icon">🛒</span>
                                    <span class="mza-health-label">Marketplace</span>
                                    <span class="mza-health-lock">🔒</span>
                                </div>
                                <div class="mza-health-upgrade">
                                    <p>Marketplace not included in your plan.</p>
                                    <a href="/app/account" class="mza-upgrade-link">Upgrade plan →</a>
                                </div>
                            </div>
                        </t>

                    </div>
                </div>

                <!-- Quick actions -->
                <div class="mza-section">
                    <h2 class="mza-section-title">Quick Actions</h2>
                    <div class="mza-quick-grid">
                        <t t-if="has_zaki">
                            <a href="/mumtaz/ai" class="mza-quick-card mza-quick-featured">
                                <div class="mza-quick-icon">🤖</div>
                                <div class="mza-quick-label">Ask ZAKI</div>
                                <div class="mza-quick-desc">AI-powered CFO insights</div>
                            </a>
                        </t>
                        <t t-if="has_erp">
                            <a href="/app/erp" class="mza-quick-card">
                                <div class="mza-quick-icon">🎯</div>
                                <div class="mza-quick-label">CRM Pipeline</div>
                                <div class="mza-quick-desc">Leads &amp; opportunities</div>
                            </a>
                        </t>
                        <t t-if="has_marketplace">
                            <a href="/app/marketplace" class="mza-quick-card">
                                <div class="mza-quick-icon">🛒</div>
                                <div class="mza-quick-label">Marketplace</div>
                                <div class="mza-quick-desc">Listings &amp; inquiries</div>
                            </a>
                        </t>
                        <a href="/app/account" class="mza-quick-card">
                            <div class="mza-quick-icon">📋</div>
                            <div class="mza-quick-label">Account</div>
                            <div class="mza-quick-desc">Plan &amp; subscription</div>
                        </a>
                        <t t-if="has_erp">
                            <a href="/web#action=mumtaz_lead_scraper.action_lead_scraper_source"
                               class="mza-quick-card">
                                <div class="mza-quick-icon">🔍</div>
                                <div class="mza-quick-label">Lead Scraper</div>
                                <div class="mza-quick-desc">Automated lead sourcing</div>
                            </a>
                        </t>
                        <t t-if="has_zaki">
                            <a href="/app/zaki" class="mza-quick-card">
                                <div class="mza-quick-icon">💳</div>
                                <div class="mza-quick-label">Transactions</div>
                                <div class="mza-quick-desc">Financial records</div>
                            </a>
                        </t>
                    </div>
                </div>

                <!-- Onboarding checklist if incomplete -->
                <t t-if="tenant_profile and tenant_profile.onboarding_stage != 'done'">
                    <div class="mza-section">
                        <div class="mza-onboarding-card">
                            <div class="mza-onboarding-header">
                                <span class="mza-onboarding-icon">🚀</span>
                                <div>
                                    <div class="mza-onboarding-title">Get Started with Mumtaz</div>
                                    <div class="mza-onboarding-sub">Complete setup to unlock the full platform</div>
                                </div>
                                <div class="mza-onboarding-progress">
                                    <div class="mza-progress-bar">
                                        <div t-att-class="'mza-progress-fill'"
                                             t-att-style="'width: ' + str(profile_completeness or 0) + '%'"/>
                                    </div>
                                    <span class="mza-progress-label">
                                        <t t-esc="profile_completeness or 0"/>% complete
                                    </span>
                                </div>
                            </div>
                            <div class="mza-onboarding-steps">
                                <a href="/app/account" class="mza-onboarding-step mza-step-active">
                                    <span class="mza-step-check">○</span>
                                    Complete company profile
                                </a>
                                <t t-if="has_zaki and not zaki_workspace">
                                    <a href="/mumtaz/cfo" class="mza-onboarding-step mza-step-active">
                                        <span class="mza-step-check">○</span>
                                        Set up ZAKI CFO workspace
                                    </a>
                                </t>
                                <t t-if="has_marketplace and mp_my_listings == 0">
                                    <a href="/app/marketplace" class="mza-onboarding-step mza-step-active">
                                        <span class="mza-step-check">○</span>
                                        Post your first marketplace listing
                                    </a>
                                </t>
                            </div>
                        </div>
                    </div>
                </t>

            </div>
        </t>
    </template>
</odoo>
