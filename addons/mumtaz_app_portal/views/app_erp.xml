<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="app_erp" name="Mumtaz App — ERP Section">
        <t t-call="mumtaz_app_portal.app_base_layout">

            <div class="mza-page">

                <!-- Section header -->
                <div class="mza-section-hero mza-hero-erp">
                    <div class="mza-hero-inner">
                        <div>
                            <h1 class="mza-hero-title">ERP</h1>
                            <p class="mza-hero-sub">CRM pipeline, lead intelligence, nurture campaigns</p>
                        </div>
                        <div class="mza-hero-actions">
                            <a href="/web#action=crm.crm_lead_all_leads_act"
                               class="mza-btn mza-btn-primary">CRM Pipeline</a>
                            <a href="/web" class="mza-btn mza-btn-ghost">Backend</a>
                        </div>
                    </div>
                </div>

                <!-- Stats -->
                <div class="mza-section">
                    <div class="mza-stat-row">
                        <div class="mza-stat-card">
                            <div class="mza-stat-val"><t t-esc="leads_total"/></div>
                            <div class="mza-stat-lbl">Total Leads</div>
                        </div>
                        <div class="mza-stat-card mza-stat-warning">
                            <div class="mza-stat-val"><t t-esc="opps_open"/></div>
                            <div class="mza-stat-lbl">Open Opps</div>
                        </div>
                        <div class="mza-stat-card mza-stat-success">
                            <div class="mza-stat-val"><t t-esc="opps_won"/></div>
                            <div class="mza-stat-lbl">Won</div>
                        </div>
                        <div class="mza-stat-card mza-stat-blue">
                            <div class="mza-stat-val"><t t-esc="campaign_count"/></div>
                            <div class="mza-stat-lbl">Campaigns</div>
                        </div>
                    </div>
                </div>

                <!-- Intel bar -->
                <t t-if="scraper_source_count &gt; 0">
                    <div class="mza-section">
                        <div class="mza-intel-strip">
                            <div class="mza-intel-cell">
                                <span class="mza-intel-val"><t t-esc="scraper_source_count"/></span>
                                <span class="mza-intel-key">Active Sources</span>
                            </div>
                            <div class="mza-intel-cell">
                                <span class="mza-intel-val"><t t-esc="total_scraped_records"/></span>
                                <span class="mza-intel-key">Records Extracted</span>
                            </div>
                            <div class="mza-intel-cell">
                                <span class="mza-intel-val"><t t-esc="nurturing_leads"/></span>
                                <span class="mza-intel-key">Nurturing</span>
                            </div>
                            <div class="mza-intel-cell">
                                <span class="mza-intel-val mza-val-success"><t t-esc="qualified_leads"/></span>
                                <span class="mza-intel-key">Qualified</span>
                            </div>
                            <div class="mza-intel-cell">
                                <span class="mza-intel-val mza-val-gold"><t t-esc="converted_leads"/></span>
                                <span class="mza-intel-key">Converted</span>
                            </div>
                        </div>
                    </div>
                </t>

                <!-- Quick actions -->
                <div class="mza-section">
                    <h2 class="mza-section-title">Actions</h2>
                    <div class="mza-action-grid">
                        <a href="/web#action=crm.crm_lead_all_leads_act" class="mza-action-tile mza-tile-featured">
                            <span class="mza-tile-icon">🎯</span>
                            <span class="mza-tile-lbl">CRM Leads</span>
                        </a>
                        <a href="/web#action=crm.crm_lead_opportunities_tree_view" class="mza-action-tile">
                            <span class="mza-tile-icon">💼</span>
                            <span class="mza-tile-lbl">Opportunities</span>
                        </a>
                        <a href="/web#action=mumtaz_lead_scraper.action_lead_scraper_source" class="mza-action-tile">
                            <span class="mza-tile-icon">🔍</span>
                            <span class="mza-tile-lbl">Lead Sources</span>
                        </a>
                        <a href="/web#action=mumtaz_lead_scraper.action_lead_scraper_job" class="mza-action-tile">
                            <span class="mza-tile-icon">📡</span>
                            <span class="mza-tile-lbl">Scraper Jobs</span>
                        </a>
                        <a href="/web#action=mumtaz_lead_nurture.action_lead_nurture_campaign" class="mza-action-tile">
                            <span class="mza-tile-icon">📣</span>
                            <span class="mza-tile-lbl">Campaigns</span>
                        </a>
                        <a href="/web#action=mumtaz_lead_nurture.action_nurture_leads" class="mza-action-tile">
                            <span class="mza-tile-icon">🔄</span>
                            <span class="mza-tile-lbl">Nurture Leads</span>
                        </a>
                    </div>
                </div>

                <!-- Active campaigns -->
                <t t-if="active_campaigns">
                    <div class="mza-section">
                        <div class="mza-section-hdr">
                            <h2 class="mza-section-title">Active Campaigns</h2>
                            <a href="/web#action=mumtaz_lead_nurture.action_lead_nurture_campaign"
                               class="mza-section-link">View all →</a>
                        </div>
                        <div class="mza-list">
                            <t t-foreach="active_campaigns" t-as="c">
                                <a t-att-href="'/web#id=' + str(c.id) + '&amp;model=lead.nurture.campaign&amp;view_type=form'"
                                   class="mza-list-item">
                                    <span class="mza-list-icon">📣</span>
                                    <div class="mza-list-body">
                                        <div class="mza-list-title"><t t-esc="c.name"/></div>
                                        <div class="mza-list-meta">
                                            <t t-esc="c.lead_count or 0"/> leads ·
                                            <t t-esc="c.qualified_count or 0"/> qualified ·
                                            <t t-esc="c.converted_count or 0"/> converted
                                        </div>
                                    </div>
                                    <span class="mza-list-arrow">→</span>
                                </a>
                            </t>
                        </div>
                    </div>
                </t>

                <!-- Last scraper run -->
                <t t-if="last_scraper_job">
                    <div class="mza-section">
                        <h2 class="mza-section-title">Last Scraper Run</h2>
                        <div class="mza-kv-card">
                            <div class="mza-kv-row">
                                <span class="mza-kv-key">Source</span>
                                <span class="mza-kv-val"><t t-esc="last_scraper_job.source_id.name or last_scraper_job.name or '—'"/></span>
                            </div>
                            <div class="mza-kv-row">
                                <span class="mza-kv-key">Status</span>
                                <span t-att-class="'mza-badge mza-badge-' + last_scraper_job.status">
                                    <t t-esc="last_scraper_job.status"/>
                                </span>
                            </div>
                            <div class="mza-kv-row">
                                <span class="mza-kv-key">Found / Created</span>
                                <span class="mza-kv-val">
                                    <t t-esc="last_scraper_job.total_found or 0"/> found ·
                                    <span class="mza-val-success"><t t-esc="last_scraper_job.total_created or 0"/> created</span>
                                </span>
                            </div>
                            <div class="mza-kv-row">
                                <span class="mza-kv-key">Run at</span>
                                <span class="mza-kv-val">
                                    <t t-esc="last_scraper_job.create_date" t-options='{"widget": "datetime"}'/>
                                </span>
                            </div>
                        </div>
                    </div>
                </t>

                <!-- Recent leads -->
                <div class="mza-section">
                    <div class="mza-section-hdr">
                        <h2 class="mza-section-title">Recent Leads</h2>
                        <a href="/web#action=crm.crm_lead_all_leads_act" class="mza-section-link">View all →</a>
                    </div>
                    <t t-if="recent_leads">
                        <div class="mza-table-wrap">
                            <table class="mza-table">
                                <thead>
                                    <tr>
                                        <th>Name</th><th>Company</th><th>Stage</th><th>Created</th><th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="recent_leads" t-as="lead">
                                        <tr>
                                            <td class="mza-td-primary"><t t-esc="lead.name"/></td>
                                            <td><t t-esc="lead.partner_name or '—'"/></td>
                                            <td><t t-esc="lead.stage_id.name or '—'"/></td>
                                            <td><t t-esc="lead.create_date" t-options='{"widget": "date"}'/></td>
                                            <td>
                                                <a t-att-href="'/web#id=' + str(lead.id) + '&amp;model=crm.lead&amp;view_type=form'"
                                                   class="mza-table-link">View →</a>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="mza-empty">
                            <div class="mza-empty-icon">🎯</div>
                            <div class="mza-empty-title">No leads yet</div>
                            <div class="mza-empty-body">Use the lead scraper to fill your pipeline automatically.</div>
                            <a href="/web#action=mumtaz_lead_scraper.action_lead_scraper_source"
                               class="mza-btn mza-btn-primary">Set Up Scraper</a>
                        </div>
                    </t>
                </div>

            </div>
        </t>
    </template>
</odoo>
