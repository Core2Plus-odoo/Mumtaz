<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="app_erp" name="Mumtaz App — ERP Section">
        <t t-call="mumtaz_app_portal.app_base_layout">

            <div class="mza-page">

                <!-- ═══════════════════════════ ERP HERO ═══════════════════════════ -->
                <div class="mza-portal-hero mza-portal-hero-erp">
                    <div class="mza-portal-hero-content">
                        <div class="mza-portal-hero-left">
                            <div class="mza-portal-hero-badge mza-badge-erp">ERP Suite</div>
                            <h1 class="mza-portal-hero-title">Business Operations</h1>
                            <p class="mza-portal-hero-sub">
                                Full Odoo ERP — accounting, sales, CRM, inventory, HR, and more. Everything in one place.
                            </p>
                            <div class="mza-portal-hero-actions">
                                <a href="/web" class="mza-btn mza-btn-primary">Open Odoo Backend ↗</a>
                                <a href="/web#action=crm.crm_lead_all_leads_act" class="mza-btn mza-btn-ghost">CRM Pipeline</a>
                            </div>
                        </div>
                        <div class="mza-portal-hero-stats">
                            <div class="mza-portal-hero-stat">
                                <div class="mza-portal-hero-stat-val">
                                    <t t-esc="leads_total"/>
                                </div>
                                <div class="mza-portal-hero-stat-lbl">Leads</div>
                            </div>
                            <div class="mza-portal-hero-stat">
                                <div class="mza-portal-hero-stat-val mza-val-amber">
                                    <t t-esc="opps_open"/>
                                </div>
                                <div class="mza-portal-hero-stat-lbl">Open Opps</div>
                            </div>
                            <div class="mza-portal-hero-stat">
                                <div class="mza-portal-hero-stat-val mza-val-green">
                                    <t t-esc="opps_won"/>
                                </div>
                                <div class="mza-portal-hero-stat-lbl">Won</div>
                            </div>
                            <div class="mza-portal-hero-stat">
                                <div class="mza-portal-hero-stat-val mza-val-blue">
                                    <t t-esc="campaign_count"/>
                                </div>
                                <div class="mza-portal-hero-stat-lbl">Campaigns</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ═══════════════════════════ ERP MODULES ════════════════════════ -->
                <div class="mza-section mza-section-pad">
                    <div class="mza-section-head">
                        <h2 class="mza-section-title">Odoo Modules</h2>
                        <a href="/web" class="mza-section-link">Open Backend ↗</a>
                    </div>
                    <div class="mza-erp-module-grid">
                        <a href="/web#action=account.action_move_out_invoice_type" class="mza-erp-module mza-erp-mod-blue">
                            <div class="mza-erp-mod-icon">📒</div>
                            <div class="mza-erp-mod-name">Accounting</div>
                            <div class="mza-erp-mod-desc">Invoices · Journals · GL</div>
                        </a>
                        <a href="/web#action=sale.action_quotations_with_onboarding" class="mza-erp-module mza-erp-mod-green">
                            <div class="mza-erp-mod-icon">🏷️</div>
                            <div class="mza-erp-mod-name">Sales</div>
                            <div class="mza-erp-mod-desc">Orders · Quotes · Revenue</div>
                        </a>
                        <a href="/web#action=crm.crm_lead_all_leads_act" class="mza-erp-module mza-erp-mod-amber">
                            <div class="mza-erp-mod-icon">🎯</div>
                            <div class="mza-erp-mod-name">CRM</div>
                            <div class="mza-erp-mod-desc">Leads · Pipeline · Won</div>
                        </a>
                        <a href="/web#action=purchase.action_orders" class="mza-erp-module mza-erp-mod-cyan">
                            <div class="mza-erp-mod-icon">📦</div>
                            <div class="mza-erp-mod-name">Purchase</div>
                            <div class="mza-erp-mod-desc">POs · Vendors · Receipts</div>
                        </a>
                        <a href="/web#action=stock.action_stock_view" class="mza-erp-module mza-erp-mod-purple">
                            <div class="mza-erp-mod-icon">🏭</div>
                            <div class="mza-erp-mod-name">Inventory</div>
                            <div class="mza-erp-mod-desc">Stock · Transfers · Lots</div>
                        </a>
                        <a href="/web#action=hr.open_view_employee_list_my" class="mza-erp-module mza-erp-mod-teal">
                            <div class="mza-erp-mod-icon">👥</div>
                            <div class="mza-erp-mod-name">HR</div>
                            <div class="mza-erp-mod-desc">Employees · Leaves · Payroll</div>
                        </a>
                        <a href="/web#action=account.action_account_payable_tree" class="mza-erp-module mza-erp-mod-red">
                            <div class="mza-erp-mod-icon">💸</div>
                            <div class="mza-erp-mod-name">Payables</div>
                            <div class="mza-erp-mod-desc">Bills · Vendors · AP</div>
                        </a>
                        <a href="/web#action=account.action_account_receivable_tree" class="mza-erp-module mza-erp-mod-blue">
                            <div class="mza-erp-mod-icon">💰</div>
                            <div class="mza-erp-mod-name">Receivables</div>
                            <div class="mza-erp-mod-desc">Invoices · Customers · AR</div>
                        </a>
                        <a href="/web#action=base_setup.action_general_configuration" class="mza-erp-module mza-erp-mod-gray">
                            <div class="mza-erp-mod-icon">⚙️</div>
                            <div class="mza-erp-mod-name">Settings</div>
                            <div class="mza-erp-mod-desc">Company · Users · Config</div>
                        </a>
                    </div>
                </div>

                <!-- ═══════════════════════════ INTEL STRIP (if scraper active) ════ -->
                <t t-if="scraper_source_count &gt; 0">
                    <div class="mza-section mza-section-pad">
                        <div class="mza-intel-banner">
                            <div class="mza-intel-banner-label">
                                <span>📡</span> Lead Intelligence
                            </div>
                            <div class="mza-intel-banner-stats">
                                <div class="mza-intel-stat">
                                    <div class="mza-intel-stat-val">
                                        <t t-esc="scraper_source_count"/>
                                    </div>
                                    <div class="mza-intel-stat-lbl">Active Sources</div>
                                </div>
                                <div class="mza-intel-stat">
                                    <div class="mza-intel-stat-val">
                                        <t t-esc="total_scraped_records"/>
                                    </div>
                                    <div class="mza-intel-stat-lbl">Records Extracted</div>
                                </div>
                                <div class="mza-intel-stat">
                                    <div class="mza-intel-stat-val mza-val-blue">
                                        <t t-esc="nurturing_leads"/>
                                    </div>
                                    <div class="mza-intel-stat-lbl">Nurturing</div>
                                </div>
                                <div class="mza-intel-stat">
                                    <div class="mza-intel-stat-val mza-val-green">
                                        <t t-esc="qualified_leads"/>
                                    </div>
                                    <div class="mza-intel-stat-lbl">Qualified</div>
                                </div>
                                <div class="mza-intel-stat">
                                    <div class="mza-intel-stat-val mza-val-amber">
                                        <t t-esc="converted_leads"/>
                                    </div>
                                    <div class="mza-intel-stat-lbl">Converted</div>
                                </div>
                            </div>
                            <a href="/web#action=mumtaz_lead_scraper.action_lead_scraper_source"
                               class="mza-btn mza-btn-ghost mza-btn-sm">Manage →</a>
                        </div>
                    </div>
                </t>

                <!-- ═══════════════════════════ BOTTOM SPLIT ══════════════════════ -->
                <div class="mza-section mza-section-pad">
                    <div class="mza-cols-2">

                        <!-- Active campaigns -->
                        <div class="mza-card">
                            <div class="mza-card-header">
                                <span class="mza-card-title" style="border:none;margin:0;padding:0;font-size:13.5px">Active Campaigns</span>
                                <a href="/web#action=mumtaz_lead_nurture.action_lead_nurture_campaign"
                                   class="mza-card-link">View all →</a>
                            </div>
                            <t t-if="active_campaigns">
                                <div class="mza-campaign-list">
                                    <t t-foreach="active_campaigns" t-as="c">
                                        <a t-att-href="'/web#id=' + str(c.id) + '&amp;model=lead.nurture.campaign&amp;view_type=form'"
                                           class="mza-campaign-item">
                                            <div class="mza-campaign-icon">📣</div>
                                            <div class="mza-campaign-body">
                                                <div class="mza-campaign-name">
                                                    <t t-esc="c.name"/>
                                                </div>
                                                <div class="mza-campaign-stats">
                                                    <span><t t-esc="c.lead_count or 0"/> leads</span>
                                                    <span class="mza-campaign-dot">·</span>
                                                    <span class="mza-val-green"><t t-esc="c.qualified_count or 0"/> qualified</span>
                                                    <span class="mza-campaign-dot">·</span>
                                                    <span class="mza-val-amber"><t t-esc="c.converted_count or 0"/> converted</span>
                                                </div>
                                            </div>
                                            <span class="mza-campaign-arrow">→</span>
                                        </a>
                                    </t>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="mza-empty" style="padding:32px 16px">
                                    <div class="mza-empty-icon">📣</div>
                                    <div class="mza-empty-title">No active campaigns</div>
                                    <div class="mza-empty-sub">
                                        <a href="/web#action=mumtaz_lead_nurture.action_lead_nurture_campaign"
                                           class="mza-table-link">Create a campaign →</a>
                                    </div>
                                </div>
                            </t>
                        </div>

                        <!-- Recent leads -->
                        <div class="mza-card">
                            <div class="mza-card-header">
                                <span class="mza-card-title" style="border:none;margin:0;padding:0;font-size:13.5px">
                                    Recent Leads
                                </span>
                                <a href="/web#action=crm.crm_lead_all_leads_act" class="mza-card-link">View all →</a>
                            </div>
                            <t t-if="recent_leads">
                                <div class="mza-lead-list">
                                    <t t-foreach="recent_leads" t-as="lead">
                                        <a t-att-href="'/web#id=' + str(lead.id) + '&amp;model=crm.lead&amp;view_type=form'"
                                           class="mza-lead-item">
                                            <div class="mza-lead-avatar">
                                                <t t-esc="(lead.contact_name or lead.name or 'L')[0].upper()"/>
                                            </div>
                                            <div class="mza-lead-body">
                                                <div class="mza-lead-name">
                                                    <t t-esc="lead.name"/>
                                                </div>
                                                <div class="mza-lead-meta">
                                                    <t t-esc="lead.partner_name or '—'"/>
                                                    <t t-if="lead.stage_id">
                                                        · <span class="mza-badge mza-badge-blue" style="font-size:9px"><t t-esc="lead.stage_id.name"/></span>
                                                    </t>
                                                </div>
                                            </div>
                                            <span class="mza-lead-date">
                                                <t t-esc="lead.create_date" t-options='{"widget": "date"}'/>
                                            </span>
                                        </a>
                                    </t>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="mza-empty" style="padding:32px 16px">
                                    <div class="mza-empty-icon">🎯</div>
                                    <div class="mza-empty-title">No leads yet</div>
                                    <div class="mza-empty-sub">
                                        <a href="/web#action=mumtaz_lead_scraper.action_lead_scraper_source"
                                           class="mza-table-link">Set up lead scraper →</a>
                                    </div>
                                </div>
                            </t>
                        </div>

                    </div>
                </div>

                <!-- ═══════════════════════════ QUICK ACTIONS ═════════════════════ -->
                <div class="mza-section mza-section-pad">
                    <h2 class="mza-section-title" style="margin-bottom:14px">Quick Actions</h2>
                    <div class="mza-action-grid">
                        <a href="/web#action=crm.crm_lead_all_leads_act" class="mza-action-tile mza-action-featured">
                            <span class="mza-action-tile-icon">🎯</span>
                            <span>CRM Leads</span>
                        </a>
                        <a href="/web#action=account.action_move_out_invoice_type" class="mza-action-tile">
                            <span class="mza-action-tile-icon">📒</span>
                            <span>Invoices</span>
                        </a>
                        <a href="/web#action=sale.action_quotations_with_onboarding" class="mza-action-tile">
                            <span class="mza-action-tile-icon">🏷️</span>
                            <span>Sales Orders</span>
                        </a>
                        <a href="/web#action=purchase.action_orders" class="mza-action-tile">
                            <span class="mza-action-tile-icon">📦</span>
                            <span>Purchase Orders</span>
                        </a>
                        <a href="/web#action=mumtaz_lead_scraper.action_lead_scraper_job" class="mza-action-tile">
                            <span class="mza-action-tile-icon">📡</span>
                            <span>Scraper Jobs</span>
                        </a>
                        <a href="/web#action=mumtaz_lead_nurture.action_lead_nurture_campaign" class="mza-action-tile">
                            <span class="mza-action-tile-icon">📣</span>
                            <span>Campaigns</span>
                        </a>
                    </div>
                </div>

            </div>
        </t>
    </template>
</odoo>
