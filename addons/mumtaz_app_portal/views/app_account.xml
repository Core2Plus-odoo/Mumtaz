<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="app_account" name="Mumtaz App — Account &amp; Plan">
        <t t-call="mumtaz_app_portal.app_base_layout">

            <div class="mza-page">

                <!-- ═══════════════════════════ ACCOUNT HERO ═════════════════════ -->
                <div class="mza-portal-hero mza-portal-hero-account">
                    <div class="mza-portal-hero-content">
                        <div class="mza-portal-hero-left">
                            <div class="mza-portal-hero-badge mza-badge-account">Account</div>
                            <h1 class="mza-portal-hero-title">
                                <t t-esc="company.name"/>
                            </h1>
                            <p class="mza-portal-hero-sub">
                                Subscription, enabled features, company profile, and user settings.
                            </p>
                        </div>
                        <div class="mza-acct-hero-plan">
                            <t t-if="subscription">
                                <div class="mza-plan-badge-hero">
                                    <div class="mza-plan-badge-name">
                                        <t t-esc="subscription.plan_id.name if subscription.plan_id else 'Custom Plan'"/>
                                    </div>
                                    <div t-att-class="'mza-plan-badge-status ' + ('mza-plan-active' if subscription.status == 'active' else 'mza-plan-trial' if subscription.status in ['trial','grace'] else 'mza-plan-expired')">
                                        <t t-esc="subscription.status"/>
                                    </div>
                                </div>
                                <t t-if="subscription.renewal_date">
                                    <div class="mza-plan-renewal">
                                        Renews <t t-esc="subscription.renewal_date" t-options='{"widget": "date"}'/>
                                    </div>
                                </t>
                                <t t-if="subscription.status == 'trial' and subscription.trial_end_date">
                                    <div class="mza-plan-renewal mza-plan-trial-end">
                                        Trial ends <t t-esc="subscription.trial_end_date" t-options='{"widget": "date"}'/>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="mza-plan-badge-hero">
                                    <div class="mza-plan-badge-name">No Plan</div>
                                    <div class="mza-plan-badge-status mza-plan-expired">inactive</div>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- ═══════════════════════════ SUBSCRIPTION DETAILS ════════════ -->
                <div class="mza-section mza-section-pad">
                    <div class="mza-cols-2">

                        <!-- Plan card -->
                        <div class="mza-acct-plan-card">
                            <div class="mza-acct-plan-header">
                                <div class="mza-acct-plan-icon">📋</div>
                                <div class="mza-acct-plan-info">
                                    <div class="mza-acct-plan-name">
                                        <t t-if="subscription and subscription.plan_id">
                                            <t t-esc="subscription.plan_id.name"/>
                                        </t>
                                        <t t-else="">No Active Plan</t>
                                    </div>
                                    <div class="mza-acct-plan-sub">Subscription Plan</div>
                                </div>
                                <t t-if="subscription">
                                    <span t-att-class="'mza-badge ' + ('mza-badge-green' if subscription.status == 'active' else 'mza-badge-yellow' if subscription.status in ['trial','grace'] else 'mza-badge-red')">
                                        <t t-esc="subscription.status"/>
                                    </span>
                                </t>
                            </div>
                            <t t-if="subscription">
                                <div class="mza-acct-kv-grid">
                                    <t t-if="subscription.plan_id and subscription.plan_id.monthly_price">
                                        <div class="mza-acct-kv">
                                            <span class="mza-acct-kv-key">Billing</span>
                                            <span class="mza-acct-kv-val">
                                                <t t-esc="'%.2f' % subscription.plan_id.monthly_price"/> / month
                                            </span>
                                        </div>
                                    </t>
                                    <t t-if="subscription.plan_id and subscription.plan_id.max_users">
                                        <div class="mza-acct-kv">
                                            <span class="mza-acct-kv-key">User Limit</span>
                                            <span class="mza-acct-kv-val">
                                                <t t-esc="subscription.plan_id.max_users"/> users
                                            </span>
                                        </div>
                                    </t>
                                    <t t-if="subscription.renewal_date">
                                        <div class="mza-acct-kv">
                                            <span class="mza-acct-kv-key">Renewal</span>
                                            <span class="mza-acct-kv-val">
                                                <t t-esc="subscription.renewal_date" t-options='{"widget": "date"}'/>
                                            </span>
                                        </div>
                                    </t>
                                    <t t-if="subscription.status == 'trial' and subscription.trial_end_date">
                                        <div class="mza-acct-kv">
                                            <span class="mza-acct-kv-key">Trial Ends</span>
                                            <span class="mza-acct-kv-val mza-val-amber">
                                                <t t-esc="subscription.trial_end_date" t-options='{"widget": "date"}'/>
                                            </span>
                                        </div>
                                    </t>
                                </div>
                                <t t-if="subscription.status == 'trial'">
                                    <div class="mza-acct-cta mza-acct-cta-upgrade">
                                        <span>Upgrade to a paid plan before your trial ends.</span>
                                        <a href="mailto:sales@mumtaz.digital?subject=Upgrade%20Request"
                                           class="mza-btn mza-btn-primary mza-btn-sm">Contact Sales →</a>
                                    </div>
                                </t>
                                <t t-elif="subscription.status in ['past_due', 'grace']">
                                    <div class="mza-acct-cta mza-acct-cta-warning">
                                        <span>⚠ Payment issue — please contact support immediately.</span>
                                        <a href="mailto:support@mumtaz.digital?subject=Subscription%20Issue"
                                           class="mza-btn mza-btn-primary mza-btn-sm">Contact Support</a>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="mza-empty" style="padding:24px">
                                    <div class="mza-empty-title">No active subscription</div>
                                    <div class="mza-empty-sub">Contact us to set up your plan.</div>
                                    <a href="mailto:sales@mumtaz.digital?subject=Plan%20Setup"
                                       class="mza-btn mza-btn-primary mza-btn-sm" style="margin-top:12px">Contact Sales</a>
                                </div>
                            </t>
                        </div>

                        <!-- Features -->
                        <div class="mza-card">
                            <div class="mza-card-header" style="margin-bottom:14px">
                                <span class="mza-card-title" style="border:none;margin:0;padding:0;font-size:13.5px">Enabled Features</span>
                            </div>
                            <t t-if="active_features">
                                <div class="mza-feature-pills">
                                    <t t-foreach="active_features" t-as="feat">
                                        <div class="mza-feature-pill mza-feature-on">
                                            <span class="mza-feature-dot mza-dot-green"/>
                                            <t t-esc="feat.name"/>
                                        </div>
                                    </t>
                                </div>
                            </t>
                            <t t-if="locked_features">
                                <div class="mza-feature-section-label">Upgrade to Unlock</div>
                                <div class="mza-feature-pills">
                                    <t t-foreach="locked_features" t-as="feat">
                                        <div class="mza-feature-pill mza-feature-off">
                                            <span>🔒</span>
                                            <t t-esc="feat.name"/>
                                        </div>
                                    </t>
                                </div>
                            </t>
                            <t t-if="not active_features and not locked_features">
                                <div class="mza-empty" style="padding:24px">
                                    <div class="mza-empty-sub">No features configured for this plan.</div>
                                </div>
                            </t>
                        </div>

                    </div>
                </div>

                <!-- ═══════════════════════════ COMPANY PROFILE ══════════════════ -->
                <div class="mza-section mza-section-pad">
                    <div class="mza-section-head">
                        <h2 class="mza-section-title">Company Profile</h2>
                        <t t-if="tenant_profile">
                            <a t-att-href="'/web#id=' + str(tenant_profile.id) + '&amp;model=mumtaz.sme.profile&amp;view_type=form'"
                               class="mza-section-link">Edit →</a>
                        </t>
                    </div>
                    <div class="mza-cols-2">

                        <div class="mza-card">
                            <t t-if="tenant_profile">
                                <div class="mza-acct-company-header">
                                    <div class="mza-acct-company-logo">
                                        <t t-esc="(tenant_profile.trade_name or company.name or 'C')[0].upper()"/>
                                    </div>
                                    <div class="mza-acct-company-info">
                                        <div class="mza-acct-company-name">
                                            <t t-esc="tenant_profile.trade_name or tenant_profile.legal_name or company.name"/>
                                        </div>
                                        <t t-if="tenant_profile.industry">
                                            <div class="mza-acct-company-industry">
                                                <t t-esc="tenant_profile.industry"/>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                                <!-- Profile completeness bar -->
                                <t t-if="tenant_profile.profile_completeness">
                                    <div class="mza-acct-progress">
                                        <div class="mza-acct-progress-label">
                                            Profile Completeness
                                            <span class="mza-acct-progress-pct">
                                                <t t-esc="tenant_profile.profile_completeness or 0"/>%
                                            </span>
                                        </div>
                                        <div class="mza-acct-progress-bar">
                                            <div class="mza-acct-progress-fill"
                                                 t-att-style="'width:' + str(tenant_profile.profile_completeness or 0) + '%'"/>
                                        </div>
                                    </div>
                                </t>
                                <div class="mza-acct-kv-grid" style="margin-top:16px">
                                    <div class="mza-acct-kv">
                                        <span class="mza-acct-kv-key">Legal Name</span>
                                        <span class="mza-acct-kv-val">
                                            <t t-esc="tenant_profile.legal_name or '—'"/>
                                        </span>
                                    </div>
                                    <div class="mza-acct-kv">
                                        <span class="mza-acct-kv-key">Location</span>
                                        <span class="mza-acct-kv-val">
                                            <t t-esc="tenant_profile.city or '—'"/>
                                            <t t-if="tenant_profile.country_id"> · <t t-esc="tenant_profile.country_id.name"/></t>
                                        </span>
                                    </div>
                                    <div class="mza-acct-kv">
                                        <span class="mza-acct-kv-key">Contact</span>
                                        <span class="mza-acct-kv-val">
                                            <t t-esc="tenant_profile.contact_email or '—'"/>
                                        </span>
                                    </div>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="mza-empty" style="padding:32px">
                                    <div class="mza-empty-icon">🏢</div>
                                    <div class="mza-empty-title">Profile not set up</div>
                                    <div class="mza-empty-sub">Complete your SME profile to improve visibility.</div>
                                </div>
                            </t>
                        </div>

                        <!-- User account card -->
                        <div class="mza-card">
                            <div class="mza-acct-user-header">
                                <div class="mza-acct-user-avatar">
                                    <t t-esc="(user.name or 'U')[0].upper()"/>
                                </div>
                                <div class="mza-acct-user-info">
                                    <div class="mza-acct-user-name">
                                        <t t-esc="user.name"/>
                                    </div>
                                    <div class="mza-acct-user-email">
                                        <t t-esc="user.email or '—'"/>
                                    </div>
                                </div>
                            </div>
                            <div class="mza-acct-kv-grid" style="margin-top:16px">
                                <div class="mza-acct-kv">
                                    <span class="mza-acct-kv-key">Company</span>
                                    <span class="mza-acct-kv-val">
                                        <t t-esc="company.name"/>
                                    </span>
                                </div>
                                <div class="mza-acct-kv">
                                    <span class="mza-acct-kv-key">Portal</span>
                                    <span class="mza-acct-kv-val">
                                        <t t-esc="user.mumtaz_portal_type or 'Standard'"/>
                                    </span>
                                </div>
                            </div>
                            <div class="mza-acct-user-actions">
                                <a href="/web#action=base_setup.action_general_configuration"
                                   class="mza-btn mza-btn-ghost mza-btn-sm">Company Settings</a>
                                <a href="/web#action=base.action_res_users"
                                   class="mza-btn mza-btn-ghost mza-btn-sm">Manage Users</a>
                                <a href="/web/session/logout"
                                   class="mza-btn mza-btn-ghost mza-btn-sm mza-btn-logout">Sign Out ↩</a>
                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </t>
    </template>
</odoo>
