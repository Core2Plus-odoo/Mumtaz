<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend CRM opportunity form to add Proposals smart button -->
    <record id="view_crm_lead_proposal_button" model="ir.ui.view">
        <field name="name">crm.lead.form.mumtaz.proposal</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_proposals"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file-text-o"
                        invisible="proposal_count == 0">
                    <field name="proposal_count" widget="statinfo" string="Proposals"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
