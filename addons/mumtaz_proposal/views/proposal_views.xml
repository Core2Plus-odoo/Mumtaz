<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Actions ──────────────────────────────────────────────────────────── -->

    <record id="action_mumtaz_proposal" model="ir.actions.act_window">
        <field name="name">Proposals</field>
        <field name="res_model">mumtaz.proposal</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first proposal
            </p>
            <p>
                Send professional proposals to your customers directly from CRM opportunities.
            </p>
        </field>
    </record>

    <!-- ── Form View ────────────────────────────────────────────────────────── -->

    <record id="view_mumtaz_proposal_form" model="ir.ui.view">
        <field name="name">mumtaz.proposal.form</field>
        <field name="model">mumtaz.proposal</field>
        <field name="arch" type="xml">
            <form string="Proposal">
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_send" string="Send by Email" type="object"
                            class="btn-primary"
                            invisible="state not in ('confirmed',)"/>
                    <button name="action_mark_sent" string="Mark as Sent" type="object"
                            invisible="state not in ('confirmed',)"/>
                    <button name="action_accept" string="Accept" type="object"
                            class="btn-success"
                            invisible="state not in ('sent', 'viewed')"/>
                    <button name="action_reject" string="Reject" type="object"
                            invisible="state not in ('sent', 'viewed')"/>
                    <button name="action_new_revision" string="New Revision" type="object"
                            invisible="state not in ('sent', 'viewed', 'rejected', 'expired')"/>
                    <button name="action_create_sale_order" string="Create Sale Order" type="object"
                            class="btn-secondary"
                            invisible="state != 'accepted'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('cancelled', 'accepted')"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,sent,viewed,accepted"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sale_orders" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart"
                                invisible="sale_order_count == 0">
                            <field name="sale_order_count" widget="statinfo" string="Sale Orders"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name" string="Proposal Reference"/>
                        <h1>
                            <field name="name" readonly="True"/>
                        </h1>
                        <div class="o_field_badge" invisible="revision == 0">
                            <span class="badge text-bg-info">
                                Revision <field name="revision" readonly="True"/>
                            </span>
                        </div>
                    </div>

                    <group>
                        <group string="Proposal Details">
                            <field name="opportunity_id"/>
                            <field name="partner_id" required="1"/>
                            <field name="template_id"/>
                            <button name="action_apply_template" string="Apply Template"
                                    type="object" class="btn-sm btn-secondary"
                                    invisible="not template_id"/>
                        </group>
                        <group string="Sales">
                            <field name="user_id"/>
                            <field name="team_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <group>
                        <group string="Dates">
                            <field name="date_proposal"/>
                            <field name="date_valid"/>
                            <field name="date_sent" invisible="not date_sent"/>
                            <field name="date_accepted" invisible="not date_accepted"/>
                        </group>
                        <group string="Amounts">
                            <field name="amount_untaxed" widget="monetary"/>
                            <field name="amount_tax" widget="monetary"/>
                            <field name="amount_total" widget="monetary"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Proposal Lines" name="lines">
                            <field name="line_ids" widget="one2many_list"
                                   context="{'default_proposal_id': id}">
                                <list string="Proposal Lines" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="product_uom_id"/>
                                    <field name="price_unit" widget="monetary"/>
                                    <field name="discount"/>
                                    <field name="tax_ids" widget="many2many_tags"/>
                                    <field name="price_subtotal" widget="monetary"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </list>
                            </field>

                            <!-- Totals section -->
                            <div class="o_field_widget o_field_one2many">
                                <div class="oe_subtotal_footer oe_right mt-3">
                                    <table class="table table-sm w-auto ms-auto">
                                        <tr>
                                            <td class="text-end pe-3 text-muted">Subtotal:</td>
                                            <td class="text-end">
                                                <field name="amount_untaxed" widget="monetary" readonly="1"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="text-end pe-3 text-muted">Taxes:</td>
                                            <td class="text-end">
                                                <field name="amount_tax" widget="monetary" readonly="1"/>
                                            </td>
                                        </tr>
                                        <tr class="fw-bold border-top">
                                            <td class="text-end pe-3">
                                                <strong>Total:</strong>
                                            </td>
                                            <td class="text-end">
                                                <field name="amount_total" widget="monetary" readonly="1"/>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </page>

                        <page string="Terms &amp; Conditions" name="terms">
                            <field name="terms_conditions" widget="html" placeholder="Enter terms and conditions..."/>
                        </page>

                        <page string="Internal Notes" name="notes">
                            <field name="internal_notes" placeholder="Internal notes (not visible to customer)..."/>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── List View ────────────────────────────────────────────────────────── -->

    <record id="view_mumtaz_proposal_list" model="ir.ui.view">
        <field name="name">mumtaz.proposal.list</field>
        <field name="model">mumtaz.proposal</field>
        <field name="arch" type="xml">
            <list string="Proposals" decoration-success="state == 'accepted'"
                  decoration-danger="state in ('rejected', 'expired', 'cancelled')"
                  decoration-info="state in ('sent', 'viewed')"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="opportunity_id"/>
                <field name="amount_total" widget="monetary" sum="Total"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'accepted'"
                       decoration-danger="state in ('rejected', 'expired', 'cancelled')"
                       decoration-info="state in ('sent', 'viewed')"
                       decoration-warning="state == 'confirmed'"
                       decoration-muted="state == 'draft'"/>
                <field name="date_valid"/>
                <field name="user_id" widget="many2one_avatar_user"/>
            </list>
        </field>
    </record>

    <!-- ── Kanban View ──────────────────────────────────────────────────────── -->

    <record id="view_mumtaz_proposal_kanban" model="ir.ui.view">
        <field name="name">mumtaz.proposal.kanban</field>
        <field name="model">mumtaz.proposal</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column"
                    records_draggable="False">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="amount_total"/>
                <field name="currency_id"/>
                <field name="date_valid"/>
                <field name="state"/>
                <field name="user_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div class="o_kanban_manage_button_section">
                                    <field name="state" widget="label_selection"
                                           options="{'classes': {'draft': 'default', 'confirmed': 'warning', 'sent': 'info', 'viewed': 'info', 'accepted': 'success', 'rejected': 'danger', 'expired': 'danger', 'cancelled': 'danger'}}"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <i class="fa fa-user me-1"/>
                                    <field name="partner_id"/>
                                </div>
                                <div t-if="record.date_valid.raw_value">
                                    <i class="fa fa-calendar me-1"/>
                                    Valid until: <field name="date_valid"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <strong>
                                        <field name="amount_total" widget="monetary"/>
                                    </strong>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ── Search View ──────────────────────────────────────────────────────── -->

    <record id="view_mumtaz_proposal_search" model="ir.ui.view">
        <field name="name">mumtaz.proposal.search</field>
        <field name="model">mumtaz.proposal</field>
        <field name="arch" type="xml">
            <search string="Search Proposals">
                <field name="name" string="Reference"/>
                <field name="partner_id"/>
                <field name="opportunity_id"/>
                <field name="user_id"/>
                <filter string="My Proposals" name="my_proposals"
                        domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="state_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="state_confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="Sent" name="state_sent" domain="[('state', '=', 'sent')]"/>
                <filter string="Accepted" name="state_accepted" domain="[('state', '=', 'accepted')]"/>
                <filter string="Rejected" name="state_rejected" domain="[('state', '=', 'rejected')]"/>
                <filter string="Expired" name="state_expired" domain="[('state', '=', 'expired')]"/>
                <separator/>
                <filter string="Expiring Soon" name="expiring_soon"
                        domain="[('date_valid', '&lt;=', (context_today() + relativedelta(days=7)).strftime('%Y-%m-%d')), ('state', 'in', ['confirmed', 'sent', 'viewed'])]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Salesperson" name="group_by_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Customer" name="group_by_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Proposal Date" name="group_by_date" context="{'group_by': 'date_proposal:month'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
