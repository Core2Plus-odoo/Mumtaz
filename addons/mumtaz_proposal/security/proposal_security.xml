<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Groups ─────────────────────────────────────────────────────────── -->

    <record id="group_proposal_viewer" model="res.groups">
        <field name="name">Proposal Viewer</field>
        <field name="category_id" ref="base.module_category_sales_crm"/>
    </record>

    <record id="group_proposal_user" model="res.groups">
        <field name="name">Proposal User</field>
        <field name="category_id" ref="base.module_category_sales_crm"/>
        <field name="implied_ids" eval="[(4, ref('mumtaz_proposal.group_proposal_viewer'))]"/>
    </record>

    <record id="group_proposal_manager" model="res.groups">
        <field name="name">Proposal Manager</field>
        <field name="category_id" ref="base.module_category_sales_crm"/>
        <field name="implied_ids" eval="[(4, ref('mumtaz_proposal.group_proposal_user'))]"/>
    </record>

    <!-- ── Record Rules ───────────────────────────────────────────────────── -->

    <!-- Proposal User: can only see own or team proposals -->
    <record id="rule_proposal_user_own" model="ir.rule">
        <field name="name">Proposals: Users see own proposals</field>
        <field name="model_id" ref="model_mumtaz_proposal"/>
        <field name="groups" eval="[(4, ref('mumtaz_proposal.group_proposal_user'))]"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Proposal Manager: sees all proposals -->
    <record id="rule_proposal_manager_all" model="ir.rule">
        <field name="name">Proposals: Managers see all proposals</field>
        <field name="model_id" ref="model_mumtaz_proposal"/>
        <field name="groups" eval="[(4, ref('mumtaz_proposal.group_proposal_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
