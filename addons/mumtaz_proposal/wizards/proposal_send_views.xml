<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Send Proposal Wizard Form ────────────────────────────────────────── -->

    <record id="view_mumtaz_proposal_send_form" model="ir.ui.view">
        <field name="name">mumtaz.proposal.send.form</field>
        <field name="model">mumtaz.proposal.send</field>
        <field name="arch" type="xml">
            <form string="Send Proposal">
                <group>
                    <field name="proposal_id" readonly="1"/>
                    <field name="partner_ids" widget="many2many_tags"
                           placeholder="Select recipients..."/>
                    <field name="subject"/>
                </group>
                <group string="Message">
                    <field name="body_html" widget="html" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_send_email" string="Send" type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
