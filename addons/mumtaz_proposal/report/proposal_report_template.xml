<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_proposal_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="proposal">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- ── Proposal Header ────────────────────────────── -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <h1 class="text-uppercase" style="font-size: 2.5rem; color: #2c3e50; letter-spacing: 2px;">PROPOSAL</h1>
                            </div>
                            <div class="col-6 text-end">
                                <table class="table table-sm table-borderless w-auto ms-auto">
                                    <tr>
                                        <td class="text-muted pe-2">Reference:</td>
                                        <td><strong><t t-esc="proposal.name"/></strong></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted pe-2">Date:</td>
                                        <td><t t-esc="proposal.date_proposal" t-options='{"widget": "date"}'/></td>
                                    </tr>
                                    <tr t-if="proposal.date_valid">
                                        <td class="text-muted pe-2">Valid Until:</td>
                                        <td><t t-esc="proposal.date_valid" t-options='{"widget": "date"}'/></td>
                                    </tr>
                                    <tr t-if="proposal.revision">
                                        <td class="text-muted pe-2">Revision:</td>
                                        <td><t t-esc="proposal.revision"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <hr style="border-top: 3px solid #2c3e50;"/>

                        <!-- ── Customer Info ──────────────────────────────── -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <h5 class="text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 1px;">Prepared For</h5>
                                <address>
                                    <strong><t t-esc="proposal.partner_id.name"/></strong><br/>
                                    <t t-if="proposal.partner_id.street">
                                        <t t-esc="proposal.partner_id.street"/><br/>
                                    </t>
                                    <t t-if="proposal.partner_id.street2">
                                        <t t-esc="proposal.partner_id.street2"/><br/>
                                    </t>
                                    <t t-if="proposal.partner_id.city or proposal.partner_id.zip">
                                        <t t-esc="proposal.partner_id.zip"/>&#160;<t t-esc="proposal.partner_id.city"/><br/>
                                    </t>
                                    <t t-if="proposal.partner_id.country_id">
                                        <t t-esc="proposal.partner_id.country_id.name"/><br/>
                                    </t>
                                    <t t-if="proposal.partner_id.email">
                                        <t t-esc="proposal.partner_id.email"/>
                                    </t>
                                </address>
                            </div>
                            <div class="col-6">
                                <h5 class="text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 1px;">Prepared By</h5>
                                <address>
                                    <strong><t t-esc="proposal.user_id.name"/></strong><br/>
                                    <t t-if="proposal.user_id.email">
                                        <t t-esc="proposal.user_id.email"/><br/>
                                    </t>
                                    <t t-if="proposal.user_id.phone">
                                        <t t-esc="proposal.user_id.phone"/>
                                    </t>
                                </address>
                            </div>
                        </div>

                        <t t-if="proposal.opportunity_id">
                            <div class="row mb-3">
                                <div class="col-12">
                                    <span class="text-muted">Opportunity: </span>
                                    <strong><t t-esc="proposal.opportunity_id.name"/></strong>
                                </div>
                            </div>
                        </t>

                        <!-- ── Lines Table ────────────────────────────────── -->
                        <table class="table table-sm o_main_table mt-4">
                            <thead>
                                <tr style="background-color: #2c3e50; color: white;">
                                    <th style="width: 40%;">Description</th>
                                    <th class="text-end" style="width: 8%;">Qty</th>
                                    <th class="text-end" style="width: 12%;">Unit Price</th>
                                    <th class="text-end" style="width: 8%;">Disc.%</th>
                                    <th style="width: 12%;">Taxes</th>
                                    <th class="text-end" style="width: 12%;">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="proposal.line_ids" t-as="line">
                                    <tr>
                                        <td>
                                            <strong t-if="line.product_id"><t t-esc="line.product_id.name"/><br/></strong>
                                            <span style="white-space: pre-wrap;"><t t-esc="line.name"/></span>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="line.quantity" t-options='{"widget": "float", "precision": 2}'/>
                                            <t t-if="line.product_uom_id">&#160;<t t-esc="line.product_uom_id.name"/></t>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="line.price_unit" t-options='{"widget": "monetary", "display_currency": proposal.currency_id}'/>
                                        </td>
                                        <td class="text-end">
                                            <t t-if="line.discount">
                                                <t t-esc="line.discount" t-options='{"widget": "float", "precision": 2}'/>%
                                            </t>
                                            <t t-else="">-</t>
                                        </td>
                                        <td>
                                            <t t-esc="', '.join(line.tax_ids.mapped('name'))"/>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": proposal.currency_id}'/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ── Totals ─────────────────────────────────────── -->
                        <div class="row">
                            <div class="col-6 offset-6">
                                <table class="table table-sm">
                                    <tr>
                                        <td class="text-end text-muted">Subtotal:</td>
                                        <td class="text-end" style="min-width: 120px;">
                                            <t t-esc="proposal.amount_untaxed" t-options='{"widget": "monetary", "display_currency": proposal.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="text-end text-muted">VAT / Taxes:</td>
                                        <td class="text-end">
                                            <t t-esc="proposal.amount_tax" t-options='{"widget": "monetary", "display_currency": proposal.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr style="border-top: 2px solid #2c3e50;">
                                        <td class="text-end"><strong>Total:</strong></td>
                                        <td class="text-end">
                                            <strong style="font-size: 1.1rem;">
                                                <t t-esc="proposal.amount_total" t-options='{"widget": "monetary", "display_currency": proposal.currency_id}'/>
                                            </strong>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- ── Terms &amp; Conditions ─────────────────────── -->
                        <t t-if="proposal.terms_conditions">
                            <div class="mt-4 pt-3" style="border-top: 1px solid #dee2e6;">
                                <h5 class="text-uppercase text-muted mb-2" style="font-size: 0.8rem; letter-spacing: 1px;">Terms &amp; Conditions</h5>
                                <div>
                                    <t t-out="proposal.terms_conditions"/>
                                </div>
                            </div>
                        </t>

                        <!-- ── Signature ──────────────────────────────────── -->
                        <div class="row mt-5 pt-4">
                            <div class="col-5">
                                <div style="border-top: 1px solid #333; padding-top: 8px;">
                                    <small class="text-muted">Customer Signature &amp; Date</small>
                                </div>
                            </div>
                            <div class="col-2"></div>
                            <div class="col-5">
                                <div style="border-top: 1px solid #333; padding-top: 8px;">
                                    <small class="text-muted">Authorized Signature &amp; Date</small>
                                </div>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
