<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mumtaz_marketplace_category_list" model="ir.ui.view">
        <field name="name">mumtaz.marketplace.category.list</field>
        <field name="model">mumtaz.marketplace.category</field>
        <field name="arch" type="xml">
            <list string="Categories" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="icon"/>
                <field name="listing_count" string="Published Listings"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_mumtaz_marketplace_categories" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">mumtaz.marketplace.category</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
