<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Sale Order: Market Demand smart button ── -->
    <record id="view_sale_order_marketplace_demand" model="ir.ui.view">
        <field name="name">sale.order.marketplace.demand</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_market_demand"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-signal">
                    <field name="marketplace_demand_count" widget="statinfo"
                           string="Market Demand"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
