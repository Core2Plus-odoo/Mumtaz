<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_mumtaz_async_job_cleanup" model="ir.cron">
            <field name="name">Mumtaz API - Cleanup Async Jobs</field>
            <field name="model_id" ref="model_mumtaz_async_job"/>
            <field name="state">code</field>
            <field name="code">model.search([('state', 'in', ['done', 'failed'])], limit=200).unlink()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
