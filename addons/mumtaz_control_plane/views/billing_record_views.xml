<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_mumtaz_billing_record_tree" model="ir.ui.view">
            <field name="name">mumtaz.subscription.billing.record.tree</field>
            <field name="model">mumtaz.subscription.billing.record</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="record_type"/>
                    <field name="tenant_id"/>
                    <field name="subscription_id"/>
                    <field name="amount_due"/>
                    <field name="currency_id"/>
                    <field name="due_date"/>
                    <field name="payment_status" widget="badge"/>
                    <field name="paid_date"/>
                </tree>
            </field>
        </record>

        <record id="view_mumtaz_billing_record_form" model="ir.ui.view">
            <field name="name">mumtaz.subscription.billing.record.form</field>
            <field name="model">mumtaz.subscription.billing.record</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_mark_under_review" type="object" string="Under Review" class="btn-secondary"/>
                        <button name="action_mark_invoiced" type="object" string="Mark Invoiced" class="btn-secondary"/>
                        <button name="action_mark_paid" type="object" string="Mark Paid" class="btn-primary"/>
                        <button name="action_mark_waived" type="object" string="Waive" class="btn-secondary"/>
                        <field name="payment_status" widget="statusbar" statusbar_visible="draft,under_review,invoiced,paid,waived,cancelled"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="record_type"/>
                                <field name="operation_id"/>
                                <field name="subscription_id"/>
                                <field name="tenant_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="amount_due"/>
                                <field name="currency_id"/>
                                <field name="issued_date"/>
                                <field name="due_date"/>
                                <field name="paid_date" readonly="1"/>
                                <field name="external_reference"/>
                            </group>
                        </group>
                        <group>
                            <field name="commercial_notes"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_mumtaz_billing_records" model="ir.actions.act_window">
            <field name="name">Billing Records</field>
            <field name="res_model">mumtaz.subscription.billing.record</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
