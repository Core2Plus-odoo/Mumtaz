<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_mumtaz_tenant_feature_tree" model="ir.ui.view">
            <field name="name">mumtaz.tenant.feature.tree</field>
            <field name="model">mumtaz.tenant.feature</field>
            <field name="arch" type="xml">
                <list>
                    <field name="tenant_id"/>
                    <field name="feature_id"/>
                    <field name="override_mode"/>
                    <field name="override_quota_limit"/>
                    <field name="effective_from"/>
                    <field name="effective_to"/>
                    <field name="granted_by"/>
                </list>
            </field>
        </record>

        <record id="view_mumtaz_tenant_feature_search" model="ir.ui.view">
            <field name="name">mumtaz.tenant.feature.search</field>
            <field name="model">mumtaz.tenant.feature</field>
            <field name="arch" type="xml">
                <search string="Feature Overrides">
                    <field name="tenant_id"/>
                    <field name="feature_id"/>
                    <field name="override_mode"/>
                    <filter string="Tenant" name="group_by_tenant" context="{'group_by': 'tenant_id'}"/>
                    <filter string="Mode" name="group_by_mode" context="{'group_by': 'override_mode'}"/>
                </search>
            </field>
        </record>

        <record id="view_mumtaz_tenant_feature_form" model="ir.ui.view">
            <field name="name">mumtaz.tenant.feature.form</field>
            <field name="model">mumtaz.tenant.feature</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="tenant_id"/>
                                <field name="feature_id"/>
                                <field name="override_mode"/>
                                <field name="override_quota_limit"/>
                            </group>
                            <group>
                                <field name="effective_from"/>
                                <field name="effective_to"/>
                                <field name="granted_by"/>
                            </group>
                        </group>
                        <group>
                            <field name="reason"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_mumtaz_tenant_feature" model="ir.actions.act_window">
            <field name="name">Feature Overrides</field>
            <field name="res_model">mumtaz.tenant.feature</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_mumtaz_tenant_feature_search"/>
        </record>
    </data>
</odoo>
