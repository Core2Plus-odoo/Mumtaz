<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_mumtaz_plan_tree" model="ir.ui.view">
            <field name="name">mumtaz.plan.tree</field>
            <field name="model">mumtaz.plan</field>
            <field name="arch" type="xml">
                <list>
                    <field name="sequence"/>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="billing_cycle_default"/>
                    <field name="list_price"/>
                    <field name="currency_id" optional="hide"/>
                    <field name="grace_days_default"/>
                    <field name="legacy_bundle_id"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_mumtaz_plan_search" model="ir.ui.view">
            <field name="name">mumtaz.plan.search</field>
            <field name="model">mumtaz.plan</field>
            <field name="arch" type="xml">
                <search string="Plans">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="billing_cycle_default"/>
                    <field name="legacy_bundle_id"/>
                    <filter name="active_only" string="Active" domain="[('active','=',True)]"/>
                    <filter string="Cycle" name="group_by_cycle" context="{'group_by': 'billing_cycle_default'}"/>
                </search>
            </field>
        </record>

        <record id="view_mumtaz_plan_form" model="ir.ui.view">
            <field name="name">mumtaz.plan.form</field>
            <field name="model">mumtaz.plan</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="active"/>
                                <field name="sequence"/>
                            </group>
                            <group>
                                <field name="billing_cycle_default"/>
                                <field name="list_price"/>
                                <field name="currency_id"/>
                                <field name="grace_days_default"/>
                            </group>
                        </group>
                        <group>
                            <field name="legacy_bundle_id"/>
                            <field name="notes"/>
                        </group>
                        <notebook>
                            <page string="Plan Features">
                                <field name="plan_feature_ids">
                                    <list editable="bottom">
                                        <field name="feature_id"/>
                                        <field name="enabled"/>
                                        <field name="quota_limit"/>
                                        <field name="limit_period"/>
                                        <field name="source" readonly="1"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_mumtaz_plan" model="ir.actions.act_window">
            <field name="name">Plans</field>
            <field name="res_model">mumtaz.plan</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_mumtaz_plan_search"/>
        </record>
    </data>
</odoo>
