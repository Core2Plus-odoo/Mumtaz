<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="portal_vendor_po_detail" name="Vendor Purchase Order Detail">
    <t t-call="mumtaz_vendor_portal.portal_vendor_layout">
        <t t-set="title" t-value="'PO ' + order.name"/>

        <div class="mvp-card">
            <div class="mvp-card-header">
                <a href="/vendor/purchase-orders" class="mvp-back-link">
                    &#8592; All Purchase Orders
                </a>
                <h3 class="mvp-card-title">
                    <t t-esc="order.name"/>
                </h3>
                <span t-attf-class="mvp-status mvp-status-#{order.state}">
                    <t t-esc="dict(order._fields['state'].selection)[order.state]"/>
                </span>
            </div>

            <!-- ── Header info grid ── -->
            <div class="mvp-detail-grid">
                <div class="mvp-detail-block">
                    <div class="mvp-detail-label">Buyer</div>
                    <div class="mvp-detail-value">
                        <t t-esc="order.company_id.name"/>
                    </div>
                </div>
                <div class="mvp-detail-block">
                    <div class="mvp-detail-label">Order Date</div>
                    <div class="mvp-detail-value">
                        <t t-esc="order.date_order.strftime('%d %b %Y') if order.date_order else '—'"/>
                    </div>
                </div>
                <div class="mvp-detail-block">
                    <div class="mvp-detail-label">Expected Delivery</div>
                    <div class="mvp-detail-value">
                        <t t-esc="order.date_planned.strftime('%d %b %Y') if order.date_planned else '—'"/>
                    </div>
                </div>
                <div class="mvp-detail-block">
                    <div class="mvp-detail-label">Reference</div>
                    <div class="mvp-detail-value">
                        <t t-esc="order.partner_ref or '—'"/>
                    </div>
                </div>
            </div>

            <!-- ── Order lines ── -->
            <div class="mvp-table-wrap" style="margin-top:24px;">
                <table class="mvp-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Product</th>
                            <th>Description</th>
                            <th class="mvp-col-amount">Qty</th>
                            <th class="mvp-col-amount">UoM</th>
                            <th class="mvp-col-amount">Unit Price</th>
                            <th class="mvp-col-amount">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="order.order_line" t-as="line">
                            <tr>
                                <td><t t-esc="line_index + 1"/></td>
                                <td>
                                    <strong t-esc="line.product_id.display_name"/>
                                </td>
                                <td t-esc="line.name"/>
                                <td class="mvp-col-amount" t-esc="'%.2f' % line.product_qty"/>
                                <td class="mvp-col-amount" t-esc="line.product_uom.name"/>
                                <td class="mvp-col-amount"
                                    t-esc="'%s %.2f' % (order.currency_id.symbol or order.currency_id.name, line.price_unit)"/>
                                <td class="mvp-col-amount"
                                    t-esc="'%s %.2f' % (order.currency_id.symbol or order.currency_id.name, line.price_subtotal)"/>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="6" class="mvp-col-amount mvp-totals-label">Untaxed Total</td>
                            <td class="mvp-col-amount mvp-totals-value"
                                t-esc="'%s %.2f' % (order.currency_id.symbol or order.currency_id.name, order.amount_untaxed)"/>
                        </tr>
                        <tr>
                            <td colspan="6" class="mvp-col-amount mvp-totals-label">Tax</td>
                            <td class="mvp-col-amount mvp-totals-value"
                                t-esc="'%s %.2f' % (order.currency_id.symbol or order.currency_id.name, order.amount_tax)"/>
                        </tr>
                        <tr>
                            <td colspan="6" class="mvp-col-amount mvp-totals-grand-label">Total</td>
                            <td class="mvp-col-amount mvp-totals-grand-value"
                                t-esc="'%s %.2f' % (order.currency_id.symbol or order.currency_id.name, order.amount_total)"/>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <!-- ── Acknowledge action ── -->
            <div class="mvp-actions" style="margin-top:24px;">
                <t t-if="order.state in ('purchase','done')">
                    <form t-attf-action="/vendor/purchase-orders/#{order.id}/acknowledge"
                          method="post" class="mvp-acknowledge-form">
                        <input type="hidden" name="csrf_token"
                               t-att-value="request.csrf_token()"/>
                        <button type="submit" class="mvp-btn-primary">
                            <i class="fa fa-check"/> Acknowledge Order
                        </button>
                    </form>
                </t>
                <a t-attf-href="/my/purchase/#{order.id}?report_type=pdf&amp;download=1"
                   class="mvp-btn-secondary">
                    <i class="fa fa-download"/> Download PDF
                </a>
            </div>
        </div>

    </t>
</template>

</odoo>
