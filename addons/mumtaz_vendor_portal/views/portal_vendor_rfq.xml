<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="portal_vendor_rfq" name="Vendor RFQs">
    <t t-call="mumtaz_vendor_portal.portal_vendor_layout">
        <t t-set="title">Requests for Quotation</t>

        <div class="mvp-card">
            <div class="mvp-card-header">
                <h3 class="mvp-card-title">Open RFQs</h3>
                <span class="mvp-card-count">
                    <t t-esc="pager['count']"/> requests
                </span>
            </div>

            <div class="mvp-table-wrap">
                <table class="mvp-table">
                    <thead>
                        <tr>
                            <th>Reference</th>
                            <th>Date</th>
                            <th>Deadline</th>
                            <th class="mvp-col-amount">Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="rfqs" t-as="rfq">
                            <tr class="mvp-tr-hover">
                                <td>
                                    <strong class="mvp-ref">
                                        <t t-esc="rfq.name"/>
                                    </strong>
                                </td>
                                <td class="mvp-col-date">
                                    <t t-esc="rfq.date_order" t-options="{'widget': 'date'}"/>
                                </td>
                                <td class="mvp-col-date">
                                    <t t-if="rfq.date_approve">
                                        <t t-esc="rfq.date_approve" t-options="{'widget': 'date'}"/>
                                    </t>
                                    <t t-else="">
                                        <span class="mvp-muted">—</span>
                                    </t>
                                </td>
                                <td class="mvp-col-amount mvp-amount-strong">
                                    <t t-esc="'{:,.2f} {}'.format(rfq.amount_total, rfq.currency_id.name)"/>
                                </td>
                                <td>
                                    <t t-if="rfq.state == 'sent'">
                                        <span class="mvp-badge mvp-badge-teal">SENT</span>
                                    </t>
                                    <t t-else="">
                                        <span class="mvp-badge mvp-badge-gold">DRAFT</span>
                                    </t>
                                </td>
                            </tr>
                        </t>
                        <t t-if="not rfqs">
                            <tr>
                                <td colspan="5" class="mvp-empty">No open RFQs at this time.</td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>

            <!-- Pager -->
            <t t-if="pager['page_count'] > 1">
                <div class="mvp-pager">
                    <t t-if="pager['page']['num'] > 1">
                        <a t-att-href="pager['page_previous']['url']" class="mvp-pager-btn">&#8592; Previous</a>
                    </t>
                    <span class="mvp-pager-info">
                        Page <t t-esc="pager['page']['num']"/> of <t t-esc="pager['page_count']"/>
                    </span>
                    <t t-if="pager['page']['num'] &lt; pager['page_count']">
                        <a t-att-href="pager['page_next']['url']" class="mvp-pager-btn">Next &#8594;</a>
                    </t>
                </div>
            </t>
        </div>

    </t>
</template>

</odoo>
