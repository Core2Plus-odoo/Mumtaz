<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="portal_vendor_rfq_detail" name="Vendor RFQ Detail">
    <t t-call="mumtaz_vendor_portal.portal_vendor_layout">
        <t t-set="title">RFQ <t t-esc="rfq.name"/></t>

        <div class="mvp-card">
            <div class="mvp-card-header">
                <a href="/vendor/rfq" class="mvp-back-link">&#8592; All RFQs</a>
                <h3 class="mvp-card-title">
                    Request for Quotation — <t t-esc="rfq.name"/>
                </h3>
                <t t-if="rfq.state == 'sent'">
                    <span class="mvp-badge mvp-badge-teal">SENT</span>
                </t>
                <t t-else="">
                    <span class="mvp-badge mvp-badge-gold">DRAFT</span>
                </t>
            </div>

            <!-- Status messages -->
            <t t-if="error">
                <div class="mvp-alert mvp-alert-error">
                    <i class="fa fa-exclamation-triangle"/>
                    <span t-esc="error"/>
                </div>
            </t>
            <t t-if="success">
                <div class="mvp-alert mvp-alert-success">
                    <i class="fa fa-check-circle"/>
                    <span t-esc="success"/>
                </div>
            </t>

            <!-- RFQ meta grid -->
            <div class="mvp-detail-grid" style="margin: 16px 0;">
                <div class="mvp-detail-block">
                    <span class="mvp-detail-label">Buyer Company</span>
                    <span class="mvp-detail-value">
                        <t t-esc="rfq.company_id.name"/>
                    </span>
                </div>
                <div class="mvp-detail-block">
                    <span class="mvp-detail-label">Order Date</span>
                    <span class="mvp-detail-value">
                        <t t-if="rfq.date_order">
                            <t t-esc="rfq.date_order" t-options="{'widget': 'date'}"/>
                        </t>
                        <t t-else=""><span class="mvp-muted">—</span></t>
                    </span>
                </div>
                <div class="mvp-detail-block">
                    <span class="mvp-detail-label">Response Deadline</span>
                    <span class="mvp-detail-value">
                        <t t-if="rfq.date_approve">
                            <t t-esc="rfq.date_approve" t-options="{'widget': 'date'}"/>
                        </t>
                        <t t-else=""><span class="mvp-muted">—</span></t>
                    </span>
                </div>
                <div class="mvp-detail-block">
                    <span class="mvp-detail-label">Currency</span>
                    <span class="mvp-detail-value">
                        <t t-esc="rfq.currency_id.name"/>
                    </span>
                </div>
            </div>

            <!-- RFQ lines table — read only -->
            <div class="mvp-table-wrap" style="margin-bottom: 24px;">
                <table class="mvp-table">
                    <thead>
                        <tr>
                            <th>Product / Description</th>
                            <th class="mvp-col-amount">Qty</th>
                            <th class="mvp-col-amount">Unit (UoM)</th>
                            <th class="mvp-col-amount">Requested Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="rfq.order_line" t-as="line">
                            <tr>
                                <td>
                                    <strong><t t-esc="line.name"/></strong>
                                    <t t-if="line.product_id.default_code">
                                        <br/>
                                        <small class="mvp-muted">
                                            <t t-esc="line.product_id.default_code"/>
                                        </small>
                                    </t>
                                </td>
                                <td class="mvp-col-amount">
                                    <t t-esc="'%.2f' % line.product_qty"/>
                                </td>
                                <td class="mvp-col-amount">
                                    <t t-esc="line.product_uom.name"/>
                                </td>
                                <td class="mvp-col-amount mvp-amount-strong">
                                    <t t-if="line.price_unit">
                                        <t t-esc="'{:,.2f}'.format(line.price_unit)"/>
                                    </t>
                                    <t t-else="">
                                        <span class="mvp-muted">Not set</span>
                                    </t>
                                </td>
                            </tr>
                        </t>
                        <t t-if="not rfq.order_line">
                            <tr>
                                <td colspan="4" class="mvp-empty">No lines on this RFQ.</td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>

            <!-- Quote response form -->
            <t t-if="not success">
                <div style="border-top: 2px solid #E2E8F0; padding-top: 20px;">
                    <h4 style="font-size: .95rem; font-weight: 700; margin-bottom: 16px; color: #0F172A;">
                        Submit Your Quote
                    </h4>

                    <form t-att-action="'/vendor/rfq/%d/respond' % rfq.id"
                          method="post"
                          class="mvp-form">
                        <input type="hidden" name="csrf_token"
                               t-att-value="request.csrf_token()"/>

                        <!-- Per-line price inputs -->
                        <t t-if="rfq.order_line">
                            <div class="mvp-form-row">
                                <label class="mvp-form-label">Quoted Unit Prices</label>
                                <small class="mvp-form-hint">
                                    Leave blank to keep the buyer's price or to quote line-by-line selectively.
                                </small>
                            </div>

                            <div class="mvp-rfq-lines-grid">
                                <t t-foreach="rfq.order_line" t-as="line">
                                    <div class="mvp-rfq-line-row">
                                        <div class="mvp-rfq-line-desc">
                                            <strong><t t-esc="line.name"/></strong>
                                            <small class="mvp-muted">
                                                <t t-esc="'%.2f %s' % (line.product_qty, line.product_uom.name)"/>
                                            </small>
                                        </div>
                                        <div class="mvp-rfq-line-price">
                                            <input type="number"
                                                   t-att-name="'price_%d' % line.id"
                                                   class="mvp-form-input mvp-rfq-price-input"
                                                   step="0.01" min="0"
                                                   t-att-placeholder="'{:,.2f}'.format(line.price_unit) if line.price_unit else '0.00'"
                                                   autocomplete="off"/>
                                            <span class="mvp-rfq-currency">
                                                <t t-esc="rfq.currency_id.name"/>
                                            </span>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </t>

                        <!-- Extra metadata -->
                        <div class="mvp-form-row-half" style="display:flex;gap:16px;margin-top:8px;">
                            <div style="flex:1;">
                                <label for="valid_until" class="mvp-form-label">Quote Valid Until</label>
                                <input type="date" id="valid_until" name="valid_until"
                                       class="mvp-form-input"/>
                            </div>
                            <div style="flex:1;">
                                <label for="delivery_days" class="mvp-form-label">
                                    Lead Time (days)
                                </label>
                                <input type="number" id="delivery_days" name="delivery_days"
                                       class="mvp-form-input" min="0" step="1"
                                       placeholder="e.g. 14"/>
                            </div>
                        </div>

                        <div class="mvp-form-row">
                            <label for="notes" class="mvp-form-label">Additional Notes</label>
                            <textarea id="notes" name="notes"
                                      class="mvp-form-input"
                                      rows="3"
                                      placeholder="Any conditions, substitutions, or remarks…"/>
                        </div>

                        <div class="mvp-actions" style="margin-top: 8px;">
                            <button type="submit" class="mvp-btn-primary">
                                <i class="fa fa-paper-plane"/> Submit Quote
                            </button>
                            <a href="/vendor/rfq" class="mvp-btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </t>

            <!-- After successful submission: just show a Done button -->
            <t t-if="success">
                <div class="mvp-actions" style="margin-top: 16px;">
                    <a href="/vendor/rfq" class="mvp-btn-secondary">&#8592; Back to RFQs</a>
                </div>
            </t>

        </div>

    </t>
</template>

</odoo>
