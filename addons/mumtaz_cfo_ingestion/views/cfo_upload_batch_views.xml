<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_mumtaz_cfo_upload_batch_tree" model="ir.ui.view">
        <field name="name">mumtaz.cfo.upload.batch.tree</field>
        <field name="model">mumtaz.cfo.upload.batch</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="workspace_id"/>
                <field name="data_source_id"/>
                <field name="mapping_profile_id"/>
                <field name="upload_filename"/>
                <field name="file_type"/>
                <field name="state"/>
                <field name="uploaded_on"/>
            </list>
        </field>
    </record>

    <record id="view_mumtaz_cfo_upload_batch_form" model="ir.ui.view">
        <field name="name">mumtaz.cfo.upload.batch.form</field>
        <field name="model">mumtaz.cfo.upload.batch</field>
        <field name="arch" type="xml">
            <form string="CFO Upload Batch">
                <header>
                    <button name="action_generate_preview" string="Generate Preview" type="object" class="btn-primary"/>
                    <button name="action_mark_mapped" string="Mark Mapped" type="object" invisible="state in ('mapped', 'ready')"/>
                    <button name="action_mark_ready" string="Mark Ready" type="object" invisible="state == 'ready'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,uploaded,mapped,ready,failed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="workspace_id"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                            <field name="data_source_id"/>
                            <field name="mapping_profile_id"/>
                        </group>
                        <group>
                            <field name="upload_file" filename="upload_filename"/>
                            <field name="upload_filename" readonly="1"/>
                            <field name="file_type" readonly="1"/>
                            <field name="uploaded_by" readonly="1"/>
                            <field name="uploaded_on" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="preview_line_count" readonly="1"/>
                            <field name="row_count" readonly="1"/>
                            <field name="detected_columns" readonly="1"/>
                        </group>
                    </group>
                    <group string="Preview JSON">
                        <field name="preview_json" nolabel="1" readonly="1" widget="text"/>
                    </group>
                    <group string="Errors" invisible="not error_message">
                        <field name="error_message" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_mumtaz_cfo_upload_batch" model="ir.actions.act_window">
        <field name="name">Upload Batches</field>
        <field name="res_model">mumtaz.cfo.upload.batch</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
