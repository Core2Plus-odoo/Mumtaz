<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_switcher" name="Mumtaz Portal Switcher">
        <t t-call="mumtaz_portal_routing.portal_base_layout">

            <div class="mzp-switcher-page">
                <div class="mzp-switcher-header">
                    <h1>Select Portal</h1>
                    <p>You have access to multiple Mumtaz portals. Choose where to go.</p>
                </div>

                <div class="mzp-switcher-portal-grid">
                    <t t-foreach="portals" t-as="portal">
                        <a t-att-href="portal['url']" class="mzp-switcher-portal-card">
                            <t t-if="portal['type'] == 'admin'">
                                <div class="mzp-switcher-portal-icon">🏛️</div>
                            </t>
                            <t t-elif="portal['type'] == 'erp'">
                                <div class="mzp-switcher-portal-icon">📊</div>
                            </t>
                            <t t-elif="portal['type'] == 'zaki'">
                                <div class="mzp-switcher-portal-icon">🤖</div>
                            </t>
                            <t t-elif="portal['type'] == 'marketplace'">
                                <div class="mzp-switcher-portal-icon">🛒</div>
                            </t>
                            <t t-else="">
                                <div class="mzp-switcher-portal-icon">⬡</div>
                            </t>
                            <div class="mzp-switcher-portal-label">
                                <t t-esc="portal['label']"/>
                            </div>
                            <div class="mzp-switcher-portal-arrow">→</div>
                        </a>
                    </t>
                </div>
            </div>

        </t>
    </template>
</odoo>
