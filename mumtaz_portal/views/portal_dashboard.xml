<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="portal_dashboard" name="Mumtaz Portal – Dashboard">
    <t t-call="mumtaz_portal.portal_layout">
      <t t-set="title">Dashboard — Mumtaz</t>
      <t t-set="page_title">Dashboard</t>

      <!-- Greeting -->
      <div class="mz-page-hero">
        <div>
          <h1 class="mz-page-title">
            Good morning, <span class="mz-gradient-text" t-esc="(user.name or '').split()[0]"/>
          </h1>
          <p class="mz-page-sub">Here's your business snapshot for today.</p>
        </div>
        <div class="mz-hero-actions">
          <a class="mz-btn mz-btn-primary" href="/mumtaz/ai">Ask AI CFO</a>
          <t t-if="not onboarding_done">
            <a class="mz-btn mz-btn-ghost" href="/mumtaz/onboard">Continue Setup</a>
          </t>
        </div>
      </div>

      <!-- Onboarding banner -->
      <t t-if="not onboarding_done">
        <div class="mz-onboard-banner">
          <div class="mz-onboard-banner-left">
            <span class="mz-badge mz-badge-gold">Setup in progress</span>
            <p>Complete your setup to unlock all Mumtaz features and improve your finance readiness score.</p>
          </div>
          <div class="mz-onboard-banner-progress">
            <div class="mz-progress-ring" t-attf-data-pct="#{onboarding_pct}">
              <span t-esc="str(onboarding_pct) + '%'"/>
            </div>
          </div>
          <a class="mz-btn mz-btn-gold" href="/mumtaz/onboard">Continue →</a>
        </div>
      </t>

      <!-- KPI Cards -->
      <div class="mz-kpi-grid">
        <div class="mz-kpi-card">
          <div class="mz-kpi-icon" style="background:rgba(99,102,241,0.15);color:#a5b4fc">📈</div>
          <div class="mz-kpi-body">
            <div class="mz-kpi-label">Net Cash Position</div>
            <div class="mz-kpi-value mz-kpi-indigo">
              <t t-if="workspace">
                <t t-esc="'{:,.0f}'.format(net_position)"/>
                <span class="mz-kpi-currency" t-esc="workspace.currency_id.symbol or 'AED'"/>
              </t>
              <t t-else="">—</t>
            </div>
          </div>
        </div>
        <div class="mz-kpi-card">
          <div class="mz-kpi-icon" style="background:rgba(6,182,212,0.15);color:#67e8f9">🧾</div>
          <div class="mz-kpi-body">
            <div class="mz-kpi-label">Transactions Tracked</div>
            <div class="mz-kpi-value" t-esc="txn_count"/>
          </div>
        </div>
        <div class="mz-kpi-card">
          <div class="mz-kpi-icon" style="background:rgba(245,158,11,0.15);color:#fcd34d">⚠️</div>
          <div class="mz-kpi-body">
            <div class="mz-kpi-label">Items for Review</div>
            <div class="mz-kpi-value" t-attf-style="color: #{review_count > 0 and 'var(--mz-gold)' or 'var(--mz-text)'}">
              <t t-esc="review_count"/>
            </div>
          </div>
        </div>
        <div class="mz-kpi-card">
          <div class="mz-kpi-icon" style="background:rgba(16,185,129,0.15);color:#6ee7b7">✓</div>
          <div class="mz-kpi-body">
            <div class="mz-kpi-label">Setup Progress</div>
            <div class="mz-kpi-value mz-kpi-emerald" t-esc="str(onboarding_pct) + '%'"/>
          </div>
        </div>
      </div>

      <!-- Two-column lower section -->
      <div class="mz-dash-grid">

        <!-- Last AI Briefing -->
        <div class="mz-card">
          <div class="mz-card-header">
            <h3>Last AI CFO Briefing</h3>
            <a class="mz-card-link" href="/mumtaz/ai">View all →</a>
          </div>
          <t t-if="last_ai_session">
            <div class="mz-ai-snippet">
              <div class="mz-ai-bubble">
                <t t-esc="(last_ai_session.response or 'No response recorded.')[:300]"/>
                <t t-if="last_ai_session.response and len(last_ai_session.response) > 300">…</t>
              </div>
              <div class="mz-ai-meta">
                <span t-esc="last_ai_session.create_date.strftime('%d %b %Y, %H:%M') if last_ai_session.create_date else ''"/>
                <span t-if="last_ai_session.model_used" t-esc="last_ai_session.model_used"/>
              </div>
            </div>
          </t>
          <t t-else="">
            <div class="mz-empty-state">
              <div class="mz-empty-icon">🧠</div>
              <p>No AI briefings yet.</p>
              <a class="mz-btn mz-btn-primary" href="/mumtaz/ai">Start your first conversation</a>
            </div>
          </t>
        </div>

        <!-- Quick Actions -->
        <div class="mz-card">
          <div class="mz-card-header">
            <h3>Quick Actions</h3>
          </div>
          <div class="mz-quick-actions">
            <a class="mz-quick-action" href="/mumtaz/ai">
              <span class="mz-qa-icon">🧠</span>
              <div>
                <div class="mz-qa-title">Ask AI CFO</div>
                <div class="mz-qa-sub">Get instant business insight</div>
              </div>
            </a>
            <a class="mz-quick-action" href="/mumtaz/cfo">
              <span class="mz-qa-icon">📊</span>
              <div>
                <div class="mz-qa-title">Upload Transactions</div>
                <div class="mz-qa-sub">Sync your bank data</div>
              </div>
            </a>
            <a class="mz-quick-action" href="/mumtaz/finance">
              <span class="mz-qa-icon">💳</span>
              <div>
                <div class="mz-qa-title">Finance Hub</div>
                <div class="mz-qa-sub">View matched offers</div>
              </div>
            </a>
            <t t-if="review_count > 0">
              <a class="mz-quick-action mz-qa-warning" href="/mumtaz/cfo">
                <span class="mz-qa-icon">⚠️</span>
                <div>
                  <div class="mz-qa-title">Review Needed</div>
                  <div class="mz-qa-sub"><t t-esc="review_count"/> item(s) need attention</div>
                </div>
              </a>
            </t>
          </div>
        </div>

      </div>

    </t>
  </template>

</odoo>
