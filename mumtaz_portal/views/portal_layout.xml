<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ═══════════════════════════════════════════════════════════
       MUMTAZ PORTAL — Base Layout
       All portal pages inherit this template.
  ════════════════════════════════════════════════════════════════ -->
  <template id="portal_layout" name="Mumtaz Portal Layout">
    <t t-call="web.layout">
      <t t-set="head">
        <meta charset="UTF-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1"/>
        <title t-esc="title or 'Mumtaz Portal'"/>
        <link rel="preconnect" href="https://fonts.googleapis.com"/>
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin=""/>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap"/>
        <t t-call-assets="web.assets_frontend" t-css="true" t-js="false"/>
      </t>
      <t t-set="body_classname">mumtaz-portal-body</t>

      <!-- ── Portal Shell ── -->
      <div class="mz-shell">

        <!-- Sidebar -->
        <aside class="mz-sidebar" id="mzSidebar">
          <div class="mz-sidebar-header">
            <a href="/mumtaz/dashboard" class="mz-brand">
              <span class="mz-brand-mark"></span>
              <span class="mz-brand-name">Mumtaz</span>
            </a>
            <button class="mz-sidebar-close" id="mzSidebarClose" aria-label="Close menu">✕</button>
          </div>

          <!-- Onboarding progress bar -->
          <t t-if="onboarding and not onboarding_done">
            <div class="mz-onboard-progress">
              <div class="mz-onboard-label">
                <span>Setup Progress</span>
                <span t-esc="str(onboarding_pct) + '%'"/>
              </div>
              <div class="mz-progress-bar">
                <div class="mz-progress-fill" t-attf-style="width: #{onboarding_pct}%"></div>
              </div>
            </div>
          </t>

          <nav class="mz-nav">
            <a t-attf-class="mz-nav-item #{active_page == 'dashboard' and 'active' or ''}"
               href="/mumtaz/dashboard">
              <span class="mz-nav-icon">⬡</span>
              <span>Dashboard</span>
            </a>
            <a t-attf-class="mz-nav-item #{active_page == 'ai' and 'active' or ''}"
               href="/mumtaz/ai">
              <span class="mz-nav-icon">🧠</span>
              <span>AI CFO</span>
            </a>
            <a t-attf-class="mz-nav-item #{active_page == 'cfo' and 'active' or ''}"
               href="/mumtaz/cfo">
              <span class="mz-nav-icon">📊</span>
              <span>CFO Workspace</span>
            </a>
            <a t-attf-class="mz-nav-item #{active_page == 'finance' and 'active' or ''}"
               href="/mumtaz/finance">
              <span class="mz-nav-icon">💳</span>
              <span>Finance Hub</span>
            </a>
            <div class="mz-nav-divider"></div>
            <a t-attf-class="mz-nav-item #{active_page == 'profile' and 'active' or ''}"
               href="/mumtaz/profile">
              <span class="mz-nav-icon">⚙</span>
              <span>Profile &amp; Settings</span>
            </a>
            <a class="mz-nav-item" href="/web" target="_blank">
              <span class="mz-nav-icon">⊞</span>
              <span>Odoo Backend</span>
            </a>
            <a class="mz-nav-item" href="/web/session/logout">
              <span class="mz-nav-icon">⟵</span>
              <span>Sign Out</span>
            </a>
          </nav>

          <div class="mz-sidebar-footer">
            <div class="mz-user-chip">
              <div class="mz-user-avatar" t-esc="(user.name or 'U')[:1].upper()"/>
              <div class="mz-user-info">
                <div class="mz-user-name" t-esc="user.name"/>
                <div class="mz-user-company" t-esc="company.name"/>
              </div>
            </div>
          </div>
        </aside>

        <!-- Main content area -->
        <div class="mz-main">
          <!-- Top bar -->
          <header class="mz-topbar">
            <button class="mz-menu-btn" id="mzMenuBtn" aria-label="Open menu">☰</button>
            <div class="mz-topbar-title" t-esc="page_title or 'Dashboard'"/>
            <div class="mz-topbar-right">
              <a href="/mumtaz.digital" class="mz-topbar-link" target="_blank">mumtaz.digital ↗</a>
              <a href="/mumtaz/ai" class="mz-topbar-btn">Ask AI CFO</a>
            </div>
          </header>

          <!-- Flash messages -->
          <t t-if="success_msg">
            <div class="mz-alert mz-alert-success" t-esc="success_msg"/>
          </t>
          <t t-if="error_msg">
            <div class="mz-alert mz-alert-error" t-esc="error_msg"/>
          </t>

          <!-- Page content slot -->
          <main class="mz-content">
            <t t-out="0"/>
          </main>
        </div>
      </div>

      <!-- Sidebar overlay for mobile -->
      <div class="mz-overlay" id="mzOverlay"></div>

      <t t-call-assets="web.assets_frontend" t-css="false" t-js="true"/>
    </t>
  </template>

</odoo>
