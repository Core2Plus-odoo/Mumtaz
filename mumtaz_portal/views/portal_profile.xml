<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="portal_profile" name="Mumtaz Portal – Profile">
    <t t-call="mumtaz_portal.portal_layout">
      <t t-set="title">Profile &amp; Settings — Mumtaz</t>
      <t t-set="page_title">Profile &amp; Settings</t>

      <div class="mz-page-hero">
        <div>
          <h1 class="mz-page-title">Profile &amp; Settings</h1>
          <p class="mz-page-sub">Manage your business profile and platform preferences.</p>
        </div>
      </div>

      <div class="mz-profile-layout">
        <!-- Profile form -->
        <div class="mz-card">
          <div class="mz-card-header"><h3>Business Profile</h3></div>
          <form class="mz-profile-form" id="mzProfileForm">
            <div class="mz-field-row">
              <div class="mz-field-group">
                <label>Legal Business Name</label>
                <input type="text" name="legal_name"
                       t-att-value="sme_profile.legal_name if sme_profile else company.name"
                       placeholder="Registered legal name"/>
              </div>
              <div class="mz-field-group">
                <label>Trading / Brand Name</label>
                <input type="text" name="trade_name"
                       t-att-value="sme_profile.trade_name if sme_profile else ''"
                       placeholder="Trading name"/>
              </div>
            </div>
            <div class="mz-field-row">
              <div class="mz-field-group">
                <label>Industry</label>
                <select name="industry">
                  <t t-foreach="industry_options" t-as="opt">
                    <option t-att-value="opt[0]"
                            t-att-selected="sme_profile and sme_profile.industry == opt[0] and 'selected' or None"
                            t-esc="opt[1]"/>
                  </t>
                </select>
              </div>
              <div class="mz-field-group">
                <label>City</label>
                <input type="text" name="city"
                       t-att-value="sme_profile.city if sme_profile else ''"
                       placeholder="City"/>
              </div>
            </div>
            <div id="mzProfileMsg" class="mz-form-msg" style="display:none"></div>
            <button type="submit" class="mz-btn mz-btn-primary">Save Changes</button>
          </form>
        </div>

        <!-- Account info -->
        <div class="mz-card">
          <div class="mz-card-header"><h3>Account</h3></div>
          <div class="mz-account-info">
            <div class="mz-acct-row">
              <span class="mz-acct-label">Name</span>
              <span t-esc="user.name"/>
            </div>
            <div class="mz-acct-row">
              <span class="mz-acct-label">Email</span>
              <span t-esc="user.email or user.login"/>
            </div>
            <div class="mz-acct-row">
              <span class="mz-acct-label">Company</span>
              <span t-esc="company.name"/>
            </div>
          </div>
          <div style="margin-top:16px; display:flex; gap:10px; flex-wrap:wrap">
            <a class="mz-btn mz-btn-ghost mz-btn-sm" href="/web#action=base_setup.action_general_configuration">
              Platform Settings ↗
            </a>
            <a class="mz-btn mz-btn-ghost mz-btn-sm" href="/web/session/logout">Sign Out</a>
          </div>
        </div>

        <!-- Platform links -->
        <div class="mz-card">
          <div class="mz-card-header"><h3>Platform Links</h3></div>
          <div class="mz-platform-links">
            <a class="mz-plat-link" href="https://mumtaz.digital" target="_blank">
              <span class="mz-plat-icon">🌐</span>
              <div>
                <div class="mz-plat-title">Marketing Site</div>
                <div class="mz-plat-url">mumtaz.digital</div>
              </div>
            </a>
            <a class="mz-plat-link" href="/mumtaz/ai">
              <span class="mz-plat-icon">🧠</span>
              <div>
                <div class="mz-plat-title">AI CFO Chat</div>
                <div class="mz-plat-url">app / AI</div>
              </div>
            </a>
            <a class="mz-plat-link" href="/mumtaz/cfo">
              <span class="mz-plat-icon">📊</span>
              <div>
                <div class="mz-plat-title">CFO Workspace</div>
                <div class="mz-plat-url">app / CFO</div>
              </div>
            </a>
            <a class="mz-plat-link" href="/mumtaz/finance">
              <span class="mz-plat-icon">💳</span>
              <div>
                <div class="mz-plat-title">Finance Hub</div>
                <div class="mz-plat-url">app / Finance</div>
              </div>
            </a>
          </div>
        </div>
      </div>
    </t>
  </template>

</odoo>
