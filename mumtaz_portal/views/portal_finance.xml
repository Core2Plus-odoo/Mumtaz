<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="portal_finance" name="Mumtaz Portal – Finance Hub">
    <t t-call="mumtaz_portal.portal_layout">
      <t t-set="title">Finance Hub — Mumtaz</t>
      <t t-set="page_title">Finance Hub</t>

      <div class="mz-page-hero">
        <div>
          <h1 class="mz-page-title">Finance Hub</h1>
          <p class="mz-page-sub">Your credit readiness score and matched finance products from our partner network.</p>
        </div>
      </div>

      <!-- Credit Score Widget -->
      <div class="mz-finance-top">
        <div class="mz-credit-card">
          <div class="mz-credit-label">Credit Readiness Score</div>
          <div class="mz-credit-score-ring">
            <svg viewBox="0 0 120 120" class="mz-score-svg">
              <circle cx="60" cy="60" r="50" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="10"/>
              <circle cx="60" cy="60" r="50" fill="none"
                      t-attf-stroke="#{score_band == 'excellent' and '#6366f1' or score_band == 'strong' and '#06b6d4' or score_band == 'building' and '#f59e0b' or '#f43f5e'}"
                      stroke-width="10"
                      stroke-linecap="round"
                      t-attf-stroke-dasharray="#{int(credit_score * 3.14)} 314"
                      stroke-dashoffset="78"
                      transform="rotate(-90 60 60)"/>
            </svg>
            <div class="mz-score-inner">
              <div class="mz-score-number" t-esc="credit_score"/>
              <div class="mz-score-max">/100</div>
            </div>
          </div>
          <div t-attf-class="mz-score-band mz-band-#{score_band}">
            <t t-if="score_band == 'excellent'">Excellent</t>
            <t t-elif="score_band == 'strong'">Strong</t>
            <t t-elif="score_band == 'building'">Building</t>
            <t t-else="">Early Stage</t>
          </div>
          <p class="mz-credit-sub">Based on your operational data and platform engagement</p>
        </div>

        <!-- Score Factors -->
        <div class="mz-card mz-score-factors">
          <div class="mz-card-header">
            <h3>What makes up your score</h3>
          </div>
          <div class="mz-factor-list">
            <t t-foreach="score_factors" t-as="factor">
              <div class="mz-factor-row">
                <div class="mz-factor-name">
                  <span t-attf-class="mz-factor-check #{factor[2] and 'mz-check-done' or 'mz-check-todo'}">
                    <t t-if="factor[2]">✓</t>
                    <t t-else="">○</t>
                  </span>
                  <t t-esc="factor[0]"/>
                </div>
                <div class="mz-factor-pts">
                  <t t-if="factor[2]">
                    <span class="mz-pts-done">+<t t-esc="factor[1]"/> pts</span>
                  </t>
                  <t t-else="">
                    <span class="mz-pts-todo"><t t-esc="factor[1]"/> pts available</span>
                  </t>
                </div>
              </div>
            </t>
          </div>
          <t t-if="credit_score &lt; 100">
            <a class="mz-btn mz-btn-ghost mz-btn-full" href="/mumtaz/onboard">
              Improve your score →
            </a>
          </t>
        </div>
      </div>

      <!-- Matched Finance Offers -->
      <div class="mz-card" style="margin-top:28px">
        <div class="mz-card-header">
          <h3>Matched Finance Products</h3>
          <span class="mz-badge mz-badge-indigo">
            <t t-esc="len(partner_offers)"/> matched
          </span>
        </div>
        <div class="mz-offers-grid">
          <t t-foreach="partner_offers" t-as="offer">
            <div class="mz-offer-card">
              <div class="mz-offer-top">
                <span class="mz-offer-icon" t-esc="offer.get('icon', '🏦')"/>
                <span t-attf-class="mz-badge #{offer.get('badge_class', 'mz-badge-indigo')}"
                      t-esc="offer.get('badge', '')"/>
              </div>
              <h4 class="mz-offer-title" t-esc="offer.get('title', '')"/>
              <div class="mz-offer-provider" t-esc="offer.get('provider', '')"/>
              <div class="mz-offer-details">
                <div class="mz-offer-detail">
                  <span class="mz-offer-detail-label">Amount</span>
                  <span t-esc="offer.get('amount', '')"/>
                </div>
                <div class="mz-offer-detail">
                  <span class="mz-offer-detail-label">Rate</span>
                  <span t-esc="offer.get('rate', '')"/>
                </div>
              </div>
              <a class="mz-btn mz-btn-ghost mz-btn-sm mz-btn-full" href="/mumtaz.digital/contact.html">
                Enquire →
              </a>
            </div>
          </t>
        </div>
      </div>

      <!-- Improve CTA -->
      <t t-if="credit_score &lt; 60">
        <div class="mz-cta-band" style="margin-top:28px">
          <h3>Unlock more finance options</h3>
          <p>Complete your setup and upload 3+ months of transactions to improve your score and unlock premium partner offers.</p>
          <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
            <a class="mz-btn mz-btn-primary" href="/mumtaz/onboard">Continue Setup</a>
            <a class="mz-btn mz-btn-ghost" href="/mumtaz/cfo">Upload Transactions</a>
          </div>
        </div>
      </t>

    </t>
  </template>

</odoo>
