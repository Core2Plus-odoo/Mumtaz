<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="portal_ai" name="Mumtaz Portal – AI CFO">
    <t t-call="mumtaz_portal.portal_layout">
      <t t-set="title">AI CFO — Mumtaz</t>
      <t t-set="page_title">AI CFO</t>

      <div class="mz-ai-layout">

        <!-- Session sidebar -->
        <aside class="mz-ai-sidebar">
          <a class="mz-btn mz-btn-primary mz-btn-full" href="/mumtaz/ai/new">+ New Conversation</a>
          <div class="mz-sessions-label">Recent Sessions</div>
          <div class="mz-sessions-list">
            <t t-foreach="recent_sessions" t-as="sess">
              <a t-attf-href="/mumtaz/ai?session_id=#{sess.id}"
                 t-attf-class="mz-session-item #{ai_session and ai_session.id == sess.id and 'active' or ''}">
                <div class="mz-session-name">
                  <t t-esc="(sess.name or 'Chat')[:30]"/>
                </div>
                <div class="mz-session-date">
                  <t t-esc="sess.create_date.strftime('%d %b') if sess.create_date else ''"/>
                </div>
              </a>
            </t>
            <t t-if="not recent_sessions">
              <div class="mz-sessions-empty">No sessions yet</div>
            </t>
          </div>
        </aside>

        <!-- Chat area -->
        <div class="mz-chat-area">
          <div class="mz-chat-messages" id="mzChatMessages">
            <t t-if="not ai_messages">
              <!-- Welcome state -->
              <div class="mz-chat-welcome">
                <div class="mz-welcome-icon">🧠</div>
                <h2>Ask your AI CFO anything</h2>
                <p>Get instant answers on cash flow, business performance, risk, and financial strategy.</p>
                <div class="mz-chat-starters">
                  <button class="mz-starter" data-msg="What is my current cash position and runway?">
                    What is my cash runway?
                  </button>
                  <button class="mz-starter" data-msg="Give me a financial health summary of my business.">
                    Financial health summary
                  </button>
                  <button class="mz-starter" data-msg="What should I focus on this week to improve my business performance?">
                    This week's priorities
                  </button>
                  <button class="mz-starter" data-msg="Am I ready to apply for a business loan? What's my credit readiness?">
                    Am I credit-ready?
                  </button>
                </div>
              </div>
            </t>
            <t t-foreach="ai_messages" t-as="msg">
              <div t-attf-class="mz-msg mz-msg-#{msg.role}">
                <div class="mz-msg-avatar">
                  <t t-if="msg.role == 'assistant'">🧠</t>
                  <t t-else=""><t t-esc="(user.name or 'U')[:1].upper()"/></t>
                </div>
                <div class="mz-msg-bubble">
                  <div class="mz-msg-text" t-esc="msg.response if msg.role == 'assistant' else msg.prompt"/>
                  <div class="mz-msg-meta">
                    <t t-if="msg.intent and msg.intent != 'general'">
                      <span class="mz-intent-tag" t-esc="msg.intent.replace('_', ' ').title()"/>
                    </t>
                    <t t-if="msg.model_used">
                      <span class="mz-model-tag" t-esc="msg.model_used"/>
                    </t>
                  </div>
                </div>
              </div>
            </t>
            <!-- Thinking indicator (hidden, shown by JS) -->
            <div class="mz-msg mz-msg-assistant mz-thinking" id="mzThinking" style="display:none">
              <div class="mz-msg-avatar">🧠</div>
              <div class="mz-msg-bubble">
                <div class="mz-thinking-dots">
                  <span></span><span></span><span></span>
                </div>
              </div>
            </div>
          </div>

          <!-- Input bar -->
          <div class="mz-chat-input-bar">
            <form id="mzChatForm" class="mz-chat-form"
                  t-attf-data-session="#{ai_session and ai_session.id or ''}">
              <textarea
                id="mzChatInput"
                class="mz-chat-input"
                placeholder="Ask your AI CFO anything about your business…"
                rows="1"
                autocomplete="off"></textarea>
              <button type="submit" class="mz-chat-send" id="mzChatSend" aria-label="Send">
                ↑
              </button>
            </form>
            <div class="mz-chat-hints">
              Press Enter to send · Shift+Enter for new line
            </div>
          </div>
        </div>

      </div>
    </t>
  </template>

</odoo>
