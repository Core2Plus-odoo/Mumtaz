# ── General ──────────────────────────────────────────────────────────
ENVIRONMENT=local

# ── PostgreSQL (for Odoo) ─────────────────────────────────────────────
POSTGRES_DB=mumtaz
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo

# ── Odoo ─────────────────────────────────────────────────────────────
ODOO_URL=http://localhost:8069
ODOO_DB=mumtaz
# admin_passwd from odoo.conf — required for database provisioning
ODOO_MASTER_PASS=admin
ODOO_ADMIN=admin@mumtaz.digital
ODOO_PASS=admin
ODOO_ADDONS_PATH=/opt/custom_addons

# ── ZAKI server (port 8001) ───────────────────────────────────────────
JWT_SECRET=change-me-in-production
ANTHROPIC_API_KEY=sk-ant-...

# ── ERP server (port 8002) ───────────────────────────────────────────
ERP_SECRET=change-me-in-production

# ── Email / SMTP ─────────────────────────────────────────────────────
EMAIL_FROM=noreply@mumtaz.digital
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Stripe ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Redis ────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
